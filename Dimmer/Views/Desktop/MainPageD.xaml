           <DataTemplate x:DataType="models:SongsModelView">
               <Label Text="{Binding .}" VerticalTextAlignment="Center" HorizontalTextAlignment="Justify"/>
           </DataTemplate>
       </dg:DataGridColumn.CellTemplate>
   </dg:DataGridColumn>


