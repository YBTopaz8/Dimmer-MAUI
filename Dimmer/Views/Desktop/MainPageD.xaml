               <Image WidthRequest="13" VerticalOptions="Center" IsVisible="{Binding .}">
                   <Image.Source>
                       <FontImageSource FontFamily="MaterialRounded" Glyph="{x:Static m:MaterialRounded.Lyrics}"/>
                   </Image.Source>
               </Image>

           </DataTemplate>
       </dg:DataGridColumn.CellTemplate>
   </dg:DataGridColumn>
   
