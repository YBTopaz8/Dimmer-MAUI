<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="Dimmer.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:Dimmer.Utilities.TypeConverters"
    xmlns:local="clr-namespace:Dimmer"
    >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary x:Name="appColors" Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary x:Name="appStyles" Source="Resources/Styles/Styles.xaml" />

            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter" />
            <converters:BoolToInverseConverter x:Key="BoolToInverseConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:PlayTypeToBorderBrush x:Key="PlayTypeToBorderBrushConv" />
            <converters:OtherArtistNamesToListOfStringsConverter x:Key="OtherArtistNamesToListOfStringsConverter" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
