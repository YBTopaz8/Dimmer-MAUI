<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.ArtistPage"
    x:Name="MyArtistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Dimmer.Utilities.TypeConverters;assembly=Dimmer"
    xmlns:convertersWinUI="using:Dimmer.WinUI.Utils.Converters"
    xmlns:cw="using:Dimmer.WinUI.Views.WinuiPages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:devWin="using:DevWinUI"
    xmlns:dgView="using:WinUI.TableView"
    xmlns:dimmSearch="clr-namespace:Dimmer.Data.ModelView.DimmerSearch;assembly=Dimmer"
    xmlns:lang="clr-namespace:Dimmer.Resources.Localization;assembly=Dimmer"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:modelsDb="clr-namespace:Dimmer.Data.Models;assembly=Dimmer"
    xmlns:modeltwo="clr-namespace:Dimmer.WinUI.Utils.Models"
    xmlns:statsModels="clr-namespace:Dimmer.Charts;assembly=Dimmer"
    xmlns:statsVM="clr-namespace:Dimmer.ViewModel.StatsVMs;assembly=Dimmer"
    xmlns:tql="clr-namespace:Dimmer.DimmerSearch.TQL;assembly=Dimmer"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:vm="clr-namespace:Dimmer.WinUI.ViewModel"
    PointerPressed="MyArtistPage_PointerPressed"
    mc:Ignorable="d"
    >

    <ScrollViewer>

        <Grid Padding="5" Background="#222222">

            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Image
                        x:Name="ArtistImg"
                        Width="130"
                        Loaded="ArtistImg_Loaded"
                        />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{x:Bind MyViewModel.SelectedArtist.Name, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.SelectedArtist.Bio, Mode=OneWay}" />

                    <ItemsControl x:Name="loopingList" ItemsSource="{x:Bind MyViewModel.SelectedArtist.AlbumsByArtist, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <devWin:LoopPanel
                                    Background="Transparent"
                                    BringChildrenIntoView="False"
                                    IsInertiaEnabled="True"
                                    Orientation="Horizontal"
                                    Spacing="5"
                                    />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel
                                    Margin="10,10,0,0"
                                    Padding="5"
                                    Background="Transparent"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    >
                                    <Image
                                        Width="150"
                                        Height="150"
                                        Source="{Binding ImagePath}"
                                        Stretch="Uniform"
                                        />
                                    <devWin:AutoScrollView RequiresPointer="WhenFocused">

                                        <TextBlock Text="{Binding Name}" />

                                    </devWin:AutoScrollView>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Grid>

            <Pivot Grid.Row="1">

                <PivotItem Header="Overview">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <dgView:TableView
                            x:Name="ArtistSongsDG"
                            Height="400"
                            AutoGenerateColumns="False"
                            CellDoubleTapped="ArtistSongsDG_CellDoubleTapped"
                            Loaded="ArtistSongsDG_Loaded"
                            >
                            <dgView:TableView.Columns>
                                <dgView:TableViewTemplateColumn>
                                    <dgView:TableViewTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Image Height="45" Source="{Binding CoverImagePath}" />
                                                <TextBlock Text="{Binding FileFormat}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </dgView:TableViewTemplateColumn.CellTemplate>
                                </dgView:TableViewTemplateColumn>
                                <dgView:TableViewTextColumn
                                    Width="*"
                                    Binding="{Binding Title}"
                                    Header="Title"
                                    />
                                <dgView:TableViewTextColumn
                                    Width="*"
                                    Binding="{Binding OtherArtistsName}"
                                    Header="Artists"
                                    />
                                <dgView:TableViewTextColumn Width="*" Binding="{Binding AlbumName}" />
                                <dgView:TableViewTextColumn Width="*" Binding="{Binding GenreName}" />
                                <dgView:TableViewTextColumn
                                    Width="50"
                                    Binding="{Binding PlayCompletedCount}"
                                    Header="Dims"
                                    />
                                <dgView:TableViewTextColumn
                                    Width="80"
                                    Binding="{Binding DurationFormatted}"
                                    Header="Duration"
                                    />
                            </dgView:TableView.Columns>
                        </dgView:TableView>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Statistics">
                    <Grid Padding="5" Background="#222222">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <StackPanel
                                x:Name="SongStats"
                                Grid.Row="0"
                                Loaded="SongStats_Loaded"
                                Orientation="Horizontal"
                                >
                                <devWin:Card
                                    Title="{x:Bind MyArtistStatsViewModel.TextBingeRecord.Title, Mode=OneWay}"
                                    Content="{x:Bind MyArtistStatsViewModel.TextBingeRecord.Value, Mode=OneWay}"
                                    TitleContent="{x:Bind MyArtistStatsViewModel.TextBingeRecord.Subtitle, Mode=OneWay}"
                                    />



                                <devWin:Card
                                    Title="{x:Bind MyArtistStatsViewModel.TextTotalTime.Title, Mode=OneWay}"
                                    Content="{x:Bind MyArtistStatsViewModel.TextTotalTime.Value, Mode=OneWay}"
                                    TitleContent="{x:Bind MyArtistStatsViewModel.TextTotalTime.Subtitle, Mode=OneWay}"
                                    />

                                <devWin:Card
                                    Title="{x:Bind MyArtistStatsViewModel.TextLoyaltyIndex.Title, Mode=OneWay}"
                                    Content="{x:Bind MyArtistStatsViewModel.TextLoyaltyIndex.Value, Mode=OneWay}"
                                    TitleContent="{x:Bind MyArtistStatsViewModel.TextLoyaltyIndex.Subtitle, Mode=OneWay}"
                                    />

                                <devWin:Card
                                    Title="{x:Bind MyArtistStatsViewModel.TextYoYGrowth.Title, Mode=OneWay}"
                                    Content="{x:Bind MyArtistStatsViewModel.TextYoYGrowth.Value, Mode=OneWay}"
                                    TitleContent="{x:Bind MyArtistStatsViewModel.TextYoYGrowth.Subtitle, Mode=OneWay}"
                                    />

                                <devWin:Card
                                    Title="{x:Bind MyArtistStatsViewModel.TextLifespan.Title, Mode=OneWay}"
                                    Content="{x:Bind MyArtistStatsViewModel.TextLifespan.Value, Mode=OneWay}"
                                    TitleContent="{x:Bind MyArtistStatsViewModel.TextLifespan.Subtitle, Mode=OneWay}"
                                    />

                            </StackPanel>

                            <devWin:CoverFlow
                                x:Name="StoreCarouselTopSongs"
                                Height="350"
                                Loaded="StoreCarouselTopSongs_Loaded"
                                >
                                <devWin:CoverFlow.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="5">
                                            <Image Source="{Binding ImagePath}" />
                                            <TextBlock
                                                Style="{ThemeResource BaseTextBlockStyle}"
                                                Text="{Binding Name}"
                                                TextTrimming="CharacterEllipsis"
                                                />

                                        </StackPanel>
                                    </DataTemplate>

                                </devWin:CoverFlow.ItemTemplate>
                            </devWin:CoverFlow>

                        </StackPanel>


                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />

                            </Grid.ColumnDefinitions>

                            <ItemsRepeater
                                x:Name="ListPlaySkipRatio"
                                Grid.Column="0"
                                Height="350"
                                Loaded="ListPlaySkipRatio_Loaded"
                                >
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel
                                            Padding="10"
                                            BorderBrush="{Binding ColorHex}"
                                            BorderThickness="1"
                                            CornerRadius="20"
                                            >
                                            <TextBlock Text="{Binding Title}" />
                                            <TextBlock Text="{Binding Description}" />
                                            <TextBlock Text="{Binding Icon}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <ItemsRepeater
                                x:Name="ListDeepCuts"
                                Grid.Column="1"
                                Height="350"
                                Loaded="ListDeepCuts_Loaded"
                                >
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Rank}" />
                                            <Image Grid.Column="1" Source="{Binding ImagePath}" />
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Text="{Binding SubValue}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <ItemsRepeater
                                x:Name="ListMonthlyTrend"
                                Grid.Column="2"
                                Height="350"
                                Loaded="ListMonthlyTrend_Loaded"
                                >
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel
                                            Padding="10"
                                            BorderBrush="Gray"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            >
                                            <StackPanel Orientation="Horizontal" Spacing="5">

                                                <TextBlock Text="Period" />
                                                <TextBlock Text="{Binding Period}" />
                                                <StackPanel Orientation="Horizontal" Spacing="5">

                                                    <TextBlock Text="(" />
                                                    <TextBlock Text="{Binding PlayCount}" />
                                                    <TextBlock Text=" dims)" />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="5">

                                                <TextBlock Text="ChangeVsPrevious" />
                                                <TextBlock Text="{Binding ChangeVsPrevious}" />
                                            </StackPanel>

                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <ItemsRepeater
                                x:Name="ListTopAlbums"
                                Grid.Column="3"
                                Height="350"
                                Loaded="ListTopAlbums_Loaded"
                                >
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Rank}" />
                                            <Image Grid.Column="1" Source="{Binding ImagePath}" />
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Text="{Binding SubValue}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>



                            <ItemsRepeater
                                x:Name="ListEraPreference"
                                Grid.Column="4"
                                Height="350"
                                Loaded="ListEraPreference_Loaded"
                                >
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel
                                            Padding="10"
                                            BorderBrush="Gray"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            >
                                            <StackPanel Orientation="Horizontal" Spacing="5">

                                                <TextBlock Text="Period" />
                                                <TextBlock Text="{Binding Period}" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="5">

                                                <TextBlock Text="Play Count" />
                                                <TextBlock Text="{Binding PlayCount}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="5">

                                                <TextBlock Text="ChangeVsPrevious" />
                                                <TextBlock Text="{Binding ChangeVsPrevious}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>



                        </Grid>
                    </Grid>
                </PivotItem>
            </Pivot>

        </Grid>

    </ScrollViewer>
</Page>
