<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.ArtistPage"
    x:Name="MyArtistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Dimmer.Utilities.TypeConverters;assembly=Dimmer"
    xmlns:convertersWinUI="using:Dimmer.WinUI.Utils.Converters"
    xmlns:cw="using:Dimmer.WinUI.Views.WinuiPages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:devWin="using:DevWinUI"
    xmlns:dgView="using:WinUI.TableView"
    xmlns:dimmSearch="clr-namespace:Dimmer.Data.ModelView.DimmerSearch;assembly=Dimmer"
    xmlns:lang="clr-namespace:Dimmer.Resources.Localization;assembly=Dimmer"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:modelsDb="clr-namespace:Dimmer.Data.Models;assembly=Dimmer"
    xmlns:modeltwo="clr-namespace:Dimmer.WinUI.Utils.Models"
    xmlns:tql="clr-namespace:Dimmer.DimmerSearch.TQL;assembly=Dimmer"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:vm="clr-namespace:Dimmer.WinUI.ViewModel"
    PointerPressed="MyArtistPage_PointerPressed"
    mc:Ignorable="d"
    >


    <Grid Padding="5" Background="#222222">

        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Image
                    x:Name="ArtistImg"
                    Width="130"
                    Loaded="ArtistImg_Loaded"
                    />
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="{x:Bind SelectedArtist.Name, Mode=OneWay}" />
                <TextBlock Text="{x:Bind SelectedArtist.Bio, Mode=OneWay}" />

                <ItemsControl x:Name="loopingList" ItemsSource="{x:Bind MyViewModel.SelectedArtist.AlbumsByArtist, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <devWin:LoopPanel
                                Background="Transparent"
                                BringChildrenIntoView="False"
                                IsInertiaEnabled="True"
                                Orientation="Horizontal"
                                Spacing="5"
                                />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel
                                Margin="10,10,0,0"
                                Padding="5"
                                Background="Transparent"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                >
                                <Image
                                    Width="150"
                                    Height="150"
                                    Source="{Binding ImagePath}"
                                    Stretch="Uniform"
                                    />
                                <devWin:AutoScrollView RequiresPointer="WhenFocused">

                                    <TextBlock Text="{Binding Name}" />

                                </devWin:AutoScrollView>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Grid>

        <StackPanel
            x:Name="SongStats"
            Grid.Row="1"
            Loaded="SongStats_Loaded"
            Orientation="Horizontal"
            >
            <StackPanel
                Padding="10"
                BorderThickness="1"
                CornerRadius="20"
                >

                <TextBlock FontSize="20" Text="{x:Bind MyArtistStatsViewModel.TextBingeScore.Title, Mode=OneWay}" />
                <TextBlock FontSize="16" Text="{x:Bind MyArtistStatsViewModel.TextBingeScore.Subtitle, Mode=OneWay}" />
                <devWin:Divider />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{x:Bind MyArtistStatsViewModel.TextBingeScore.Value, Mode=OneWay}" />
                </Grid>
            </StackPanel>

            <devWin:Divider />
            <StackPanel
                Padding="10"
                BorderThickness="1"
                CornerRadius="20"
                >

                <TextBlock FontSize="20" Text="{x:Bind MyArtistStatsViewModel.TextDiscoveryComparison.Title, Mode=OneWay}" />
                <TextBlock FontSize="16" Text="{x:Bind MyArtistStatsViewModel.TextDiscoveryComparison.Subtitle, Mode=OneWay}" />
                <devWin:Divider />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{x:Bind MyArtistStatsViewModel.TextDiscoveryComparison.Value, Mode=OneWay}" />
                </Grid>
            </StackPanel>

            <devWin:Divider />
            <StackPanel
                Padding="10"
                BorderThickness="1"
                CornerRadius="20"
                >

                <TextBlock FontSize="20" Text="{x:Bind MyArtistStatsViewModel.TextLoyaltyIndex.Title, Mode=OneWay}" />
                <TextBlock FontSize="16" Text="{x:Bind MyArtistStatsViewModel.TextLoyaltyIndex.Subtitle, Mode=OneWay}" />
                <devWin:Divider />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{x:Bind MyArtistStatsViewModel.TextLoyaltyIndex.Value, Mode=OneWay}" />
                </Grid>
            </StackPanel>

            <devWin:Divider />





        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />

            </Grid.ColumnDefinitions>

            <ItemsRepeater
                x:Name="ListInsights"
                Grid.Column="0"
                Height="350"
                Loaded="ListInsights_Loaded"
                >
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <StackPanel
                            Padding="10"
                            BorderBrush="{Binding ColorHex}"
                            BorderThickness="1"
                            CornerRadius="20"
                            >
                            <TextBlock Text="{Binding Title}" />
                            <TextBlock Text="{Binding Description}" />
                            <TextBlock Text="{Binding Icon}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
            <ItemsRepeater
                x:Name="ListTopSongs"
                Grid.Column="1"
                Height="350"
                Loaded="ListTopSongs_Loaded"
                >
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Rank}" />
                            <Image Grid.Column="1" Source="{Binding ImagePath}" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text="{Binding SubValue}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <ItemsRepeater
                x:Name="ListDeepCuts"
                Grid.Column="2"
                Height="350"
                Loaded="ListDeepCuts_Loaded"
                >
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Rank}" />
                            <Image Grid.Column="1" Source="{Binding ImagePath}" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text="{Binding SubValue}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <ItemsRepeater
                x:Name="ListMonthlyTrend"
                Grid.Column="3"
                Height="350"
                Loaded="ListMonthlyTrend_Loaded"
                >
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <StackPanel
                            Padding="10"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="10"
                            >
                            <StackPanel Orientation="Horizontal" Spacing="5">

                                <TextBlock Text="Period" />
                                <TextBlock Text="{Binding Period}" />
                                <StackPanel Orientation="Horizontal" Spacing="5">

                                    <TextBlock Text="(" />
                                    <TextBlock Text="{Binding PlayCount}" />
                                    <TextBlock Text=" dims)" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="5">

                                <TextBlock Text="ChangeVsPrevious" />
                                <TextBlock Text="{Binding ChangeVsPrevious}" />
                            </StackPanel>

                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <ItemsRepeater
                x:Name="ListTopAlbums"
                Grid.Column="4"
                Height="350"
                Loaded="ListTopAlbums_Loaded"
                >
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Rank}" />
                            <Image Grid.Column="1" Source="{Binding ImagePath}" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text="{Binding SubValue}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>



            <ItemsRepeater
                Grid.Column="5"
                Height="350"
                Loaded="ListInsights_Loaded"
                >
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <StackPanel
                            Padding="10"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="10"
                            >
                            <StackPanel Orientation="Horizontal" Spacing="5">

                                <TextBlock Text="Period" />
                                <TextBlock Text="{Binding Period}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="5">

                                <TextBlock Text="Play Count" />
                                <TextBlock Text="{Binding PlayCount}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">

                                <TextBlock Text="ChangeVsPrevious" />
                                <TextBlock Text="{Binding ChangeVsPrevious}" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>



        </Grid>


    </Grid>

</Page>
