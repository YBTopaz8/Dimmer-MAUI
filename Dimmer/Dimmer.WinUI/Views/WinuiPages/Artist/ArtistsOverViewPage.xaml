<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.Artist.ArtistsOverViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages.Artist"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    >


    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <SelectorBar
            x:Name="ArtistSelectorBar"
            Grid.Row="0"
            SelectionChanged="ArtistSelectorBar_SelectionChanged"
            >
            <SelectorBarItem
                x:Name="AllArtistsSelector"
                IsSelected="True"
                Text="All Artists"
                />
            <SelectorBarItem x:Name="ArtistAlbumsSelector" Text="Artist Albums" />
            <SelectorBarItem x:Name="ArtistSongsSelector" Text="Artist Songs" />
        </SelectorBar>
        <StackPanel
            x:Name="TopRightOptionSection"
            Grid.Column="1"
            Margin="5"
            >
            <Button Click="FetchAllInfos_Click" Content="Fetch Artist Images" />
        </StackPanel>
        <Frame
            x:Name="ArtistContentFrame"
            Grid.Row="1"
            Grid.ColumnSpan="2"
            x:FieldModifier="Public"
            IsNavigationStackEnabled="False"
            />
    </Grid>
</Page>
