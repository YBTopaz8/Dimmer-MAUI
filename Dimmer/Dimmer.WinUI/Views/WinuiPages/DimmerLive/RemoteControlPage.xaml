<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.DimmerLive.RemoteControlPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dgView="using:WinUI.TableView"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages.DimmerLive"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Dimmer.DimmerLive.Models"
    DataContext=""
    mc:Ignorable="d"
    >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Button
                    x:Name="GetAllSongs"
                    Click="GetAllSongs_Click"
                    Content="Get All Songs"
                    />
                <Button
                    x:Name="GetPlayBackQueue"
                    Click="GetPlayBackQueue_Click"
                    Content="Get Current Queue"
                    />
                <Button
                    x:Name="GetFavs"
                    Click="GetFavs_Click"
                    Content="Get Favorites"
                    />

            </StackPanel>
        </StackPanel>

        <dgView:TableView
            Grid.Row="1"
            AutoGenerateColumns="True"
            ItemsSource="{x:Bind MyViewModel.SessionMgtVM.FavSongs, Mode=OneWay}"
            />
    </Grid>
</Page>
