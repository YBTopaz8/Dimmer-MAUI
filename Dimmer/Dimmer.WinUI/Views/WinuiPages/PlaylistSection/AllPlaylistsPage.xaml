<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.PlaylistSection.AllPlaylistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:converters="using:Dimmer.WinUI.Utils.Converters"
    xmlns:customViews="using:Dimmer.WinUI.Views.CustomViews.WinuiViews"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:devWin="using:DevWinUI"
    xmlns:dgView="using:WinUI.TableView"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages.PlaylistSection"
    xmlns:localViews="using:Dimmer.WinUI.Views.CustomViews.WinuiViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:stateTriggers="using:Dimmer.WinUI.Utils.StateTriggers"
    mc:Ignorable="d"
    >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Playlists" />
        </StackPanel>


        <dgView:TableView
            x:Name="PlaylistsListTableView"
            Grid.Row="1" IsReadOnly="True"
            AutoGenerateColumns="False"
            ItemClick="PlaylistsListTableView_ItemClick"
            ItemsSource="{x:Bind MyViewModel.PlaylistsCollection, Mode=OneWay}"
            Tapped="PlaylistsListTableView_Tapped"
            CellDoubleTapped="PlaylistsListTableView_CellDoubleTapped"
            RowDoubleTapped="PlaylistsListTableView_RowDoubleTapped"
            DoubleTapped="PlaylistsListTableView_DoubleTapped">
            <dgView:TableView.Columns>
                <dgView:TableViewTextColumn Binding="{Binding PlaylistName}"
                                            Header="Name"/>
                
                <dgView:TableViewTextColumn Binding="{Binding QueryText}"
                                            Header="TQL Query"/>
                
            </dgView:TableView.Columns>
            
        </dgView:TableView>
    </Grid>
</Page>
