<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.PlaylistSection.AllPlaylistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:converters="using:Dimmer.WinUI.Utils.Converters"
    xmlns:customViews="using:Dimmer.WinUI.Views.CustomViews.WinuiViews"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:devWin="using:DevWinUI"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages.PlaylistSection"
    xmlns:localViews="using:Dimmer.WinUI.Views.CustomViews.WinuiViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:stateTriggers="using:Dimmer.WinUI.Utils.StateTriggers"
    mc:Ignorable="d"
    >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Playlists" />
        </StackPanel>

        <Grid Grid.Row="1">
            <ListView
                x:Name="PlaylistsListView"
                ItemsSource="{x:Bind MyViewModel.PlaylistsCollection, Mode=OneWay}"
                Tapped="PlaylistsListView_Tapped"
                >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel
                            BorderBrush="DarkSlateBlue"
                            BorderThickness="1"
                            CornerRadius="20"
                            >
                            <Image
                                MaxWidth="100"
                                MaxHeight="100"
                                Source="{Binding CoverImagePath}"
                                Stretch="UniformToFill"
                                />
                            <TextBlock Text="{Binding PlaylistName}" />
                            <devWin:WrapPanel HorizontalSpacing="5" VerticalSpacing="5">

                                <TextBlock Text="{Binding PlaylistType}" />
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <TextBlock Text="{Binding SongsIdsInPlaylist.Count}" />
                                    <TextBlock Text="Songs" />

                                </StackPanel>
                            </devWin:WrapPanel>


                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
