<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.PlaylistSection.SinglePlaylistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:converters="using:Dimmer.WinUI.Utils.Converters"
    xmlns:customViews="using:Dimmer.WinUI.Views.CustomViews.WinuiViews"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:devWin="using:DevWinUI"
    xmlns:dgView="using:WinUI.TableView"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages.PlaylistSection"
    xmlns:localViews="using:Dimmer.WinUI.Views.CustomViews.WinuiViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:stateTriggers="using:Dimmer.WinUI.Utils.StateTriggers"
    mc:Ignorable="d"
    >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock FontSize="25" Text="{x:Bind MyViewModel.SelectedPlaylist.PlaylistName}" />

            <Button Content="{x:Bind MyViewModel.SelectedPlaylist.QueryText}" />
        </StackPanel>
        <Pivot x:Name="MainPivot" Grid.Row="1">
            <PivotItem x:Name="SongsPivotItem" Header="Songs">
                <dgView:TableView AutoGenerateColumns="False" ItemsSource="{x:Bind MyViewModel.SelectedPlaylist.SongsInPlaylist}">
                    <dgView:TableView.Columns>
                        <dgView:TableViewTemplateColumn Header="Image">
                            <dgView:TableViewTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image
                                        Width="50"
                                        Height="50"
                                        Source="{Binding CoverImagePath}"
                                        />
                                </DataTemplate>
                            </dgView:TableViewTemplateColumn.CellTemplate>
                        </dgView:TableViewTemplateColumn>
                        <dgView:TableViewTextColumn Binding="{Binding Title}" Header="Title" />
                        <dgView:TableViewTextColumn Binding="{Binding OtherArtistsName}" Header="Artists" />
                        <dgView:TableViewTextColumn Binding="{Binding AlbumName}" Header="Album" />
                        <dgView:TableViewTextColumn Binding="{Binding GenreName}" Header="Genre" />
                    </dgView:TableView.Columns>
                </dgView:TableView>
            </PivotItem>

            <PivotItem
                x:Name="StatsPivot"
                Header="Statistics"
                Loaded="StatsPivot_Loaded"
                >
                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <devWin:WrapPanel>
                        <devWin:Card
                            Title="{x:Bind MyStatsViewModel.TextTotalTime.Title}"
                            Content="{x:Bind MyStatsViewModel.TextTotalTime.Value}"
                            TitleContent="{x:Bind MyStatsViewModel.TextTotalTime.Subtitle}"
                            />
                        <devWin:Card
                            Title="{x:Bind MyStatsViewModel.TextLifespan.Title}"
                            Content="{x:Bind MyStatsViewModel.TextLifespan.Value}"
                            TitleContent="{x:Bind MyStatsViewModel.TextLifespan.Subtitle}"
                            />
                        <devWin:Card
                            Title="{x:Bind MyStatsViewModel.TextDominantMood.Title}"
                            Content="{x:Bind MyStatsViewModel.TextDominantMood.Value}"
                            TitleContent="{x:Bind MyStatsViewModel.TextDominantMood.Subtitle}"
                            />
                        <devWin:Card
                            Title="{x:Bind MyStatsViewModel.TextAverageDuration.Title}"
                            Content="{x:Bind MyStatsViewModel.TextAverageDuration.Value}"
                            TitleContent="{x:Bind MyStatsViewModel.TextAverageDuration.Subtitle}"
                            />
                        <devWin:Card
                            Title="{x:Bind MyStatsViewModel.TextLifespan.Title}"
                            Content="{x:Bind MyStatsViewModel.TextLifespan.Value}"
                            TitleContent="{x:Bind MyStatsViewModel.TextLifespan.Subtitle}"
                            />
                        <devWin:Card
                            Title="{x:Bind MyStatsViewModel.TextLoyaltyScore.Title}"
                            Content="{x:Bind MyStatsViewModel.TextLoyaltyScore.Value}"
                            TitleContent="{x:Bind MyStatsViewModel.TextLoyaltyScore.Subtitle}"
                            />
                        <devWin:Card
                            Title="{x:Bind MyStatsViewModel.TextPlaylistVelocity.Title}"
                            Content="{x:Bind MyStatsViewModel.TextPlaylistVelocity.Value}"
                            TitleContent="{x:Bind MyStatsViewModel.TextPlaylistVelocity.Subtitle}"
                            />
                    </devWin:WrapPanel>
                </Grid>
            </PivotItem>
        </Pivot>

    </Grid>
</Page>
