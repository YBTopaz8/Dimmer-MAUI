<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.Settings.AppUtilsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:devWin="using:DevWinUI"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    >

    <ScrollViewer>
        <StackPanel>
            <Expander Header="Lyrics Section">
                <Expander.Content>
                    <StackPanel>
                        <CheckBox Content="Fetch from LrcLib" IsChecked="True" />

                        <devWin:ProgressButton
                            x:Name="SyncLyrics"
                            Background="Transparent"
                            CheckedContent="Fetching Lyrics..."
                            Click="SyncLyrics_Click"
                            IsIndeterminate="False"
                            Progress="{x:Bind MyViewModel.LyricsProgressValue, Mode=OneWay}"
                            ProgressRingVisibility="Visible"
                            Visibility="Visible"
                            />
                    </StackPanel>
                </Expander.Content>
            </Expander>
            <Expander Header="Cover Image Section">
                <Expander.Content>
                    <StackPanel>

                        <Button Click="SyncCovers_Click" Content="Fetching Cover Images..." />

                        <ProgressBar
                            x:Name="SyncCovers"
                            Background="Transparent"
                            IsIndeterminate="False"
                            Maximum="1"
                            Minimum="0"
                            Visibility="Visible"
                            Value="{x:Bind MyViewModel.CoverProgressValue, Mode=OneWay}"
                            />
                    </StackPanel>
                </Expander.Content>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Page>
