<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.SingleSongPage.EditSongPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Dimmer.WinUI.Utils.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dgView="using:WinUI.TableView"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages.SingleSongPage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    >

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibilityConverter" />
        <converters:BoolToPlayingPauseConv x:Key="BoolToPlayingPauseConverter" />

        <converters:CollectionSizeToVisibility x:Key="CollectionSizeToVisibility" />
        <converters:CollectionSizeToVisibilityInverted x:Key="CollectionSizeToVisibilityInverted" />
        <converters:EventDateToTimeAgo x:Key="EventDateToTimeAgo" />
        <converters:PlayTypeToBorderBrush x:Key="PlayTypeToBorderBrush" />
        <converters:StringNullOrEmptyToVisibility x:Key="StringNullOrEmptyToVisibility" />
        <converters:VolumeToPercentConverter x:Key="VolumeToPercentConverter" />
        <converters:BoolToImageConverter
            x:Key="PlayPauseConverter"
            FalseValue="play.png"
            TrueValue="pause.png"
            />
        <converters:BoolToImageConverter
            x:Key="FavIconConverter"
            FalseValue="heartbroken.png"
            TrueValue="heartlock.png"
            />


    </Page.Resources>
    <Grid PointerPressed="Grid_PointerPressed">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            Margin="10,0"
            Orientation="Horizontal"
            Spacing="15"
            >
            <Button
                x:Name="BackBtn"
                VerticalAlignment="Center"
                Click="BackButton_Click"
                Content="Back"
                />
            <Button
                x:Name="SaveChangeBtn"
                Width="120"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Click="SaveChangeBtn_Click"
                Content="Save Changes"
                />
            <TextBlock
                x:Name="PageNotificationText"
                FontSize="30"
                Foreground="DarkOrange"
                Visibility="Visible"
                />
        </StackPanel>
        <ScrollViewer
            x:Name="PageScrollviewer"
            Grid.Row="1"
            VerticalScrollBarVisibility="Hidden"
            Visibility="Visible"
            >
            <Grid Padding="10,0" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="10">

                    <Image
                        x:Name="detailedImage"
                        MaxWidth="300"
                        MaxHeight="300"
                        HorizontalAlignment="Center"
                        Loaded="DetailedImage_Loaded"
                        Source="{x:Bind DetailedSong.CoverImagePath, Mode=OneWay}"
                        />

                    <SplitButton
                        x:Name="MyImagePickerBtn"
                        HorizontalAlignment="Center"
                        Click="ChooseImageFromOtherSongsInAlbum_Click"
                        Content="Edit Image"
                        >
                        <SplitButton.Flyout>

                            <MenuFlyout>
                                <MenuFlyoutItem
                                    x:Name="ChooseImageFromFileSystem"
                                    Click="ChooseImageFromFileSystem_Click"
                                    Text="Choose From File System"
                                    >
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE91B;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    x:Name="ChooseImageFromOtherSongsInAlbum"
                                    Click="ChooseImageFromOtherSongsInAlbum_Click"
                                    Text="Choose From Other Songs In Album"
                                    >
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE93C;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    x:Name="RemoveImageFromSong"
                                    Click="RemoveImageFromSong_Click"
                                    Text="Remove Image"
                                    >
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </SplitButton.Flyout>

                    </SplitButton>

                    <Grid x:Name="GridOfOtherImages" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <ScrollViewer Grid.Column="0">
                            <ItemsRepeater x:Name="ImagesFromOtherSongsItemsRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="10" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Image
                                            Width="80"
                                            Height="80"
                                            PointerPressed="Image_PointerPressed"
                                            Source="{Binding}"
                                            />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>

                        <Button
                            Grid.Column="1"
                            Click="GridOfOtherImagesCloseButton_Click"
                            Content="X"
                            />
                    </Grid>

                    <ToggleButton
                        x:Name="ToggleSearchSongLastFM"
                        Checked="ToggleSearchSongLastFM_Checked"
                        Content="Search Online"
                        Unchecked="ToggleSearchSongLastFM_Unchecked"
                        />
                    <Expander x:Name="SearchSongLastFMExp" IsExpanded="False">
                        <Expander.Content>
                            <StackPanel Width="300">
                                <TextBlock Text="Title" />
                                <TextBox
                                    x:Name="SongNameTB"
                                    BorderBrush="Red"
                                    BorderThickness="1"
                                    TextChanged="SongNameTB_TextChanged"
                                    />

                                <TextBlock Text="Artist" />
                                <TextBox x:Name="SongArtistNameTB" />

                                <TextBlock Text="Album" />
                                <TextBox x:Name="SongAlbumNameTB" />

                                <Button
                                    x:Name="SearchOnLastFM"
                                    Click="SearchOnLastFM_Click"
                                    Content="Search"
                                    />
                            </StackPanel>
                        </Expander.Content>
                    </Expander>
                    <StackPanel
                        Grid.Column="0"
                        Padding="10"
                        BorderBrush="SlateGray"
                        BorderThickness="1"
                        CornerRadius="15"
                        >

                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Spacing="5"
                                >

                                <TextBlock
                                    Width="80"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Title:"
                                    />
                                <TextBox
                                    x:Name="TitleTextBox"
                                    Margin="0,5,0,15"
                                    Style="{StaticResource MyTextBoxStyle}"
                                    Text="{x:Bind MyViewModel.SelectedSong.Title, Mode=TwoWay}"
                                    />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Spacing="5"
                                >

                                <TextBlock
                                    Width="80"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Track #"
                                    />
                                <TextBox
                                    x:Name="TrackNumberTextBox"
                                    Margin="0,5,0,15"
                                    Style="{StaticResource MyTextBoxStyle}"
                                    Text="{x:Bind MyViewModel.SelectedSong.TrackNumber, Mode=TwoWay}"
                                    />
                            </StackPanel>
                        </Grid>


                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Spacing="5"
                                >

                                <TextBlock
                                    Width="80"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Release Year:"
                                    />

                                <TextBox
                                    x:Name="ReleaseYearTextBox"
                                    Margin="0,5,0,15"
                                    InputScope="Digits"
                                    Style="{StaticResource MyTextBoxStyle}"
                                    Text="{x:Bind MyViewModel.SelectedSong.ReleaseYear, Mode=TwoWay}"
                                    />
                            </StackPanel>



                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Spacing="5"
                                >

                                <TextBlock
                                    Width="80"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Conductor:"
                                    />
                                <TextBox
                                    x:Name="ConductorTextBox"
                                    Margin="0,5,0,15"
                                    Style="{StaticResource MyTextBoxStyle}"
                                    Text="{x:Bind MyViewModel.SelectedSong.Conductor, Mode=TwoWay}"
                                    />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Spacing="5"
                                >

                                <TextBlock
                                    Width="80"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Composer:"
                                    />
                                <TextBox
                                    x:Name="ComposerTextBox"
                                    Margin="0,5,0,15"
                                    Style="{StaticResource MyTextBoxStyle}"
                                    Text="{x:Bind MyViewModel.SelectedSong.Composer, Mode=TwoWay}"
                                    />
                            </StackPanel>


                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Spacing="5"
                                >

                                <TextBlock
                                    Width="80"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Description:"
                                    />
                                <RichEditBox x:Name="DescriptionTextBox" Margin="0,5,0,15" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Spacing="5"
                                >

                                <TextBlock
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Is Song Instrumental:"
                                    />
                                <ToggleButton
                                    x:Name="IsInstrumentalBox"
                                    Height="20"
                                    Margin="0,5,0,5"
                                    VerticalAlignment="Bottom"
                                    IsChecked="{x:Bind MyViewModel.SelectedSong.IsInstrumental, Mode=TwoWay}"
                                    />
                            </StackPanel>



                        </Grid>

                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="LastFMSearchStackPanel"
                    Grid.Column="1"
                    Visibility="Collapsed"
                    >
                    <ProgressRing IsActive="{x:Bind MyViewModel.IsSearchingOnLastFM, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Name, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Artist.Name, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Album.Name, Mode=OneWay}" />

                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Duration, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Statistics.Listeners, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Statistics.PlayCount, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Tags.Count, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Wiki.Summary, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Wiki.Published, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Wiki.Content, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind MyViewModel.InfoFromLastFM.Images.Count, Mode=OneWay}" />

                    <Button
                        x:Name="SaveInfoFromLastFMToSongInDb"
                        Click="SaveInfoFromLastFMToSongInDb_Click"
                        Content="Save"
                        />
                </StackPanel>
                <Grid
                    x:Name="PartTwoSection"
                    Grid.Column="1"
                    Padding="10"
                    RowSpacing="10"
                    Visibility="Visible"
                    >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                FontSize="21"
                                Text="Artists To Song"
                                />
                            <Button
                                x:Name="EditArtistsToSong"
                                Grid.Column="1"
                                Click="EditArtistsToSong_Click"
                                CommandParameter="Edit"
                                >
                                <Button.Content>
                                    <FontIcon Glyph="&#xEC87;" />
                                </Button.Content>
                            </Button>
                        </Grid>

                        <dgView:TableView
                            x:Name="ArtistToSongDataGrid"
                            Grid.Row="1"
                            MaxHeight="450"
                            AutoGenerateColumns="False"
                            Loaded="ArtistToSongDataGrid_Loaded"
                            SelectionChanged="ArtistToSongDataGrid_SelectionChanged"
                            SelectionMode="Multiple"
                            >
                            <dgView:TableView.Columns>
                                <dgView:TableViewTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="Artist Name"
                                    IsReadOnly="True"
                                    ToolTipService.Placement="Mouse"
                                    />
                            </dgView:TableView.Columns>
                        </dgView:TableView>
                    </Grid>



                    <StackPanel
                        Grid.Row="1"
                        Padding="10"
                        BorderBrush="MediumSlateBlue"
                        BorderThickness="1"
                        CornerRadius="15"
                        >
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="25"
                            Text="Song Album Edits"
                            />


                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10"
                            >
                            <TextBlock
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                FontSize="25"
                                FontWeight="SemiBold"
                                Text="Album:"
                                />
                            <Button
                                x:Name="AlbumTextBox2"
                                Margin="0,5,0,15"
                                Content="{Binding SelectedSong.AlbumName}"
                                />
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10"
                            >
                            <Button x:Name="AssignNewAlbumToSong" Content="Update" />
                            <Button x:Name="RemoveFromAlbum" Content="Remove From Album" />
                        </StackPanel>

                    </StackPanel>

                    <StackPanel
                        Grid.Row="2"
                        Padding="10"
                        BorderBrush="LightSlateGray"
                        BorderThickness="1"
                        CornerRadius="15"
                        >
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="25"
                            Text="Song Genre Edit"
                            />
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10"
                            >
                            <TextBlock
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                FontSize="25"
                                FontWeight="SemiBold"
                                Text="Genre:"
                                />
                            <TextBox
                                x:Name="GenreTextBox"
                                Margin="0,5,0,15"
                                Text="{Binding SelectedSong.Genre.Name}"
                                />
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10"
                            >
                            <Button x:Name="AssignNewGenreToSong" Content="Update" />
                            <Button x:Name="RemoveFromGenre" Content="Remove From Genre" />
                        </StackPanel>

                    </StackPanel>

                    <StackPanel
                        Grid.Row="3"
                        Padding="10"
                        BorderBrush="DarkSlateBlue"
                        BorderThickness="1"
                        CornerRadius="15"
                        Spacing="10"
                        >
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="25"
                            Text="Song Notes"
                            />
                        <Button
                            x:Name="AddNoteToSong"
                            HorizontalAlignment="Center"
                            Click="AddNoteToSong_Click"
                            Content="Add"
                            />
                        <ItemsRepeater ItemsSource="{Binding SelectedSong.UserNoteAggregatedCol}">

                            <ItemsRepeater.ItemTemplate>

                                <DataTemplate>
                                    <Button
                                        x:Name="UserNoteBtn"
                                        Margin="0,10,0,0"
                                        BorderThickness="1"
                                        CornerRadius="15"
                                        PointerPressed="UserNoteBtn_PointerPressed"
                                        >
                                        <StackPanel
                                            Background="Transparent"
                                            Orientation="Horizontal"
                                            Spacing="15"
                                            >

                                            <TextBlock
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                FontSize="26"
                                                Text="{Binding UserMessageText}"
                                                />


                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Grid>

            </Grid>


        </ScrollViewer>

        <Grid
            x:Name="LastFMSection"
            Grid.Row="1"
            Visibility="Collapsed"
            >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="5">

                <TextBox x:Name="SongTitleSearch" PlaceholderText="Song Title" />
                <TextBox x:Name="SongArtistNameSearch" PlaceholderText="Song Artist Name" />
                <TextBox x:Name="SongAlbumNameSearch" PlaceholderText="Song Album Name" />

                <Button
                    Command="{x:Bind MyLastFMViewModel.FetchSongOnlineOnLastFMCommand}"
                    CommandParameter="{x:Bind DetailedSong}"
                    Content="Search On Last FM"
                    />

                <Button
                    x:Name="PrefillFieldsBtn"
                    Click="PrefillFieldsBtn_Click"
                    Content="Prefill Fields"
                    />

                <Button
                    x:Name="ResetFieldsBtn"
                    Click="ResetFieldsBtn_Click"
                    Content="Reset Fields"
                    />

                <ScrollViewer Grid.Column="0" />
            </StackPanel>

            <StackPanel Grid.Column="1" />
            <!--<ItemsRepeater x:Name="AllLastFMSongs">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock x:Name="Name" />
                            <TextBlock x:Name="ArtistName" />
                            <TextBlock x:Name="AlbumName" />
                            <TextBlock x:Name="GenreName" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>-->


        </Grid>
    </Grid>
</Page>
