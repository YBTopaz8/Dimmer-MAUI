<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Dimmer.WinUI.Views.WinuiPages.SingleSongPage.SubPage.Stats.SongOverviewStatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dimmer.WinUI.Views.WinuiPages.SingleSongPage.SubPage.Stats"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="24" Margin="20">

            <!-- Song Header -->
            <StackPanel Spacing="8" Margin="0,0,0,16">
                <TextBlock x:Name="SongTitle" Style="{ThemeResource TitleTextBlockStyle}" FontSize="32"/>
                <TextBlock x:Name="ArtistName" Style="{ThemeResource SubtitleTextBlockStyle}" Opacity="0.7"/>
            </StackPanel>

            <!-- Chart 1: Listening Momentum (Area Chart) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="📈 Listening Momentum" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Play frequency acceleration/deceleration" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:CartesianChart Grid.Row="1" Height="280"
                                    Series="{x:Bind MomentumSeries}"
                                    XAxes="{x:Bind DateAxis}"
                                    YAxes="{x:Bind MomentumAxis}"/>
            </Grid>

            <!-- Chart 2: Completion Heatmap (Calendar) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="🗓️ Completion Heatmap" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="When you completed vs skipped the song" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:HeatMapSeriesChart Grid.Row="1" Height="300"
                                        Series="{x:Bind HeatmapSeries}"/>
            </Grid>

            <!-- Chart 3: Listening Seasons (Radar Chart) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="🌸 Listening Seasons" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Seasonal listening patterns" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:PolarChart Grid.Row="1" Height="300"
                                Series="{x:Bind SeasonsSeries}"/>
            </Grid>

            <!-- Chart 4: Emotional Arc (Filled Line) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="💔 Emotional Arc" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Where you skip, seek, or replay - the song's journey" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:CartesianChart Grid.Row="1" Height="250"
                                    Series="{x:Bind EmotionalArcSeries}"
                                    XAxes="{x:Bind PercentageAxis}"
                                    YAxes="{x:Bind IntensityAxis}"/>
            </Grid>

            <!-- Chart 5: Play Session Clustering (Bubble Chart) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="🫧 Session Clustering" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="How plays cluster in listening sessions" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:CartesianChart Grid.Row="1" Height="280"
                                    Series="{x:Bind BubbleSeries}"
                                    XAxes="{x:Bind SessionAxis}"
                                    YAxes="{x:Bind PlayCountAxis}"/>
            </Grid>

            <!-- Chart 6: Time to Completion (Histogram) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="⏱️ Time to Completion" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="How long it takes to fully appreciate the song" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:CartesianChart Grid.Row="1" Height="250"
                                    Series="{x:Bind TimeToCompletionSeries}"
                                    XAxes="{x:Bind DaysAxis}"
                                    YAxes="{x:Bind FrequencyAxis}"/>
            </Grid>

            <!-- Chart 7: Listening Decay Curve (Exponential) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="📉 Listening Decay Curve" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="How your interest fades over time (half-life)" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:CartesianChart Grid.Row="1" Height="250"
                                    Series="{x:Bind DecaySeries}"
                                    XAxes="{x:Bind DecayTimeAxis}"
                                    YAxes="{x:Bind DecayIntensityAxis}"/>
            </Grid>

            <!-- Chart 8: Play Context Diversity (Treemap) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="🎯 Context Diversity" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="What you were doing while listening" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:PieChart Grid.Row="1" Height="280"
                              Series="{x:Bind ContextSeries}"/>
            </Grid>

            <!-- Chart 9: Play-to-Skip Ratio Trend (Stacked Area) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="⚖️ Play-to-Skip Ratio Trend" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Is it growing on you or annoying you?" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:CartesianChart Grid.Row="1" Height="250"
                                    Series="{x:Bind RatioSeries}"
                                    XAxes="{x:Bind RatioDateAxis}"/>
            </Grid>

            <!-- Chart 10: Listening Mood Ring (Polar Area) -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                  CornerRadius="12" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="🎨 Listening Mood Ring" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="How you listen, by hour of day" Opacity="0.6" FontSize="12"/>
                </StackPanel>
                <lvc:PolarChart Grid.Row="1" Height="320"
                                Series="{x:Bind MoodRingSeries}"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
