                Grid.Row="2"
                Padding="5"
                Orientation="Horizontal"
                Spacing="5"
                Visibility="Visible"
                >
                <TextBlock
                    x:Name="AppLog"
                    Grid.Row="2"
                    VerticalAlignment="Bottom"
                    Text="{x:Bind BaseViewModel.LatestAppLog.Message, Mode=OneWay}"
                    />
                <Button
                    x:Name="OptionLogBtn"
