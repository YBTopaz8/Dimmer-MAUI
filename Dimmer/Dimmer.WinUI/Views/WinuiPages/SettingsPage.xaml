        <Grid
            x:Name="BackUpRestoreGrid"
            MinWidth="800"
            HorizontalAlignment="Center"
            Loaded="BackUpRestoreGrid_Loaded"
            Visibility="Collapsed"
            >
            <ScrollViewer>

                <StackPanel Background="#1d1d1d" CornerRadius="10">
                    <SelectorBar
                        x:Name="BackUpRestoreSelector"
                        HorizontalAlignment="Center"
                        SelectionChanged="BackUpRestoreSelector_SelectionChanged"
                        >
                        <SelectorBarItem
                            x:Name="BackUpSelector"
                            Icon="Download"
                            IsSelected="True"
                            Text="Restore"
                            />
                        <SelectorBarItem
                            x:Name="RestoreSelector"
                            Icon="SaveLocal"
                            Text="Backup"
                            />
                    </SelectorBar>

                    <Frame
                        x:Name="ContentFrame"
                        Grid.Row="1"
                        x:FieldModifier="Public"
                        IsNavigationStackEnabled="False"
                        />
                </StackPanel>
            </ScrollViewer>
