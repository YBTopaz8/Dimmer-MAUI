<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Dimmer.WinUI.Views.CustomViews.WinuiViews.SingleSongSection.ChangesReviewPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dimmer.WinUI.Views.CustomViews.WinuiViews.SingleSongSection"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:models="using:Dimmer.Data.ModelView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">


    <Grid Background="{ThemeResource CardBackgroundFillColorDefault}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="20" Spacing="10">
            <TextBlock Text="Review Changes" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="{x:Bind ViewModel.TotalChangesCount, Mode=OneWay}" 
                       FontSize="16" 
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

            <!-- Summary stats -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="{x:Bind ViewModel.AcceptedChangesCount, Mode=OneWay}" 
                           Foreground="Green"/>
                <TextBlock Grid.Column="1" 
                           Text="accepted" 
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </Grid>
        </StackPanel>

        <!-- Changes List -->
        <ListView Grid.Row="1" 
                  ItemsSource="{x:Bind ViewModel.PendingChanges, Mode=OneWay}"
                  SelectionMode="None"
                  Padding="20,0">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:PropertyChangeModelView">
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefault}" 
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <!-- Category Header -->
                            <TextBlock Text="{x:Bind Category}" 
                                       FontSize="14" 
                                       Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                                       Visibility="{Binding IsFirstInCategory, Converter={StaticResource BoolToVisibility}}"/>

                            <!-- Property Name -->
                            <TextBlock Text="{x:Bind DisplayName}" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"/>

                            <!-- Old Value -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="From:" 
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Grid.Column="1" 
                                           Text="{x:Bind OldValueDisplay}"
                                           FontSize="14"
                                           Foreground="Gray"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <!-- New Value -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="To:" 
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Grid.Column="1" 
                                           Text="{x:Bind NewValueDisplay}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Action Buttons -->
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Right"
                                        Spacing="10"
                                        Margin="0,10,0,0">

                                <!-- Accept Button -->
                                <Button Content="Accept"
                                        Background="Green"
                                        Foreground="White"
                                        Padding="20,8"
                                        CornerRadius="20"
                                        Visibility="{x:Bind IsAccepted, Converter={StaticResource BoolToInverseVisibility}}"/>

                                <!-- Reject Button -->
                                <Button Content="Reject"
                                        Background="Transparent"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        Padding="20,8"
                                        CornerRadius="20"
                                        Visibility="{x:Bind IsRejected, Converter={StaticResource BoolToInverseVisibility}}"/>

                                <!-- Accepted Indicator -->
                                <StackPanel Orientation="Horizontal" 
                                            Spacing="5"
                                            Visibility="{x:Bind IsAccepted, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon Glyph="&#xE73E;" Foreground="Green"/>
                                    <TextBlock Text="Accepted" Foreground="Green"/>
                                </StackPanel>

                                <!-- Rejected Indicator -->
                                <StackPanel Orientation="Horizontal" 
                                            Spacing="5"
                                            Visibility="{x:Bind IsRejected, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon Glyph="&#xE711;" Foreground="Red"/>
                                    <TextBlock Text="Rejected" Foreground="Red"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" 
                    Padding="20"
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Spacing="10">

            <Button Content="Reject All"
                    Padding="20,10"
                    Click="RejectAll_Click"/>

            <Button Content="Accept All"
                    Background="Green"
                    Foreground="White"
                    Padding="20,10"
                    Click="AcceptAll_Click"/>

            <Button Content="Save Selected"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="20,10"
                    Click="SaveSelected_Click"/>

            <Button Content="Cancel"
                    Padding="20,10"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
