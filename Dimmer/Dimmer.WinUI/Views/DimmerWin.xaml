<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Dimmer.WinUI.Views.DimmerWin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:converters="using:Dimmer.WinUI.Utils.Converters"
    xmlns:customViews="using:Dimmer.WinUI.Views.CustomViews.WinuiViews"
    xmlns:d="http://schemas.microsoft.com/expression/blBottom/2008"
    xmlns:local="using:Dimmer.WinUI.Views"
    xmlns:localViews="using:Dimmer.WinUI.Views.CustomViews.WinuiViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:stateTriggers="using:Dimmer.WinUI.Utils.StateTriggers"
    Title="DimmerWin"
    Activated="Window_Activated"
    Closed="DimmerWindowClosed"
    SizeChanged="Window_SizeChanged"
    mc:Ignorable="d"
    >








    <NavigationView x:Name="nvSample">
        <NavigationView.MenuItems>
            <NavigationViewItem
                x:Name="SongsBtn"
                Content="Songs"
                Tag="SongsTag"
                Tapped="SongsBtn_Tapped"
                >
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8D6;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                x:Name="ArtistsBtn"
                Content="Artists"
                Tag="ArtistsTag"
                Tapped="ArtistsBtn_Tapped"
                >

                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE720;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                x:Name="AlbumsBtn"
                Content="Albums"
                Tag="AlbumsTag"
                Tapped="AlbumsBtn_Tapped"
                >
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE93C;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>



            <NavigationViewItem
                x:Name="DimsStatsBtn"
                Content="Dimner Stats"
                Tag="DimsStats"
                Tapped="DimsStatsBtn_Tapped"
                >
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xEB05;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>


        </NavigationView.MenuItems>

        <NavigationView.PaneFooter>
            <NavigationViewItem
                x:Name="SettingsBtn"
                Content="Settings"
                Tag="SettingsTag"
                Tapped="SettingsBtn_Tapped"
                >
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.PaneFooter>
        <Grid x:Name="MainGrid" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>



            <Frame
                x:Name="ContentFrame"
                x:FieldModifier="Public"
                Navigated="ContentFrame_Navigated"
                Grid.Row="0"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Grid>

                    <Image x:Name="CurrentPlayingSongImage">
                        <Image.Source>
                            <BitmapImage UriSource="{x:Bind MyViewModel.SelectedSong.CoverImagePath}"/>
                        </Image.Source>
                    </Image>
                </Grid>
            </Grid>


        </Grid>

    </NavigationView>
</Window>
