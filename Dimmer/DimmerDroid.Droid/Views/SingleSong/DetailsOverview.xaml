<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dimmer.Views.SingleSong.DetailsOverview"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:globalVM="clr-namespace:Dimmer.ViewModel;assembly=Dimmer"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:lyrModels="clr-namespace:Dimmer.Data.Models.LyricsModels;assembly=Dimmer"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    x:DataType="models:SongModelView"
    Shell.NavBarIsVisible="False">
    <dx:DXScrollView Margin="5,0">
        <Grid>

            <dx:TabView
                x:Name="SongTabView"
                HeaderPanelPosition="Bottom"
                PropertyChanging="SongTabView_PropertyChanging">
                <dx:TabViewItem x:Name="OverViewTab" HeaderText="OverView">

                    <dx:DXStackLayout ItemSpacing="5">
                        <Grid ColumnDefinitions="150,*">
                            <dx:DXImage
                                Grid.Column="0"
                                Aspect="AspectFit"
                                HorizontalOptions="Center"
                                MaximumHeightRequest="300"
                                MaximumWidthRequest="300"
                                Source="{Binding CoverImagePath}" />

                            <dx:DXStackLayout Grid.Column="1" ItemSpacing="5">
                                <Label
                                    x:Name="TitleLabel"
                                    FontSize="23"
                                    HorizontalTextAlignment="Justify"
                                    LineBreakMode="WordWrap"
                                    SizeChanged="SongTitleLabel_SizeChanged"
                                    Text="{Binding Title}" />
                                <dx:Chip
                                    FontSize="17"
                                    HorizontalOptions="Center"
                                    Text="{Binding OtherArtistsName}" />
                                <dx:Chip
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    Text="{Binding AlbumName}" />
                            </dx:DXStackLayout>
                        </Grid>

                        <dx:Chip
                            FontSize="12"
                            HorizontalOptions="Center"
                            Text="{Binding GenreName}" />

                        <dx:Chip Text="{Binding PlayCompletedCount}" />
                        <dx:Chip Text="{Binding PauseCount}" />
                        <dx:Chip Text="{Binding SkipCount}" />

                        <dx:Chip Icon="heart.png" IsVisible="{Binding IsFavorite}" />
                    </dx:DXStackLayout>
                </dx:TabViewItem>

                <dx:TabViewItem HeaderText="Search Lyrics">
                    <dx:DXScrollView>

                        <dx:DXStackLayout
                            x:Name="LyricsTabVSL"
                            x:DataType="vm:BaseViewModelAnd"
                            ItemSpacing="10"
                            Loaded="LyricsTabVSL_Loaded">
                            <dx:DXStackLayout ItemSpacing="10">
                                <dx:TextEdit LabelText="Track Name" Text="{Binding LyricsTrackNameSearch}" />

                                <!--<dx:Chip BorderThickness="0"

                                 Icon="copy.png"/>

                        <dx:Chip BorderThickness="0"
                                 Icon="clearalt.png"/>

                        <dx:Chip BorderThickness="0"

                                 Icon="clipboard.png"/>-->
                            </dx:DXStackLayout>
                            <dx:DXStackLayout>
                                <dx:TextEdit LabelText="Artist Name" Text="{Binding LyricsArtistNameSearch}" />
                            </dx:DXStackLayout>

                            <dx:DXStackLayout ItemSpacing="10">
                                <dx:TextEdit LabelText="Album Name" Text="{Binding LyricsAlbumNameSearch}" />
                            </dx:DXStackLayout>
                            <dx:DXButton
                                x:Name="SearchLyricsBtn"
                                Command="{Binding SearchLyricsCommand}"
                                Content="Search Online" />
                            <ActivityIndicator IsRunning="{Binding IsLyricsSearchBusy}" IsVisible="{Binding IsLyricsSearchBusy}" />
                            <dx:DXCollectionView ItemsSource="{Binding LyricsSearchResults}">
                                <dx:DXCollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="lyrModels:LrcLibLyrics">
                                        <dx:DXStackLayout>
                                            <dx:DXStackLayout ItemSpacing="10" Orientation="Horizontal">
                                                <Label Text="{Binding TrackName}" />
                                                <Label Text="{Binding DurationFormatted}" />

                                            </dx:DXStackLayout>
                                            <Label Text="{Binding ArtistName}" />
                                            <Label Text="{Binding AlbumName}" />
                                            <Label IsVisible="{Binding Instrumental}" />
                                            <dx:DXButton
                                                x:Name="ApplyLyrics"
                                                x:DataType="vm:BaseViewModelAnd"
                                                Command="{Binding SelectLyricsCommand}"
                                                CommandParameter="{Binding .}" />
                                            <dx:DXScrollView MaximumHeightRequest="250">

                                                <Label Text="{Binding SyncedLyrics}" />

                                            </dx:DXScrollView>
                                        </dx:DXStackLayout>
                                    </DataTemplate>
                                </dx:DXCollectionView.ItemTemplate>
                            </dx:DXCollectionView>

                        </dx:DXStackLayout>

                    </dx:DXScrollView>
                </dx:TabViewItem>


                <dx:TabViewItem HeaderText="Statistics">

                    <dx:DXScrollView
                        x:Name="StatisticsScrollV"
                        x:DataType="globalVM:StatisticsViewModel"
                        Loaded="StatisticsScrollView_Loaded">

                        <dx:DXStackLayout ItemSpacing="10">
                            <Label HorizontalOptions="Center" Text="{Binding SongStats.FilterUsed, StringFormat='Filter: {0}'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.TotalPlays, StringFormat='TotalPlays : {0}'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.TotalSkips, StringFormat='TotalSkips : {0}'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.Completions, StringFormat='Completions : {0}'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.TotalListeningTimeSeconds, StringFormat='Total Listening Time : {0}s'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.AveragePercentListened, StringFormat='Average Percent Listened : {0}%'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.FirstPlayedDate, StringFormat='First Played Date : {0:dd-MM-yyyy}'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.LastPlayedDate, StringFormat='Last Played Date : {0:dd-MM-yyyy}'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.MostFrequentPlayHour, StringFormat='Most Frequent PlayHour : {0}'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.LongestListeningStreakDays, StringFormat='Longest Listening Streak Days : {0} days'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.AverageDaysBetweenPlays, StringFormat='Average Days BetweenPlays : {0:n2} days'}" />
                            <Label HorizontalOptions="Start" Text="{Binding SongStats.Summary.IsPlayCountFibonacci, StringFormat='Is PlayCount Fibonacci: {0}'}" />


                        </dx:DXStackLayout>
                    </dx:DXScrollView>

                </dx:TabViewItem>

                <dx:TabViewItem HeaderText="TimeLine">

                    <Grid>
                        <dx:DXCollectionView ItemsSource="{Binding PlayEvents}">
                            <dx:DXCollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:DimmerPlayEventView">
                                    <dx:DXBorder x:Name="PlayEventBorder">
                                        <dx:DXBorder.Triggers>
                                            <DataTrigger
                                                Binding="{Binding PlayType}"
                                                TargetType="dx:DXBorder"
                                                Value="0">
                                                <Setter Property="BorderColor" Value="DeepSkyBlue" />
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding PlayType}"
                                                TargetType="dx:DXBorder"
                                                Value="1">
                                                <Setter Property="BorderColor" Value="Orange" />
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding PlayType}"
                                                TargetType="dx:DXBorder"
                                                Value="3">
                                                <Setter Property="BorderColor" Value="DarkSlateBlue" />
                                            </DataTrigger>
                                        </dx:DXBorder.Triggers>
                                    </dx:DXBorder>
                                </DataTemplate>
                            </dx:DXCollectionView.ItemTemplate>
                        </dx:DXCollectionView>
                    </Grid>

                </dx:TabViewItem>


            </dx:TabView>

            <HorizontalStackLayout HorizontalOptions="End" VerticalOptions="End">
                <dx:DXExpander
                    x:Name="MiniNPExpander"
                    x:DataType="vm:BaseViewModelAnd"
                    HorizontalExpandMode="FromEndToStart"
                    IsExpanded="False"
                    Loaded="MiniNPExpander_Loaded"
                    VerticalExpandMode="FromCenter">
                    <dx:DXExpander.Content>
                        <dx:DXStackLayout>
                            <dx:DXStackLayout>
                                <Label Text="{Binding CurrentPlayingSongView.Title}" />
                                <Label Text="{Binding CurrentPlayingSongView.ArtistName}" />
                                <Label Text="{Binding CurrentPlayingSongView.AlbumName}" />
                            </dx:DXStackLayout>
                            <dx:DXStackLayout
                                HorizontalOptions="Center"
                                ItemSpacing="10"
                                Orientation="Horizontal" />
                        </dx:DXStackLayout>
                    </dx:DXExpander.Content>
                </dx:DXExpander>
            </HorizontalStackLayout>
        </Grid>
    </dx:DXScrollView>
</ContentPage>