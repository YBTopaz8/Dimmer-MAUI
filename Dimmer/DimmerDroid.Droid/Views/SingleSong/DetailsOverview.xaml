<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dimmer.Views.SingleSong.DetailsOverview"
    x:Name="myPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:globalVM="clr-namespace:Dimmer.ViewModel;assembly=Dimmer"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:lyrModels="clr-namespace:Dimmer.Data.Models.LyricsModels;assembly=Dimmer"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    x:DataType="models:SongModelView"
    Shell.NavBarIsVisible="False"
    >


    <dx:DXScrollView>
        <dx:DXStackLayout ItemSpacing="10">

            <Grid ColumnDefinitions="150,*" ColumnSpacing="5">
                <dx:DXStackLayout Grid.Column="0">

                    <dx:DXImage
                        Aspect="AspectFit"
                        HorizontalOptions="Center"
                        MaximumHeightRequest="350"
                        MaximumWidthRequest="350"
                        Source="{Binding CoverImagePath}"
                        VerticalOptions="Start"
                        />
                    <dx:DXButton
                        Padding="0"
                        BackgroundColor="Transparent"
                        Icon="heart.png"
                        IconColor="DarkSlateBlue"
                        IconHeight="40"
                        IconWidth="40"
                        IsVisible="{Binding IsFavorite}"
                        ShowIcon="True"
                        />
                </dx:DXStackLayout>


                <dx:DXStackLayout
                    Grid.Column="1"
                    ItemSpacing="5"
                    VerticalOptions="Start"
                    >
                    <Label
                        x:Name="TitleLabel"
                        FontSize="23"
                        HorizontalTextAlignment="Justify"
                        LineBreakMode="WordWrap"
                        Text="{Binding Title}"
                        VerticalOptions="Start"
                        />
                    <dx:Chip
                        x:Name="ArtistNamesChip"
                        FontSize="17"
                        HorizontalOptions="Start"
                        Icon="artistt.png"
                        IsIconVisible="True"
                        Tap="ArtistNamesChip_Tap"
                        >
                        <dx:Chip.ContentTemplate>
                            <DataTemplate>
                                <Label Text="{Binding OtherArtistsName}" />
                            </DataTemplate>
                        </dx:Chip.ContentTemplate>
                    </dx:Chip>
                    <dx:Chip
                        x:Name="AlbumChip"
                        FontSize="14"
                        HorizontalOptions="Start"
                        Icon="musicalbum.png"
                        IsIconVisible="True"
                        Tap="AlbumChip_Tap"
                        TapCommandParameter="{Binding Album}"
                        >
                        <dx:Chip.ContentTemplate>
                            <DataTemplate>
                                <Label Text="{Binding AlbumName}" />
                            </DataTemplate>
                        </dx:Chip.ContentTemplate>
                    </dx:Chip>
                    <dx:Chip
                        FontSize="12"
                        HorizontalOptions="Start"
                        Text="{Binding GenreName}"
                        />

                </dx:DXStackLayout>
            </Grid>

            <BoxView HeightRequest="1" Color="DarkSlateBlue" />

            <Grid ColumnDefinitions="*,auto">

                <Label
                    Grid.Column="0"
                    FontSize="26"
                    HorizontalOptions="Center"
                    Text="Info"
                    />
                <dx:DXButton
                    Grid.Column="1"
                    Padding="4"
                    BackgroundColor="Transparent"
                    BorderThickness="0"
                    Icon="pen.png"
                    IconColor="DarkSlateBlue"
                    IconHeight="25"
                    IconWidth="25"
                    ShowContent="False"
                    ShowIcon="True"
                    />
            </Grid>
            <dx:DXBorder
                Padding="5"
                BorderColor="DarkSlateBlue"
                BorderThickness="1"
                CornerRadius="10"
                >

                <Grid ColumnDefinitions="*,*">
                    <Grid.Resources>
                        <ResourceDictionary>
                            <Style TargetType="Label">
                                <Setter Property="FontSize" Value="18" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Dark=white, Light=black}" />
                            </Style>
                        </ResourceDictionary>
                    </Grid.Resources>
                    <dx:DXStackLayout Grid.Column="0" ItemSpacing="15">
                        <Label Text="Date Created" />
                        <Label Text="BitRate" />
                        <Label Text="Track Number" />
                        <Label Text="Duration In Seconds" />
                        <Label Text="Release Year" />
                    </dx:DXStackLayout>


                    <dx:DXStackLayout
                        Grid.Column="1"
                        HorizontalOptions="End"
                        ItemSpacing="15"
                        >
                        <dx:DXStackLayout.Resources>
                            <ResourceDictionary>
                                <Style TargetType="Label">
                                    <Setter Property="FontFamily" Value="AleySans" />
                                    <Setter Property="FontSize" Value="18" />
                                    <Setter Property="TextColor" Value="{AppThemeBinding Dark=white, Light=black}" />
                                </Style>
                            </ResourceDictionary>
                        </dx:DXStackLayout.Resources>
                        <Label HorizontalTextAlignment="End" Text="{Binding DateCreated, StringFormat='{0:dd MMMM,yyyy hh:mm}'}" />
                        <Label HorizontalTextAlignment="End" Text="{Binding BitRate, StringFormat='{0} kbps'}" />
                        <Label HorizontalTextAlignment="End" Text="{Binding TrackNumber, StringFormat='{0}'}" />
                        <Label HorizontalTextAlignment="End" Text="{Binding DurationInSeconds, StringFormat='{0} seconds'}" />
                        <Label HorizontalTextAlignment="End" Text="{Binding ReleaseYear, StringFormat='{0}'}" />

                    </dx:DXStackLayout>
                </Grid>


            </dx:DXBorder>

            <BoxView HeightRequest="1" Color="DarkSlateBlue" />


            <Grid ColumnDefinitions="*,auto">

                <Label
                    Grid.Column="0"
                    FontSize="26"
                    HorizontalOptions="Center"
                    Text="Stats"
                    />
                <dx:DXButton
                    Grid.Column="1"
                    Padding="4"
                    BackgroundColor="Transparent"
                    BorderThickness="0"
                    Icon="eye.png"
                    IconColor="DarkSlateBlue"
                    IconHeight="25"
                    IconWidth="25"
                    ShowContent="False"
                    ShowIcon="True"
                    />
            </Grid>
            <dx:DXStackLayout
                x:Name="StatsSectionPreview"
                Padding="5"
                x:DataType="globalVM:StatisticsViewModel"
                BorderColor="DarkSlateBlue"
                BorderThickness="1"
                CornerRadius="10"
                >
                <dx:DXStackLayout.Resources>
                    <ResourceDictionary>
                        <Style TargetType="Label">
                            <Setter Property="FontSize" Value="16" />
                            <Setter Property="TextColor" Value="{AppThemeBinding Light=black, Dark=white}" />

                        </Style>
                    </ResourceDictionary>
                </dx:DXStackLayout.Resources>
                <FlexLayout JustifyContent="SpaceBetween">
                    <Label Text="First Played" />
                    <Label Text="{Binding SongStats.Summary.FirstPlayedDate, StringFormat='{0:dd, MMMM yyyy : HH:mm}'}" />

                </FlexLayout>
                <FlexLayout JustifyContent="SpaceBetween">
                    <Label Text="Last Played" />
                    <Label Text="{Binding SongStats.Summary.LastPlayedDate, StringFormat='{0:dd, MMMM yyyy : HH:mm}'}" />

                </FlexLayout>
                <FlexLayout JustifyContent="SpaceBetween">
                    <Label Text="Most Frequently played hour" />
                    <Label Text="{Binding SongStats.Summary.MostFrequentPlayHour, StringFormat='{0}'}" />

                </FlexLayout>
                <FlexLayout JustifyContent="SpaceBetween">
                    <Label Text="Longest Listening Streak (in Days)" />
                    <Label Text="{Binding SongStats.Summary.LongestListeningStreakDays, StringFormat='{0}'}" />

                </FlexLayout>
                <FlexLayout JustifyContent="SpaceBetween">
                    <Label Text="Total Listening Time Seconds (in seconds)" />
                    <Label Text="{Binding SongStats.Summary.TotalListeningTimeSeconds, StringFormat='{0}s'}" />

                </FlexLayout>


            </dx:DXStackLayout>

            <BoxView HeightRequest="2" Color="DarkSlateBlue" />


            <Grid ColumnDefinitions="*,auto">

                <Label
                    Grid.Column="0"
                    FontSize="26"
                    HorizontalOptions="Center"
                    Text="Lyrics Section"
                    />
                <dx:DXButton
                    x:Name="EditLyrics"
                    Grid.Column="1"
                    Padding="4"
                    BackgroundColor="Transparent"
                    BorderThickness="0"
                    Clicked="EditLyrics_Clicked"
                    Icon="pen.png"
                    IconColor="DarkSlateBlue"
                    IconHeight="25"
                    IconWidth="25"
                    ShowContent="False"
                    ShowIcon="True"
                    />
            </Grid>

            <dx:DXScrollView AllowBounceEffect="True" MaximumHeightRequest="450">
                <Label Text="{Binding SyncLyrics}" />
            </dx:DXScrollView>

            <dx:DXPopup
                x:Name="ArtistToSongPopup"
                Margin="10"
                MaximumHeightRequest="500"
                >
                <dx:DXPopup.Content>
                    <Grid Margin="10" RowDefinitions="auto,*">
                        <Label
                            Grid.Row="0"
                            HorizontalOptions="Center"
                            Text="{Binding ArtistToSong.Count, StringFormat='{0} Artists'}"
                            />

                        <dx:DXCollectionView
                            Grid.Row="1"
                            ItemSpacing="10"
                            ItemsSource="{Binding ArtistToSong}"
                            MaximumHeightRequest="200"
                            >
                            <dx:DXCollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ArtistModelView">
                                    <Grid ColumnDefinitions="*,auto">
                                        <dx:DXStackLayout Grid.Column="0">
                                            <Label FontSize="23" Text="{Binding Name}" />
                                        </dx:DXStackLayout>

                                        <dx:DXStackLayout Grid.Column="1">
                                            <dx:DXButton
                                                x:Name="NavToArtistPage"
                                                Clicked="NavToArtistPage_Clicked"
                                                CommandParameter="{Binding .}"
                                                Icon="eye.png"
                                                ShowContent="False"
                                                ShowIcon="True"
                                                />


                                        </dx:DXStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </dx:DXCollectionView.ItemTemplate>
                        </dx:DXCollectionView>
                    </Grid>
                </dx:DXPopup.Content>
            </dx:DXPopup>
        </dx:DXStackLayout>
    </dx:DXScrollView>
