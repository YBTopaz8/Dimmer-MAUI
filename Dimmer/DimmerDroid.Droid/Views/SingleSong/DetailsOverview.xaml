<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dimmer.Views.SingleSong.DetailsOverview"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:globalVM="clr-namespace:Dimmer.ViewModel;assembly=Dimmer"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:lyrModels="clr-namespace:Dimmer.Data.Models.LyricsModels;assembly=Dimmer"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    x:Name="myPage"
    x:DataType="models:SongModelView"
    Shell.NavBarIsVisible="False">
    <dx:DXScrollView Margin="5,0">
        <Grid>

            <dx:TabView
                x:Name="SongTabView"
                HeaderPanelPosition="Bottom"
                PropertyChanging="SongTabView_PropertyChanging">
                <dx:TabViewItem x:Name="OverViewTab" HeaderText="OverView">

                    <dx:DXScrollView>
                        <dx:DXStackLayout ItemSpacing="10">

                            <Grid ColumnDefinitions="150,*" ColumnSpacing="5">
                                <dx:DXImage
                                    Grid.Column="0"
                                    Aspect="AspectFit"
                                    HorizontalOptions="Center"
                                    MaximumHeightRequest="300"
                                    MaximumWidthRequest="300"
                                    Source="{Binding CoverImagePath}" />

                                <dx:DXStackLayout
                                    Grid.Column="1"
                                    ItemSpacing="5"
                                    VerticalOptions="Start">
                                    <Label
                                        x:Name="TitleLabel"
                                        FontSize="23"
                                        HorizontalTextAlignment="Justify"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding Title}" />
                                    <dx:Chip
                                        x:Name="ArtistNamesChip"
                                        FontSize="17"
                                        HorizontalOptions="Start"
                                        Icon="artistt.png"
                                        IsIconVisible="True"
                                        Tap="ArtistNamesChip_Tap">
                                        <dx:Chip.ContentTemplate>
                                            <DataTemplate>
                                                <Label Text="{Binding OtherArtistsName}" />
                                            </DataTemplate>
                                        </dx:Chip.ContentTemplate>
                                    </dx:Chip>
                                    <dx:Chip
                                        x:Name="AlbumChip"
                                        FontSize="14"
                                        HorizontalOptions="Start"
                                        Icon="musicalbum.png"
                                        IsIconVisible="True"
                                        Tap="AlbumChip_Tap"
                                        TapCommandParameter="{Binding Album}">
                                        <dx:Chip.ContentTemplate>
                                            <DataTemplate>
                                                <Label Text="{Binding AlbumName}" />
                                            </DataTemplate>
                                        </dx:Chip.ContentTemplate>
                                    </dx:Chip>
                                    <dx:Chip
                                        FontSize="12"
                                        HorizontalOptions="Start"
                                        Text="{Binding GenreName}" />

                                </dx:DXStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="DarkSlateBlue" />

                            <dx:Chip Icon="heart.png" IsVisible="{Binding IsFavorite}" />
                            <Grid ColumnDefinitions="*,auto">

                                <Label
                                    Grid.Column="0"
                                    FontSize="26"
                                    HorizontalOptions="Center"
                                    Text="Info" />
                                <dx:DXButton
                                    Grid.Column="1"
                                    Padding="4"
                                    BackgroundColor="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding Commands.Show, Source={Reference EditSongBtmSheet}}"
                                    Icon="pen.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="25"
                                    IconWidth="25"
                                    ShowContent="False"
                                    ShowIcon="True" />
                            </Grid>
                            <dx:DXBorder
                                Padding="5"
                                BorderColor="Gray"
                                BorderThickness="1"
                                CornerRadius="10">

                                <Grid ColumnDefinitions="*,*">
                                    <Grid.Resources>
                                        <ResourceDictionary>
                                            <Style TargetType="Label">
                                                <Setter Property="FontSize" Value="18" />
                                                <Setter Property="TextColor" Value="{AppThemeBinding Dark=white, Light=black}" />
                                            </Style>
                                        </ResourceDictionary>
                                    </Grid.Resources>
                                    <dx:DXStackLayout Grid.Column="0" ItemSpacing="15">
                                        <Label Text="Date Created" />
                                        <Label Text="BitRate" />
                                        <Label Text="Disc Number" />
                                        <Label Text="Duration In Seconds" />
                                        <Label Text="Release Year" />
                                    </dx:DXStackLayout>


                                    <dx:DXStackLayout
                                        Grid.Column="1"
                                        HorizontalOptions="End"
                                        ItemSpacing="15">
                                        <dx:DXStackLayout.Resources>
                                            <ResourceDictionary>
                                                <Style TargetType="Label">
                                                    <Setter Property="FontFamily" Value="AleySans" />
                                                    <Setter Property="FontSize" Value="18" />
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Dark=white, Light=black}" />
                                                </Style>
                                            </ResourceDictionary>
                                        </dx:DXStackLayout.Resources>
                                        <Label HorizontalTextAlignment="End" Text="{Binding DateCreated, StringFormat='{0:dd MMMM,yyyy hh:mm}'}" />
                                        <Label HorizontalTextAlignment="End" Text="{Binding BitRate, StringFormat='{0} kbps'}" />
                                        <Label HorizontalTextAlignment="End" Text="{Binding DiscNumber, StringFormat='{0}'}" />
                                        <Label HorizontalTextAlignment="End" Text="{Binding DurationInSeconds, StringFormat='{0} seconds'}" />
                                        <Label HorizontalTextAlignment="End" Text="{Binding ReleaseYear, StringFormat='{0}'}" />
                                    </dx:DXStackLayout>
                                </Grid>


                            </dx:DXBorder>
                            <dx:DXScrollView>
                                <Label Text="{Binding SyncLyrics}" />
                            </dx:DXScrollView>

                            <dx:DXPopup
                                x:Name="ArtistToSongPopup"
                                Margin="10"
                                HeightRequest="300">
                                <dx:DXPopup.Content>
                                    <Grid Margin="10" RowDefinitions="auto,*">
                                        <Label
                                            Grid.Row="0"
                                            HorizontalOptions="Center"
                                            Text="{Binding ArtistToSong.Count, StringFormat='{0} Artists'}" />

                                        <dx:DXCollectionView
                                            Grid.Row="1"
                                            ItemSpacing="10"
                                            ItemsSource="{Binding ArtistToSong}"
                                            MaximumHeightRequest="300">
                                            <dx:DXCollectionView.ItemTemplate>
                                                <DataTemplate x:DataType="models:ArtistModelView">
                                                    <Grid ColumnDefinitions="*,auto">
                                                        <dx:DXStackLayout Grid.Column="0">
                                                            <Label Text="{Binding Name}" />
                                                        </dx:DXStackLayout>

                                                        <dx:DXStackLayout Grid.Column="1">
                                                            <dx:DXButton
                                                                x:Name="NavToArtistPage"
                                                                Clicked="NavToArtistPage_Clicked"
                                                                CommandParameter="{Binding .}"
                                                                Icon="eye.png"
                                                                ShowContent="False"
                                                                ShowIcon="True" />


                                                        </dx:DXStackLayout>
                                                    </Grid>
                                                </DataTemplate>
                                            </dx:DXCollectionView.ItemTemplate>
                                        </dx:DXCollectionView>
                                    </Grid>
                                </dx:DXPopup.Content>
                            </dx:DXPopup>
                        </dx:DXStackLayout>
                    </dx:DXScrollView>
                </dx:TabViewItem>

                <dx:TabViewItem HeaderText="Search Lyrics">
                    <dx:DXScrollView>

                        <dx:DXStackLayout
                            x:Name="LyricsTabVSL"
                            x:DataType="vm:BaseViewModelAnd"
                            ItemSpacing="10"
                            Loaded="LyricsTabVSL_Loaded">
                            <Grid ColumnDefinitions="*,auto" ColumnSpacing="5">

                                <dx:TextEdit LabelText="Track Name" Text="{Binding LyricsTrackNameSearch}" />

                                <dx:DXStackLayout
                                    Grid.Column="1"
                                    ItemSpacing="10"
                                    Orientation="Horizontal"
                                    VerticalOptions="End">

                                    <dx:Chip
                                        x:Name="QuickCopyTitleNameToClipBoardChip"
                                        BorderThickness="0"
                                        HeightRequest="50"
                                        Icon="copy.png"
                                        IconSize="35,35"
                                        IsIconVisible="True"
                                        LongPressCommandParameter="copy"
                                        Tap="QuickActionChip_Tap"
                                        TapCommandParameter="title" />
                                    <dx:Chip
                                        x:Name="QuickPasteSongTitleToTextChip"
                                        BorderThickness="0"
                                        HeightRequest="55"
                                        Icon="clipboard.png"
                                        IconSize="35,35"
                                        IsIconVisible="True"
                                        LongPressCommandParameter="paste"
                                        Tap="QuickActionChip_Tap"
                                        TapCommandParameter="title" />

                                </dx:DXStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="*,auto" ColumnSpacing="5">

                                <dx:TextEdit LabelText="Artist Name" Text="{Binding LyricsArtistNameSearch}" />

                                <dx:DXStackLayout
                                    Grid.Column="1"
                                    ItemSpacing="10"
                                    Orientation="Horizontal"
                                    VerticalOptions="End">

                                    <dx:Chip
                                        x:Name="QuickCopyArtistNameToClipBoardChip"
                                        BorderThickness="0"
                                        HeightRequest="50"
                                        Icon="copy.png"
                                        IconSize="35,35"
                                        IsIconVisible="True"
                                        LongPressCommandParameter="copy"
                                        Tap="QuickActionChip_Tap"
                                        TapCommandParameter="artist" />
                                    <dx:Chip
                                        x:Name="QuickPasteArtistNameToTextChip"
                                        BorderThickness="0"
                                        HeightRequest="55"
                                        Icon="clipboard.png"
                                        IconSize="35,35"
                                        IsIconVisible="True"
                                        LongPressCommandParameter="paste"
                                        Tap="QuickActionChip_Tap"
                                        TapCommandParameter="artist" />

                                </dx:DXStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="*,auto" ColumnSpacing="5">

                                <dx:TextEdit LabelText="Album Name" Text="{Binding LyricsAlbumNameSearch}" />

                                <dx:DXStackLayout
                                    Grid.Column="1"
                                    ItemSpacing="10"
                                    Orientation="Horizontal"
                                    VerticalOptions="End">

                                    <dx:Chip
                                        x:Name="QuickCopyAlbumNameToClipBoardChip"
                                        BorderThickness="0"
                                        HeightRequest="50"
                                        Icon="copy.png"
                                        IconSize="35,35"
                                        IsIconVisible="True"
                                        LongPressCommandParameter="copy"
                                        Tap="QuickActionChip_Tap"
                                        TapCommandParameter="album" />
                                    <dx:Chip
                                        x:Name="QuickPasteAlbumNameToTextChip"
                                        BorderThickness="0"
                                        HeightRequest="55"
                                        Icon="clipboard.png"
                                        IconSize="35,35"
                                        IsIconVisible="True"
                                        LongPressCommandParameter="paste"
                                        Tap="QuickActionChip_Tap"
                                        TapCommandParameter="album" />

                                </dx:DXStackLayout>
                            </Grid>


                            <dx:DXButton
                                x:Name="SearchLyricsBtn"
                                Clicked="SearchLyricsBtn_Clicked"
                                Content="Search Sync Lyrics Online" />
                            <ActivityIndicator IsRunning="{Binding IsLyricsSearchBusy}" IsVisible="{Binding IsLyricsSearchBusy}" />
                            <dx:DXCollectionView ItemSpacing="10" ItemsSource="{Binding LyricsSearchResults}">

                                <dx:DXCollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="lyrModels:LrcLibLyrics">
                                        <dx:DXStackLayout
                                            Padding="10"
                                            BorderColor="DarkSlateBlue"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            ItemSpacing="5">
                                            <Label FontAttributes="Bold" Text="{Binding TrackName, StringFormat='Title: {0}'}" />
                                            <Label FontAttributes="Bold" Text="{Binding DurationFormatted, StringFormat='Duration : {0}'}" />

                                            <Label Text="{Binding ArtistName, StringFormat='Artist : {0}'}" />
                                            <Label Text="{Binding AlbumName, StringFormat='Album : {0}'}" />
                                            <Label IsVisible="{Binding Instrumental}" Text="Is Instrumental" />
                                            <dx:DXButton
                                                x:Name="ApplyLyrics"
                                                Clicked="ApplyLyrics_Clicked"
                                                CommandParameter="{Binding .}"
                                                Content="Save Lyrics" />
                                            <dx:DXScrollView MaximumHeightRequest="250">

                                                <Label Text="{Binding SyncedLyrics}" />

                                            </dx:DXScrollView>
                                        </dx:DXStackLayout>
                                    </DataTemplate>
                                </dx:DXCollectionView.ItemTemplate>
                            </dx:DXCollectionView>

                        </dx:DXStackLayout>

                    </dx:DXScrollView>
                </dx:TabViewItem>


                <dx:TabViewItem HeaderText="Statistics">

                    <dx:DXStackLayout
                        x:Name="StatisticsStackLayout"
                        x:DataType="globalVM:StatisticsViewModel"
                        Loaded="StatisticsStackLayout_Loaded">


                        <Label HorizontalOptions="Center" Text="{Binding SongStats.FilterUsed}" />
                        <Label HorizontalOptions="Center" Text="{Binding SongStats.PowerHour.Name}" />
                        <Label HorizontalOptions="Center" Text="{Binding SongStats.PowerHour.Count}" />
                        <Label HorizontalOptions="Center" Text="{Binding SongStats.PowerHour.StatTitle}" />
                        <Label HorizontalOptions="Center" Text="{Binding SongStats.PowerHour.Value}" />


                        <dx:PieChartView HeightRequest="400">
                            <dx:PieChartView.Series>
                                <dx:PieSeries>
                                    <dx:PieSeries.Data>
                                        <dx:PieSeriesDataAdapter
                                            DataSource="{Binding SongStats.PowerHour}"
                                            LabelDataMember="Value"
                                            ValueDataMember="Count" />
                                    </dx:PieSeries.Data>
                                </dx:PieSeries>
                            </dx:PieChartView.Series>
                        </dx:PieChartView>






                    </dx:DXStackLayout>

                </dx:TabViewItem>

                <dx:TabViewItem HeaderText="TimeLine">
                    <dx:DXScrollView>
                        <Grid RowDefinitions="auto,*">
                            <dx:DXStackLayout Grid.Row="0">
                                <Label Text="{Binding PlayEvents.Count}" />
                            </dx:DXStackLayout>
                            <dx:DataGridView
                                Grid.Row="1"
                                AutoGenerateColumnsMode="None"
                                ItemsSource="{Binding PlayEvents}"
                                RowHeight="80"
                                ShowAutoFilterRow="True"
                                ShowFilterIcon="True">
                                <dx:DataGridView.Columns>
                                    <dx:TextColumn AllowSort="True" FieldName="PlayTypeStr" />
                                    <dx:DateColumn FieldName="EventDate" />
                                    <dx:CheckBoxColumn FieldName="WasPlayCompleted" />
                                </dx:DataGridView.Columns>
                            </dx:DataGridView>
                        </Grid>
                    </dx:DXScrollView>
                </dx:TabViewItem>


            </dx:TabView>


            <dx:BottomSheet
                x:Name="EditSongBtmSheet"
                AllowedState="All"
                ShowGrabber="False"
                State="FullExpanded">
                <dx:BottomSheet.Content>
                    <dx:DXStackLayout Padding="10" ItemSpacing="10">
                        <FlexLayout JustifyContent="SpaceBetween">
                            <Label FontSize="20" Text="Edit Song Details" />
                            <dx:DXButton
                                Command="{Binding Commands.Close, Source={Reference EditSongBtmSheet}}"
                                Content="X"
                                ShowContent="True"
                                ShowIcon="False" />
                        </FlexLayout>

                        <dx:TextEdit Text="{Binding Title}" />

                        <dx:FormListPickerItem
                            HorizontalOptions="Start"
                            ItemsSource="{Binding ArtistToSong}"
                            PickerShowMode="Popup"
                            SelectedItem="{Binding Artist}"
                            ShowSearchPanel="True"
                            TextLineBreakMode="WordWrap">

                            <dx:FormListPickerItem.InlineContentTemplate>
                                <DataTemplate x:DataType="models:ArtistModelView">
                                    <Label Text="{Binding Name}" />
                                </DataTemplate>
                            </dx:FormListPickerItem.InlineContentTemplate>

                        </dx:FormListPickerItem>

                        <dx:TextEdit Text="{Binding Title}" />

                        <dx:TextEdit Text="{Binding Title}" />


                    </dx:DXStackLayout>
                </dx:BottomSheet.Content>
            </dx:BottomSheet>

        </Grid>
    </dx:DXScrollView>
</ContentPage>