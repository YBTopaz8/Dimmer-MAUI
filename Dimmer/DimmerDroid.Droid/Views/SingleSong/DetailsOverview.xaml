<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dimmer.Views.SingleSong.DetailsOverview"
             xmlns:globalVM="clr-namespace:Dimmer.ViewModel;assembly=Dimmer"
            xmlns:vm="clr-namespace:Dimmer.ViewModels"
             xmlns:lyrModels="clr-namespace:Dimmer.Data.Models.LyricsModels;assembly=Dimmer"
 xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
 xmlns:dx="http://schemas.devexpress.com/maui"
 xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
  Shell.NavBarIsVisible="False"
            
>
    <dx:DXScrollView Margin="5,0">
        <Grid>
            
        <dx:TabView x:Name="SongTabView" HeaderPanelPosition="Bottom" PropertyChanging="SongTabView_PropertyChanging">
            <dx:TabViewItem x:Name="OverViewTab" HeaderText="OverView" >
                
                <dx:DXStackLayout 
                    
                    ItemSpacing="5">
                    <Grid ColumnDefinitions="150,*">
                        <dx:DXImage 
                            Grid.Column="0"
                            Source="{Binding CoverImagePath}" MaximumHeightRequest="300" MaximumWidthRequest="300" Aspect="AspectFit" HorizontalOptions="Center"/>
                        
                        <dx:DXStackLayout Grid.Column="1" ItemSpacing="5">
                            <Label Text="{Binding Title}" HorizontalTextAlignment="Justify"
                           LineBreakMode="WordWrap" 
                                   x:Name="TitleLabel"
                                   SizeChanged="SongTitleLabel_SizeChanged"
                                   FontSize="23" />
                            <dx:Chip  Text="{Binding OtherArtistsName}" HorizontalOptions="Center"
                          
                                   FontSize="17" />
                            <dx:Chip  Text="{Binding AlbumName}" HorizontalOptions="Center"
                          
                                   FontSize="14" />
                        </dx:DXStackLayout>
                    </Grid>
                    
                    <dx:Chip Text="{Binding GenreName}" HorizontalOptions="Center"
                           
                             FontSize="12" />

                    <dx:Chip Text="{Binding PlayCompletedCount}"/>
                    <dx:Chip Text="{Binding PauseCount}"/>
                    <dx:Chip Text="{Binding SkipCount}"/>
                    
                    <dx:Chip Icon="heart.png" IsVisible="{Binding IsFavorite}"/>
                </dx:DXStackLayout>
            </dx:TabViewItem>

            <dx:TabViewItem HeaderText="Lyrics" >
                <dx:DXScrollView>
                    
                <dx:DXStackLayout ItemSpacing="10" x:DataType="vm:BaseViewModelAnd" Loaded="LyricsTabVSL_Loaded" x:Name="LyricsTabVSL">
                    <dx:DXStackLayout 
                        ItemSpacing="10">
                        <dx:TextEdit Text="{Binding LyricsTrackNameSearch}"
                                     LabelText="Track Name"/>

                        <!--<dx:Chip BorderThickness="0"
                                 
                                 Icon="copy.png"/>

                        <dx:Chip BorderThickness="0"
                                 Icon="clearalt.png"/>

                        <dx:Chip BorderThickness="0"
                                 
                                 Icon="clipboard.png"/>-->
                    </dx:DXStackLayout>
                    <dx:DXStackLayout 
    >
                        <dx:TextEdit Text="{Binding LyricsArtistNameSearch}" LabelText="Artist Name"/>
                        </dx:DXStackLayout>

                        <dx:DXStackLayout  
    ItemSpacing="10">
                        <dx:TextEdit 
                            LabelText="Album Name"
                            Text="{Binding LyricsAlbumNameSearch}"/>
                    </dx:DXStackLayout>
                    <dx:DXButton x:Name="SearchLyricsBtn" Content="Search Online"
                                 Command="{Binding SearchLyricsCommand}"/>
                    <ActivityIndicator IsRunning="{Binding IsLyricsSearchBusy}"
                                       IsVisible="{Binding IsLyricsSearchBusy}"
                                       />
                    <dx:DXCollectionView ItemsSource="{Binding LyricsSearchResults}"
                                         >
                        <dx:DXCollectionView.ItemTemplate>
                            <DataTemplate x:DataType="lyrModels:LrcLibLyrics">
                                <dx:DXStackLayout>
                                    <dx:DXStackLayout Orientation="Horizontal" ItemSpacing="10">
                                        <Label Text="{Binding TrackName}"/>
                                        <Label Text="{Binding DurationFormatted}"/>
                                        
                                    </dx:DXStackLayout>
                                        <Label Text="{Binding ArtistName}"/>
                                        <Label Text="{Binding AlbumName}"/>
                                        <Label IsVisible="{Binding Instrumental}"/>
                                        <dx:DXButton x:Name="ApplyLyrics" Command="{Binding SelectLyricsCommand}" x:DataType="vm:BaseViewModelAnd"
            CommandParameter="{Binding .}" />
                                        <dx:DXScrollView MaximumHeightRequest="250">
                                            
                                    <Label Text="{Binding SyncedLyrics}"/>

                                        </dx:DXScrollView>
                                    </dx:DXStackLayout>
                            </DataTemplate>
                        </dx:DXCollectionView.ItemTemplate>
                    </dx:DXCollectionView>

                </dx:DXStackLayout>

                </dx:DXScrollView>
            </dx:TabViewItem>

                <dx:TabViewItem HeaderText="Play History" x:DataType="models:SongModelView">
                <dx:DXScrollView>
                    
                <dx:DXStackLayout>

                    <dx:DataGridView ItemsSource="{Binding PlayEvents}"
                                     AutoGenerateColumnsMode="None">
                        <dx:DataGridView.Columns>
                                <dx:TextColumn Caption="Play Type" FieldName="PlayTypeStr"/>
                                <dx:TemplateColumn FieldName="EventDate">
                                    <dx:TemplateColumn.DisplayTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Label Text="{Binding .,StringFormat='{0:dd-MM-yyyy HH:mm}'}"/>
                                        </DataTemplate>
                                    </dx:TemplateColumn.DisplayTemplate>
                                </dx:TemplateColumn>
                            <dx:NumberColumn FieldName="PositionInSeconds"
                                             />
                        </dx:DataGridView.Columns>
                    </dx:DataGridView>
                </dx:DXStackLayout>

                </dx:DXScrollView>
            </dx:TabViewItem>
                <dx:TabViewItem HeaderText="Statistics">
                    <dx:DXScrollView Loaded="StatisticsScrollView_Loaded" x:Name="StatisticsScrollV"
                                     x:DataType="globalVM:StatisticsViewModel">
                        <dx:DXStackLayout ItemSpacing="5">
                            <dx:DXStackLayout.Resources>
                                <Style TargetType="Grid">
                                    <Setter Property="ColumnSpacing" Value="5"/>
                                </Style>
                                <Style TargetType="dx:DXStackLayout">
                                    <Setter Property="ItemSpacing" Value="5"/>
                                </Style>
                            </dx:DXStackLayout.Resources>
                            <Grid ColumnDefinitions="*,*" >
                                <dx:Chip Grid.Column="0" >
                                    <dx:Chip.ContentTemplate>
                                        <DataTemplate >
                                            <dx:DXStackLayout>
                                                <Label Text="Total Play Time"/>
                                                <Label Text="{Binding SongStats.Summary.TotalListeningTimeFormatted}" Loaded="Label_Loaded"/>
                                            </dx:DXStackLayout>
                                        </DataTemplate>
                                    </dx:Chip.ContentTemplate>
                                </dx:Chip>

                                <dx:Chip Grid.Column="1" >
                                    <dx:Chip.ContentTemplate>
                                        <DataTemplate >
                                            <dx:DXStackLayout >
                                    <Label Text="Total Skips"/>
                                    <Label Text="{Binding SongStats.Summary.TotalSkips}"/>
                                </dx:DXStackLayout>
                                            </DataTemplate>
                                        </dx:Chip.ContentTemplate>
                                    </dx:Chip>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" >
                                <dx:Chip Grid.Column="0" >
                                    <dx:Chip.ContentTemplate>
                                        <DataTemplate >
                                            <dx:DXStackLayout>
                                                <Label Text="Most Frequent Play Hour"/>
                                                <Label Text="{Binding SongStats.Summary.MostFrequentPlayHourFormatted}"/>
                                            </dx:DXStackLayout>
                                        </DataTemplate>
                                    </dx:Chip.ContentTemplate>
                                </dx:Chip>

                                <dx:Chip Grid.Column="1" >
                                    <dx:Chip.ContentTemplate>
                                        <DataTemplate >
                                            <dx:DXStackLayout HorizontalOptions="Center" >
                                                <Label Text="Longest Listening Streak "/>
                                                <Label Text="{Binding SongStats.Summary.LongestListeningStreakDays}"  HorizontalOptions="Center"/>
                                </dx:DXStackLayout>
                                            </DataTemplate>
                                        </dx:Chip.ContentTemplate>
                                    </dx:Chip>
                            </Grid>
                            
                        </dx:DXStackLayout>
                    </dx:DXScrollView>
                </dx:TabViewItem>
        </dx:TabView>

         <HorizontalStackLayout HorizontalOptions="End" VerticalOptions="End">
                <dx:DXExpander IsExpanded="False" x:DataType="vm:BaseViewModelAnd"
                               Loaded="MiniNPExpander_Loaded"
                    x:Name="MiniNPExpander" HorizontalExpandMode="FromEndToStart"
                    VerticalExpandMode="FromCenter">
                    <dx:DXExpander.Content>
                        <dx:DXStackLayout>
                            <dx:DXStackLayout>
                                <Label Text="{Binding CurrentPlayingSongView.Title}"/>
                                <Label Text="{Binding CurrentPlayingSongView.ArtistName}"/>
                                <Label Text="{Binding CurrentPlayingSongView.AlbumName}"/>
                            </dx:DXStackLayout>
                            <dx:DXStackLayout Orientation="Horizontal"
                                              ItemSpacing="10" HorizontalOptions="Center">
                                
                            </dx:DXStackLayout>
                        </dx:DXStackLayout>
                    </dx:DXExpander.Content>
                </dx:DXExpander>
            </HorizontalStackLayout>
        </Grid>
    </dx:DXScrollView>
</ContentPage>