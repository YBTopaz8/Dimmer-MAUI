<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dimmer.Views.SingleSong.DetailsOverview"
    x:Name="myPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:Dimmer.Utilities.TypeConverters;assembly=Dimmer"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:globalVM="clr-namespace:Dimmer.ViewModel;assembly=Dimmer"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:lyrModels="clr-namespace:Dimmer.Data.Models.LyricsModels;assembly=Dimmer"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:statsModels="clr-namespace:Dimmer.Charts;assembly=Dimmer"
    xmlns:statsVM="clr-namespace:Dimmer.ViewModel.StatsVMs;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    Padding="5"
    x:DataType="models:SongModelView"
    Shell.NavBarIsVisible="False"
    >

    <ContentPage.Resources>
        <ResourceDictionary>

            <conv:BoolToInverseConverter x:Key="BoolToInverseConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <dx:DXScrollView>
        <dx:DXStackLayout ItemSpacing="10">

            <Grid ColumnDefinitions="150,*" ColumnSpacing="5">
                <dx:DXStackLayout Grid.Column="0">

                    <dx:DXImage
                        Aspect="AspectFit"
                        HorizontalOptions="Center"
                        MaximumHeightRequest="350"
                        MaximumWidthRequest="350"
                        Source="{Binding CoverImagePath}"
                        VerticalOptions="Start"
                        />
                    <dx:DXButton
                        Padding="0"
                        BackgroundColor="Transparent"
                        Icon="heart.png"
                        IconColor="DarkSlateBlue"
                        IconHeight="40"
                        IconWidth="40"
                        IsVisible="{Binding IsFavorite}"
                        ShowIcon="True"
                        />
                </dx:DXStackLayout>


                <dx:DXStackLayout
                    Grid.Column="1"
                    ItemSpacing="5"
                    VerticalOptions="Start"
                    >
                    <Label
                        x:Name="TitleLabel"
                        FontSize="23"
                        HorizontalTextAlignment="Justify"
                        LineBreakMode="WordWrap"
                        Text="{Binding Title}"
                        VerticalOptions="Start"
                        />
                    <dx:Chip
                        x:Name="ArtistNamesChip"
                        FontSize="17"
                        HorizontalOptions="Start"
                        Icon="artistt.png"
                        IsIconVisible="True"
                        Tap="ArtistNamesChip_Tap"
                        >
                        <dx:Chip.ContentTemplate>
                            <DataTemplate>
                                <Label Text="{Binding OtherArtistsName}" />
                            </DataTemplate>
                        </dx:Chip.ContentTemplate>
                    </dx:Chip>
                    <dx:Chip
                        x:Name="AlbumChip"
                        FontSize="14"
                        HorizontalOptions="Start"
                        Icon="musicalbum.png"
                        IsIconVisible="True"
                        Tap="AlbumChip_Tap"
                        TapCommandParameter="{Binding Album}"
                        >
                        <dx:Chip.ContentTemplate>
                            <DataTemplate>
                                <Label Text="{Binding AlbumName}" />
                            </DataTemplate>
                        </dx:Chip.ContentTemplate>
                    </dx:Chip>
                    <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                        <dx:Chip
                            FontSize="12"
                            HorizontalOptions="Start"
                            Text="{Binding GenreName}"
                            ToolTipProperties.Text="Genre Name"
                            />
                        <dx:Chip
                            BindingContext="{Binding StatsViewModel.TextCompletionRate, Source={x:Reference myPage}}"
                            FontSize="12"
                            HorizontalOptions="Start"
                            ToolTipProperties.Text="{Binding StatsViewModel.TextCompletionRate.Title, Source={x:Reference myPage}}"
                            >
                            <dx:Chip.ContentTemplate>
                                <DataTemplate x:DataType="statsModels:TextStat">
                                    <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                        <Label Text="{Binding Value}" />
                                    </dx:DXStackLayout>
                                </DataTemplate>
                            </dx:Chip.ContentTemplate>
                        </dx:Chip>

                    </dx:DXStackLayout>
                </dx:DXStackLayout>
            </Grid>

            <BoxView HeightRequest="1" Color="DarkSlateBlue" />

            <Grid ColumnDefinitions="*,auto">

                <Label
                    Grid.Column="0"
                    FontSize="26"
                    HorizontalOptions="Center"
                    Text="Info"
                    />
                <dx:DXButton
                    Grid.Column="1"
                    Padding="4"
                    BackgroundColor="Transparent"
                    BorderThickness="0"
                    Icon="pen.png"
                    IconColor="DarkSlateBlue"
                    IconHeight="25"
                    IconWidth="25"
                    ShowContent="False"
                    ShowIcon="True"
                    />
            </Grid>
            <dx:DXBorder
                Padding="5"
                BorderColor="DarkSlateBlue"
                BorderThickness="1"
                CornerRadius="10"
                >

                <Grid ColumnDefinitions="*,*">
                    <Grid.Resources>
                        <ResourceDictionary>
                            <Style TargetType="Label">
                                <Setter Property="FontSize" Value="18" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Dark=white, Light=black}" />
                            </Style>
                        </ResourceDictionary>
                    </Grid.Resources>
                    <dx:DXStackLayout Grid.Column="0" ItemSpacing="15">
                        <Label Text="Date Created" />
                        <Label Text="BitRate" />
                        <Label Text="Track Number" />
                        <Label Text="Duration In Seconds" />
                        <Label Text="Release Year" />
                    </dx:DXStackLayout>


                    <dx:DXStackLayout
                        Grid.Column="1"
                        HorizontalOptions="End"
                        ItemSpacing="15"
                        >
                        <dx:DXStackLayout.Resources>
                            <ResourceDictionary>
                                <Style TargetType="Label">
                                    <Setter Property="FontFamily" Value="AleySans" />
                                    <Setter Property="FontSize" Value="18" />
                                    <Setter Property="TextColor" Value="{AppThemeBinding Dark=white, Light=black}" />
                                </Style>
                            </ResourceDictionary>
                        </dx:DXStackLayout.Resources>
                        <Label HorizontalTextAlignment="End" Text="{Binding DateCreated, StringFormat='{0:dd MMMM,yyyy hh:mm}'}" />
                        <Label HorizontalTextAlignment="End" Text="{Binding BitRate, StringFormat='{0} kbps'}" />
                        <Label HorizontalTextAlignment="End" Text="{Binding TrackNumber, StringFormat='{0}'}" />
                        <Label HorizontalTextAlignment="End" Text="{Binding DurationInSeconds, StringFormat='{0} seconds'}" />
                        <Label HorizontalTextAlignment="End" Text="{Binding ReleaseYear, StringFormat='{0}'}" />

                    </dx:DXStackLayout>
                </Grid>


            </dx:DXBorder>

            <BoxView HeightRequest="1" Color="DarkSlateBlue" />


            <Grid ColumnDefinitions="*,auto">

                <Label
                    Grid.Column="0"
                    FontSize="26"
                    HorizontalOptions="Center"
                    Text="Stats"
                    />


            </Grid>
            <Grid
                x:Name="StatsSectionPreview"
                Padding="5"
                x:DataType="statsVM:ArtistStatsViewModel"
                Loaded="StatsSectionPreview_Loaded"
                MaximumHeightRequest="400"
                >
                <dx:SlideView
                    x:Name="StatsSlideView"
                    Padding="0"
                    BorderColor="Gray"
                    BorderThickness="1"
                    CornerRadius="15"
                    >
                    <dx:SlideView.Resources>
                        <Style TargetType="dx:DXCollectionView">
                            <Setter Property="ItemSpacing" Value="5" />
                        </Style>
                    </dx:SlideView.Resources>
                    <dx:SlideView.Items>

                        <dx:DXCollectionView
                            Header="Events"
                            ItemSeparatorColor="DarkSlateBlue"
                            ItemSeparatorThickness="1"
                            ItemSpacing="5"
                            ItemsSource="{Binding MyViewModel.SelectedSong.PlayEvents, Source={x:Reference myPage}}"
                            >
                            <dx:DXCollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:DimmerPlayEventView">
                                    <dx:DXStackLayout>
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="21"
                                            Text="{Binding PlayTypeStr}"
                                            />
                                        <Label FontSize="16" Text="{Binding EventDate}" />
                                    </dx:DXStackLayout>
                                </DataTemplate>
                            </dx:DXCollectionView.ItemTemplate>
                        </dx:DXCollectionView>

                        <dx:DXCollectionView
                            x:Name="ListWalkthrough"
                            Grid.Column="1"
                            Header="Walkthrough"
                            ItemSpacing="5"
                            Loaded="ListWalkthrough_Loaded"
                            >
                            <dx:DXCollectionView.ItemTemplate>
                                <DataTemplate>
                                    <dx:DXStackLayout
                                        Padding="5"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        >
                                        <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                            <Label Text="Session Summary" />
                                            <Label Text="{Binding SessionSummary}" />
                                        </dx:DXStackLayout>
                                        <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                            <Label Text="StartTime" />
                                            <Label Text="{Binding StartTime}" />
                                        </dx:DXStackLayout>
                                        <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                            <Label Text="EventCount" />
                                            <Label Text="{Binding EventCount}" />
                                        </dx:DXStackLayout>
                                        <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                            <Label Text="Total Listening Time Seconds" />
                                            <Label Text="{Binding TotalListeningTimeSeconds}" />
                                        </dx:DXStackLayout>
                                    </dx:DXStackLayout>
                                </DataTemplate>
                            </dx:DXCollectionView.ItemTemplate>
                        </dx:DXCollectionView>
                        <dx:DXCollectionView
                            x:Name="ListWeeklyTrend"
                            Grid.Column="3"
                            Header="Weekly Trend"
                            Loaded="ListWeeklyTrend_Loaded"
                            >
                            <dx:DXCollectionView.ItemTemplate>
                                <DataTemplate x:DataType="statsModels:TrendStat">
                                    <dx:DXStackLayout
                                        Padding="10"
                                        BorderColor="Gray"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        >
                                        <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                            <Label Text="Period" />
                                            <Label Text="{Binding Period}" />

                                            <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                                <Label Text="(" />
                                                <Label Text="{Binding PlayCount}" />
                                                <Label Text=" dims)" />
                                            </dx:DXStackLayout>
                                        </dx:DXStackLayout>

                                        <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                            <Label Text="Change Vs Previous" />
                                            <Label
                                                FontAttributes="Bold"
                                                Text="{Binding ChangeVsPrevious}"
                                                TextColor="Orange"
                                                />
                                        </dx:DXStackLayout>
                                    </dx:DXStackLayout>
                                </DataTemplate>
                            </dx:DXCollectionView.ItemTemplate>
                        </dx:DXCollectionView>
                        <dx:DXCollectionView
                            x:Name="ListMonthlyTrend"
                            Grid.Column="2"
                            Header="MonthlyTrend"
                            Loaded="ListMonthlyTrend_Loaded"
                            >
                            <dx:DXCollectionView.ItemTemplate>
                                <DataTemplate x:DataType="statsModels:TrendStat">
                                    <dx:DXStackLayout
                                        Padding="10"
                                        BorderColor="Gray"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        >
                                        <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                            <Label Text="Period" />
                                            <Label Text="{Binding Period}" />
                                            <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                                <Label Text="(" />
                                                <Label Text="{Binding PlayCount}" />
                                                <Label Text=" dims)" />
                                            </dx:DXStackLayout>
                                        </dx:DXStackLayout>

                                        <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                            <Label Text="Change Vs Previous" />
                                            <Label Text="{Binding ChangeVsPrevious}" TextColor="Orange" />
                                        </dx:DXStackLayout>

                                    </dx:DXStackLayout>
                                </DataTemplate>
                            </dx:DXCollectionView.ItemTemplate>
                        </dx:DXCollectionView>




                    </dx:SlideView.Items>
                </dx:SlideView>

                <FlexLayout JustifyContent="SpaceBetween">
                    <dx:DXButton
                        BorderColor="DarkSlateBlue"
                        BorderThickness="1"
                        Command="{Binding Commands.ShowPrevious, Source={Reference StatsSlideView}}"
                        Icon="skipprevious.png"
                        ShowContent="False"
                        VerticalOptions="End"
                        />
                    <dx:DXButton
                        Command="{Binding Commands.ShowNext, Source={Reference StatsSlideView}}"
                        Icon="skipnext.png"
                        VerticalOptions="End"
                        />
                </FlexLayout>
            </Grid>

            <Grid MaximumHeightRequest="100">

                <dx:DXCollectionView
                    x:Name="ListPerfectPairings"
                    ItemSpacing="10"
                    Loaded="ListPerfectPairings_Loaded"
                    Orientation="Horizontal"
                    >
                    <dx:DXCollectionView.ItemTemplate>
                        <DataTemplate x:DataType="statsModels:SongPairing">
                            <dx:DXStackLayout
                                Padding="10"
                                BorderColor="Gray"
                                BorderThickness="1"
                                CornerRadius="10"
                                VerticalOptions="Start"
                                >
                                <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                    <Label Text="Paired Song Title" />
                                    <Label Text="{Binding PairedSongTitle}" />
                                </dx:DXStackLayout>

                                <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">

                                    <Label Text="Times Played Together" />
                                    <Label Text="{Binding TimesPlayedTogether}" />
                                </dx:DXStackLayout>
                                <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">


                                    <Label Text="{Binding Context}" />
                                </dx:DXStackLayout>
                            </dx:DXStackLayout>
                        </DataTemplate>
                    </dx:DXCollectionView.ItemTemplate>
                </dx:DXCollectionView>
            </Grid>

            <BoxView HeightRequest="2" Color="DarkSlateBlue" />


            <Grid ColumnDefinitions="*,auto">

                <Label
                    Grid.Column="0"
                    FontSize="26"
                    HorizontalOptions="Center"
                    Text="Lyrics Section"
                    />
                <dx:DXButton
                    x:Name="EditLyrics"
                    Grid.Column="1"
                    Padding="4"
                    BackgroundColor="Transparent"
                    BorderThickness="0"
                    Clicked="EditLyrics_Clicked"
                    Icon="pen.png"
                    IconColor="DarkSlateBlue"
                    IconHeight="25"
                    IconWidth="25"
                    ShowContent="False"
                    ShowIcon="True"
                    />
            </Grid>

            <dx:DXScrollView AllowBounceEffect="True" MaximumHeightRequest="450">
                <Label Text="{Binding SyncLyrics}" />
            </dx:DXScrollView>

            <dx:DXPopup
                x:Name="ArtistToSongPopup"
                Margin="10"
                MaximumHeightRequest="500"
                >
                <dx:DXPopup.Content>
                    <Grid Margin="10" RowDefinitions="auto,*">
                        <Label
                            Grid.Row="0"
                            HorizontalOptions="Center"
                            Text="{Binding ArtistToSong.Count, StringFormat='{0} Artists'}"
                            />

                        <dx:DXCollectionView
                            Grid.Row="1"
                            ItemSpacing="10"
                            ItemsSource="{Binding ArtistToSong}"
                            MaximumHeightRequest="200"
                            >
                            <dx:DXCollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ArtistModelView">
                                    <Grid ColumnDefinitions="*,auto">
                                        <dx:DXStackLayout Grid.Column="0">
                                            <Label FontSize="23" Text="{Binding Name}" />
                                        </dx:DXStackLayout>

                                        <dx:DXStackLayout Grid.Column="1">
                                            <dx:DXButton
                                                x:Name="NavToArtistPage"
                                                Clicked="NavToArtistPage_Clicked"
                                                CommandParameter="{Binding .}"
                                                Icon="eye.png"
                                                ShowContent="False"
                                                ShowIcon="True"
                                                />


                                        </dx:DXStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </dx:DXCollectionView.ItemTemplate>
                        </dx:DXCollectionView>
                    </Grid>
                </dx:DXPopup.Content>
            </dx:DXPopup>
        </dx:DXStackLayout>
    </dx:DXScrollView>
