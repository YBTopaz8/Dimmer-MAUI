<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dimmer.Views.Artist.ArtistPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:globalVM="clr-namespace:Dimmer.ViewModel;assembly=Dimmer"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    Title="{Binding Name}"
    x:DataType="models:ArtistModelView"
    Shell.NavBarIsVisible="True">
    <Grid RowDefinitions="auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,*">

            <dx:DXImage Grid.Column="0" Source="{Binding ImagePath}" />

            <dx:DXStackLayout Grid.Column="1" ItemSpacing="10">
                <dx:Chip Text="{Binding SongsByArtist.Count, StringFormat='{0} Songs'}" />
                <dx:Chip Text="{Binding AlbumsByArtist.Count, StringFormat='{0} Albums'}" />
                <dx:DXButton
                    x:Name="LoadLastFMInfo"
                    BackgroundColor="Transparent"
                    Clicked="LoadLastFMInfo_Clicked"
                    Icon="lastfm.png"
                    IconColor="Red"
                    IconHeight="30"
                    IconWidth="30"
                    ShowContent="False"
                    ShowIcon="True" />

            </dx:DXStackLayout>
        </Grid>

        <dx:TabView
            x:Name="ArtistDetailsTableView"
            Grid.Row="1"
            Margin="0,10,0,0"
            BackgroundColor="Transparent">
            <dx:TabViewItem x:Name="SongsByArtistTab" HeaderText="Songs">


                <dx:DXCollectionView Grid.Row="1" ItemsSource="{Binding SongsByArtist}">
                    <dx:DXCollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:SongModelView">
                            <Grid ColumnDefinitions="60,*,auto" RowDefinitions="80">
                                <dx:DXStackLayout Grid.Column="0">
                                    <dx:DXStackLayout.Triggers>
                                        <DataTrigger
                                            Binding="{Binding HasSyncedLyrics}"
                                            TargetType="dx:DXStackLayout"
                                            Value="True">
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="BorderColor" Value="DarkSlateBlue" />

                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding HasSyncedLyrics}"
                                            TargetType="dx:DXStackLayout"
                                            Value="False">
                                            <Setter Property="BorderThickness" Value="0" />

                                        </DataTrigger>

                                    </dx:DXStackLayout.Triggers>
                                    <dx:DXImage Aspect="AspectFit" Source="{Binding CoverImagePath}">
                                        <dx:DXImage.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="CurrentPlayingCoverTapGesture_Tapped" />
                                        </dx:DXImage.GestureRecognizers>
                                    </dx:DXImage>
                                </dx:DXStackLayout>

                                <dx:DXStackLayout Grid.Column="1" Orientation="Vertical">
                                    <dx:DXStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer
                                            x:Name="MiddleGridSection"
                                            NumberOfTapsRequired="1"
                                            Tapped="MiddleGridSection_Tapped" />
                                    </dx:DXStackLayout.GestureRecognizers>
                                    <dx:Chip
                                        x:Name="TitleChip"
                                        BorderThickness="0"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Start"
                                        Tap="TitleChip_Tap"
                                        Text="{Binding Title}" />
                                    <dx:Chip
                                        x:Name="ArtistChip"
                                        BorderThickness="0"
                                        FontSize="13"
                                        HorizontalOptions="Start"
                                        LongPress="ArtistChip_LongPress"
                                        Tap="ArtistChip_Tap"
                                        Text="{Binding ArtistName}" />
                                </dx:DXStackLayout>

                                <dx:DXStackLayout Grid.Column="2" Orientation="Vertical">
                                    <dx:Chip
                                        x:Name="MoreBtn"
                                        BackgroundColor="Transparent"
                                        BorderThickness="0"
                                        HeightRequest="30"
                                        Icon="more1.png"
                                        IsIconVisible="True"
                                        WidthRequest="30" />
                                    <Label
                                        Margin="5,0"
                                        FontSize="8"
                                        HorizontalOptions="End"
                                        Text="{Binding DurationFormatted}"
                                        VerticalOptions="Center" />
                                    <Label
                                        Margin="5,0"
                                        FontSize="8"
                                        HorizontalOptions="End"
                                        Text="{Binding TrackNumber}"
                                        VerticalOptions="Center" />
                                </dx:DXStackLayout>

                            </Grid>
                        </DataTemplate>
                    </dx:DXCollectionView.ItemTemplate>
                </dx:DXCollectionView>

            </dx:TabViewItem>
            <dx:TabViewItem x:Name="AlbumsByArtist" HeaderText="Albums">
                <dx:DXStackLayout>

                    <dx:DXCollectionView Grid.Row="1" ItemsSource="{Binding AlbumsByArtist}">
                        <dx:DXCollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:AlbumModelView">
                                <Grid ColumnDefinitions="60,*,auto" RowDefinitions="80">
                                    <dx:DXStackLayout Grid.Column="0">

                                        <dx:DXImage Aspect="AspectFit" Source="{Binding ImagePath}" />
                                    </dx:DXStackLayout>

                                    <dx:DXStackLayout Grid.Column="1" Orientation="Vertical">
                                        <dx:DXStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer x:Name="MiddleGridSection" NumberOfTapsRequired="1" />
                                        </dx:DXStackLayout.GestureRecognizers>
                                        <dx:Chip
                                            x:Name="TitleChip"
                                            BorderThickness="0"
                                            FontAttributes="Bold"
                                            HorizontalOptions="Start"
                                            Text="{Binding Name}" />
                                        <dx:Chip
                                            x:Name="SongsInAlbumCount"
                                            BorderThickness="0"
                                            FontSize="13"
                                            HorizontalOptions="Start"
                                            Text="{Binding SongsInAlbum.Count}" />
                                    </dx:DXStackLayout>

                                    <dx:DXStackLayout Grid.Column="2" Orientation="Vertical">
                                        <dx:Chip
                                            x:Name="MoreBtn"
                                            BackgroundColor="Transparent"
                                            BorderThickness="0"
                                            HeightRequest="30"
                                            Icon="more1.png"
                                            IsIconVisible="True"
                                            WidthRequest="30" />
                                        <Label
                                            Margin="5,0"
                                            FontSize="8"
                                            HorizontalOptions="End"
                                            Text="{Binding TotalDuration, StringFormat='{0:mm\\:ss}'}"
                                            VerticalOptions="Center" />
                                    </dx:DXStackLayout>

                                </Grid>
                            </DataTemplate>
                        </dx:DXCollectionView.ItemTemplate>
                    </dx:DXCollectionView>
                </dx:DXStackLayout>
            </dx:TabViewItem>


            <dx:TabViewItem HeaderText="Play History">
                <dx:DXStackLayout>
                    <dx:Chip x:Name="ExportEvt" Tap="ExportEvt_Tap" />
                    <dx:DataGridView
                        x:Name="PlayEventDG"
                        AutoGenerateColumnsMode="None"
                        ItemsSource="{Binding PlayEvents}">
                        <dx:DataGridView.Columns>


                            <dx:ImageColumn
                                Width="100"
                                Caption="Image"
                                FieldName="CoverImagePath" />
                            <dx:TextColumn
                                Width="150"
                                Caption="Title"
                                FieldName="SongTitle" />
                            <dx:TextColumn
                                Width="150"
                                Caption="Album Name"
                                FieldName="SongAlbumName" />
                            <dx:TextColumn
                                Width="110"
                                Caption="Play Type"
                                FieldName="PlayTypeStr" />
                            <dx:DateColumn
                                Width="110"
                                Caption="Event Date"
                                FieldName="EventDate" />
                            <dx:TextColumn
                                Width="80"
                                Caption="Position"
                                FieldName="PositionInSeconds" />
                        </dx:DataGridView.Columns>
                    </dx:DataGridView>
                </dx:DXStackLayout>
            </dx:TabViewItem>

            <dx:TabViewItem x:Name="ChartsTab" HeaderText="Charts">
                <dx:DXScrollView
                    x:Name="ChartsScrollView"
                    x:DataType="globalVM:StatisticsViewModel"
                    Loaded="ChartsScrollView_Loaded">

                    <dx:DXStackLayout Padding="10">
                        <Label Text="{Binding ArtistStats.FilterUsed}" />
                        <Label Text="{Binding ArtistStats.PlottableData.SongDurationDistributionMinutes.Count}" />
                        <Label Text="{Binding ArtistStats.PlottableData.PlaysPerDayOfWeek.Count}" />
                        <Label Text="{Binding ArtistStats.PlottableData.PlaysPerHourOfDay.Count}" />
                        <Label Text="{Binding ArtistStats.CollaboratorNetwork.Count}" />
                        <Label Text="{Binding ArtistStats.ObsessionRankedSongs.Count}" />


                        <dx:ChartView HeightRequest="150">
                            <dx:ChartView.Series>
                                <dx:LineSeries>
                                    <dx:LineSeries.Data>
                                        <dx:SeriesDataAdapter ArgumentDataMember="Label" DataSource="{Binding ArtistStats.PlottableData.SongDurationDistributionMinutes}">
                                            <dx:ValueDataMember Member="Value" Type="Value" />
                                        </dx:SeriesDataAdapter>
                                    </dx:LineSeries.Data>
                                </dx:LineSeries>
                            </dx:ChartView.Series>
                        </dx:ChartView>
                        <dx:PieChartView
                            x:Name="ActionsRadarChart"
                            Grid.Row="0"
                            HeightRequest="350"
                            WidthRequest="350">
                            <dx:PieChartView.Hint>
                                <dx:PieHint Enabled="True" />
                            </dx:PieChartView.Hint>
                            <dx:PieChartView.Series>

                                <dx:PieSeries>
                                    <dx:PieSeries.Label>
                                        <dx:PieSeriesLabel Position="Inside" />
                                    </dx:PieSeries.Label>
                                    <dx:PieSeries.Data>
                                        <dx:PieSeriesDataAdapter
                                            AllowLiveDataUpdates="True"
                                            DataSource="{Binding ArtistStats.ObsessionRankedSongs}"
                                            LabelDataMember="Label"
                                            ValueDataMember="Value" />


                                    </dx:PieSeries.Data>
                                </dx:PieSeries>
                            </dx:PieChartView.Series>
                        </dx:PieChartView>



                        <dx:ChartView HeightRequest="150">
                            <dx:ChartView.Series>
                                <dx:LineSeries>
                                    <dx:LineSeries.Data>
                                        <dx:SeriesDataAdapter ArgumentDataMember="Label" DataSource="{Binding ArtistStats.PlottableData.PlaysPerHourOfDay}">
                                            <dx:ValueDataMember Member="Value" Type="Value" />
                                        </dx:SeriesDataAdapter>
                                    </dx:LineSeries.Data>
                                </dx:LineSeries>
                            </dx:ChartView.Series>
                        </dx:ChartView>

                        <dx:ChartView HeightRequest="150">
                            <dx:ChartView.Series>
                                <dx:LineSeries>
                                    <dx:LineSeries.Data>
                                        <dx:SeriesDataAdapter ArgumentDataMember="Label" DataSource="{Binding ArtistStats.PlottableData.PlaysPerDayOfWeek}">
                                            <dx:ValueDataMember Member="Value" Type="Value" />
                                        </dx:SeriesDataAdapter>
                                    </dx:LineSeries.Data>
                                </dx:LineSeries>
                            </dx:ChartView.Series>
                        </dx:ChartView>

                        <dx:ChartView HeightRequest="150">
                            <dx:ChartView.Series>
                                <dx:LineSeries>
                                    <dx:LineSeries.Data>
                                        <dx:SeriesDataAdapter ArgumentDataMember="Label" DataSource="{Binding ArtistStats.PlottableData.PlaysPerMonth}">
                                            <dx:ValueDataMember Member="Value" Type="Value" />
                                        </dx:SeriesDataAdapter>
                                    </dx:LineSeries.Data>
                                </dx:LineSeries>
                            </dx:ChartView.Series>
                        </dx:ChartView>



                    </dx:DXStackLayout>

                </dx:DXScrollView>
            </dx:TabViewItem>
        </dx:TabView>


    </Grid>
</ContentPage>