<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dimmer.Views.Artist.ArtistPage"
    x:Name="myPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:globalVM="clr-namespace:Dimmer.ViewModel;assembly=Dimmer"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:statsVM="clr-namespace:Dimmer.ViewModel.StatsVMs;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    Title="{Binding Name}"
    x:DataType="models:ArtistModelView"
    Loaded="MyPage_Loaded"
    Shell.NavBarIsVisible="True"
    >
    <Grid Margin="5" RowDefinitions="auto,*">
        <dx:DXExpander
            x:Name="TopExpander"
            Grid.Row="0"
            IsExpanded="True"
            >

            <Grid
                Grid.Row="0"
                ColumnDefinitions="auto,*"
                ColumnSpacing="5"
                >

                <dx:DXImage
                    Grid.Column="0"
                    HeightRequest="160"
                    HorizontalOptions="Start"
                    Source="{Binding ImagePath}"
                    VerticalOptions="Start"
                    WidthRequest="200"
                    />

                <dx:DXStackLayout Grid.Column="1" ItemSpacing="10">
                    <dx:Chip Text="{Binding SongsByArtist.Count, StringFormat='{0} Songs'}" />
                    <dx:Chip Text="{Binding AlbumsByArtist.Count, StringFormat='{0} Albums'}" />
                    <dx:DXButton
                        x:Name="LoadLastFMInfo"
                        BackgroundColor="Transparent"
                        Clicked="LoadLastFMInfo_Clicked"
                        Icon="lastfm.png"
                        IconColor="Red"
                        IconHeight="30"
                        IconWidth="30"
                        ShowContent="False"
                        ShowIcon="True"
                        />

                </dx:DXStackLayout>
            </Grid>

        </dx:DXExpander>
        <dx:TabView
            x:Name="ArtistDetailsTableView"
            Grid.Row="1"
            Margin="0,10,0,0"
            BackgroundColor="Transparent"
            >
            <dx:TabViewItem x:Name="SongsByArtistTab" HeaderText="Songs">


                <dx:DXCollectionView Grid.Row="1" ItemsSource="{Binding SongsByArtist}">
                    <dx:DXCollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:SongModelView">
                            <Grid ColumnDefinitions="60,*,auto" RowDefinitions="80">
                                <dx:DXStackLayout Grid.Column="0">
                                    <dx:DXStackLayout.Triggers>
                                        <DataTrigger
                                            Binding="{Binding HasSyncedLyrics}"
                                            TargetType="dx:DXStackLayout"
                                            Value="True"
                                            >
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="BorderColor" Value="DarkSlateBlue" />

                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding HasSyncedLyrics}"
                                            TargetType="dx:DXStackLayout"
                                            Value="False"
                                            >
                                            <Setter Property="BorderThickness" Value="0" />

                                        </DataTrigger>

                                    </dx:DXStackLayout.Triggers>
                                    <dx:DXImage Aspect="AspectFit" Source="{Binding CoverImagePath}">
                                        <dx:DXImage.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="CurrentPlayingCoverTapGesture_Tapped" />
                                        </dx:DXImage.GestureRecognizers>
                                    </dx:DXImage>
                                </dx:DXStackLayout>

                                <dx:DXStackLayout Grid.Column="1" Orientation="Vertical">
                                    <dx:DXStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer
                                            x:Name="MiddleGridSection"
                                            NumberOfTapsRequired="1"
                                            Tapped="MiddleGridSection_Tapped"
                                            />
                                    </dx:DXStackLayout.GestureRecognizers>
                                    <dx:Chip
                                        x:Name="TitleChip"
                                        BorderThickness="0"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Start"
                                        Tap="TitleChip_Tap"
                                        Text="{Binding Title}"
                                        />
                                    <dx:Chip
                                        x:Name="ArtistChip"
                                        BorderThickness="0"
                                        FontSize="13"
                                        HorizontalOptions="Start"
                                        LongPress="ArtistChip_LongPress"
                                        Tap="ArtistChip_Tap"
                                        Text="{Binding ArtistName}"
                                        />
                                </dx:DXStackLayout>

                                <dx:DXStackLayout Grid.Column="2" Orientation="Vertical">
                                    <dx:Chip
                                        x:Name="MoreBtn"
                                        BackgroundColor="Transparent"
                                        BorderThickness="0"
                                        HeightRequest="30"
                                        Icon="more1.png"
                                        IsIconVisible="True"
                                        WidthRequest="30"
                                        />
                                    <Label
                                        Margin="5,0"
                                        FontSize="8"
                                        HorizontalOptions="End"
                                        Text="{Binding DurationFormatted}"
                                        VerticalOptions="Center"
                                        />
                                    <Label
                                        Margin="5,0"
                                        FontSize="8"
                                        HorizontalOptions="End"
                                        Text="{Binding PlayCompletedCount}"
                                        VerticalOptions="Center"
                                        />
                                </dx:DXStackLayout>

                            </Grid>
                        </DataTemplate>
                    </dx:DXCollectionView.ItemTemplate>
                </dx:DXCollectionView>

            </dx:TabViewItem>
            <dx:TabViewItem x:Name="AlbumsByArtist" HeaderText="Albums">
                <dx:DXStackLayout>

                    <dx:DXCollectionView Grid.Row="1" ItemsSource="{Binding AlbumsByArtist}">
                        <dx:DXCollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:AlbumModelView">
                                <Grid ColumnDefinitions="60,*,auto" RowDefinitions="80">
                                    <dx:DXStackLayout Grid.Column="0">

                                        <dx:DXImage Aspect="AspectFit" Source="{Binding ImagePath}" />
                                    </dx:DXStackLayout>

                                    <dx:DXStackLayout Grid.Column="1" Orientation="Vertical">
                                        <dx:DXStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer x:Name="MiddleGridSection" NumberOfTapsRequired="1" />
                                        </dx:DXStackLayout.GestureRecognizers>
                                        <dx:Chip
                                            x:Name="TitleChip"
                                            BorderThickness="0"
                                            FontAttributes="Bold"
                                            HorizontalOptions="Start"
                                            Text="{Binding Name}"
                                            />
                                        <dx:Chip
                                            x:Name="SongsInAlbumCount"
                                            BorderThickness="0"
                                            FontSize="13"
                                            HorizontalOptions="Start"
                                            Text="{Binding SongsInAlbum.Count}"
                                            />
                                    </dx:DXStackLayout>

                                    <dx:DXStackLayout Grid.Column="2" Orientation="Vertical">
                                        <dx:Chip
                                            x:Name="MoreBtn"
                                            BackgroundColor="Transparent"
                                            BorderThickness="0"
                                            HeightRequest="30"
                                            Icon="more1.png"
                                            IsIconVisible="True"
                                            WidthRequest="30"
                                            />
                                        <Label
                                            Margin="5,0"
                                            FontSize="8"
                                            HorizontalOptions="End"
                                            Text="{Binding TotalDuration, StringFormat='{0:mm\\:ss}'}"
                                            VerticalOptions="Center"
                                            />
                                    </dx:DXStackLayout>

                                </Grid>
                            </DataTemplate>
                        </dx:DXCollectionView.ItemTemplate>
                    </dx:DXCollectionView>
                </dx:DXStackLayout>
            </dx:TabViewItem>


            <dx:TabViewItem HeaderText="Play History">
                <dx:DXStackLayout ItemSpacing="10">
                    <dx:Chip
                        x:Name="ExportEvt" IsVisible="False"
                        Tap="ExportEvt_Tap"
                        TapCommandParameter="{Binding ., Source={x:Reference PlayEventDG}}"
                        Text="Export"
                        />
                    <dx:DataGridView
                        x:Name="PlayEventDG"
                        AutoGenerateColumnsMode="None"
                        ItemsSource="{Binding PlayEvents}"
                        >
                        <dx:DataGridView.Columns>


                            <dx:ImageColumn
                                Width="100"
                                Caption="Image"
                                FieldName="CoverImagePath"
                                />
                            <dx:TextColumn
                                Width="150"
                                Caption="Title"
                                FieldName="SongTitle"
                                />
                            <dx:TextColumn
                                Width="150"
                                Caption="Album Name"
                                FieldName="SongAlbumName"
                                />
                            <dx:TextColumn
                                Width="110"
                                Caption="Play Type"
                                FieldName="PlayTypeStr"
                                />
                            <dx:DateColumn
                                Width="110"
                                Caption="Event Date"
                                FieldName="EventDate"
                                />
                            <dx:TextColumn
                                Width="120"
                                HorizontalContentAlignment="Center"
                                Caption="Position"
                                FieldName="PositionInSeconds"
                                />
                        </dx:DataGridView.Columns>
                    </dx:DataGridView>
                </dx:DXStackLayout>
            </dx:TabViewItem>

            <dx:TabViewItem x:Name="ChartsTab" HeaderText="Charts">
                <dx:DXScrollView
                    x:Name="ChartsScrollView"
                    x:DataType="statsVM:ArtistStatsViewModel"
                    Loaded="ChartsScrollView_Loaded"
                    Scrolled="ChartsScrollView_Scrolled"
                    >

                    <dx:DXStackLayout Padding="10">
                        <dx:DXStackLayout
                            HorizontalOptions="Center"
                            ItemSpacing="10"
                            Orientation="Horizontal"
                            >
                            <dx:DXStackLayout
                                Padding="5"
                                BorderColor="DarkGray"
                                BorderThickness="1"
                                CornerRadius="15"
                                >

                                <Label
                                    HorizontalOptions="Center"
                                    Text="{Binding TextBingeRecord.Value}"
                                    VerticalOptions="Center"
                                    />
                                <Label HorizontalOptions="Center" Text="Binge Record" />
                            </dx:DXStackLayout>
                            <dx:DXStackLayout
                                Padding="5"
                                BorderColor="DarkGray"
                                BorderThickness="1"
                                CornerRadius="15"
                                ToolTipProperties.Text="{Binding TextTotalTime.Subtitle}"
                                >

                                <Label HorizontalOptions="Center" Text="{Binding TextTotalTime.Value}" />
                                <Label HorizontalOptions="Center" Text="Total Time Played" />
                            </dx:DXStackLayout>
                            <dx:DXStackLayout
                                Padding="5"
                                BorderColor="DarkGray"
                                BorderThickness="1"
                                CornerRadius="15"
                                ToolTipProperties.Text="{Binding TextOneHitWonderPct.Subtitle}"
                                >

                                <Label HorizontalOptions="Center" Text="{Binding TextOneHitWonderPct.Value}" />
                                <Label HorizontalOptions="Center" Text="Binge Record" />
                            </dx:DXStackLayout>
                        </dx:DXStackLayout>
                      
                        <dx:PieChartView
                            x:Name="ActionsRadarChart"
                            Grid.Row="0"
                            HeightRequest="350"
                            WidthRequest="350"
                            >
                            <dx:PieChartView.Hint>
                                <dx:PieHint Enabled="True" />
                            </dx:PieChartView.Hint>
                            <dx:PieChartView.Series>

                                <dx:PieSeries>
                                    <dx:PieSeries.Label>
                                        <dx:PieSeriesLabel Position="Inside" />
                                    </dx:PieSeries.Label>
                                    <dx:PieSeries.Data>
                                        <dx:PieSeriesDataAdapter
                                            AllowLiveDataUpdates="True"
                                            DataSource="{Binding ListMonthlyTrend}"
                                            LabelDataMember="Period"
                                            ValueDataMember="PlayCount"
                                            />


                                    </dx:PieSeries.Data>
                                </dx:PieSeries>
                            </dx:PieChartView.Series>
                        </dx:PieChartView>




                    </dx:DXStackLayout>

                </dx:DXScrollView>
            </dx:TabViewItem>
        </dx:TabView>


    </Grid>
</ContentPage>