<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dimmer.Views.DimmerCloud.DimmerHomeCenter"
    x:Name="MyPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:globalVM="clr-namespace:Dimmer.ViewModel;assembly=Dimmer"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    Title="Dimmer Live"
    x:DataType="globalVM:SessionManagementViewModel"
    Shell.ForegroundColor="DarkSlateBlue"
    >

    <Grid
        x:Name="MainGrid"
        Padding="5"
        Loaded="MainGrid_Loaded"
        RowDefinitions="auto,*"
        >

        <FlexLayout Grid.Row="0" JustifyContent="SpaceBetween">
            <dx:DXStackLayout Grid.Row="0" ItemSpacing="10">
                <Label FontSize="23" Text="{Binding CurrentUser.Username}" />
                <Label FontSize="13" Text="{Binding CurrentUser.Email}" />


            </dx:DXStackLayout>
            <dx:DXImage
                HeightRequest="180"
                HorizontalOptions="Start"
                Source="{Binding CurrentUser.ProfileImagePath}"
                WidthRequest="180"
                />

        </FlexLayout>

        <dx:TabView Grid.Row="1">
            <dx:TabViewItem HeaderText="Live Section">
                <dx:DXStackLayout>
                    <Label Text="Current Device" />
                </dx:DXStackLayout>
            </dx:TabViewItem>
            <dx:TabViewItem HeaderText="BackUp Section">
                <dx:DXStackLayout>
                    <Label Text="Live Section" />
                </dx:DXStackLayout>
            </dx:TabViewItem>
            <dx:TabViewItem HeaderText="Live Section">
                <dx:DXStackLayout>
                    <Label Text="Live Section" />
                </dx:DXStackLayout>
            </dx:TabViewItem>
        </dx:TabView>

        <dx:BottomSheet
            x:Name="LoginBottomSheet"
            x:DataType="globalVM:LoginViewModel"
            AllowedState="HalfExpanded"
            BackgroundColor="Black"
            HalfExpandedRatio="0.8"
            >
            <dx:BottomSheet.Content>

                <dx:DXStackLayout Padding="20" ItemSpacing="10">
                    <dx:DXStackLayout.Resources>
                        <ResourceDictionary>
                            <Style TargetType="Label">
                                <Setter Property="TextColor" Value="White" />
                            </Style>
                            <Style TargetType="dx:Chip">
                                <Setter Property="TextColor" Value="White" />
                            </Style>
                            <Style TargetType="dx:TextEdit">
                                <Setter Property="PlaceholderColor" Value="White" />
                                <Setter Property="LabelColor" Value="White" />
                                <Setter Property="TextColor" Value="White" />
                            </Style>
                        </ResourceDictionary>
                    </dx:DXStackLayout.Resources>
                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        HorizontalOptions="Center"
                        Text="Login To Dimmer"
                        />
                    <dx:TextEdit
                        LabelText="Enter User Name"
                        PlaceholderText="E.g. John Doe"
                        Text="{Binding Username}"
                        />
                    <dx:PasswordEdit
                        LabelText="Enter Password"
                        PlaceholderText="E.g. ********"
                        Text="{Binding Password}"
                        />

                    <dx:DXStackLayout ItemSpacing="10" Orientation="Horizontal">

                        <dx:DXButton Command="{Binding LoginCommand}" Content="Login" />
                        <dx:DXButton Command="{Binding RegisterCommand}" Content="Register" />
                    </dx:DXStackLayout>

                    <dx:Chip
                        x:Name="CancelLoginChip"
                        Tap="CancelLoginChip_Tap"
                        Text="Cancel Login"
                        />
                </dx:DXStackLayout>
            </dx:BottomSheet.Content>
        </dx:BottomSheet>
    </Grid>
</ContentPage>