<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Dimmer.Views.CustomViews.NowPlayingView"
    x:Name="NowPlayingBtmSheet"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:Dimmer.Utilities.TypeConverters;assembly=Dimmer"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:localBehv="clr-namespace:Dimmer.Utils.Behaviors"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    x:DataType="vm:BaseViewModelAnd"
    Unloaded="myPage_Unloaded"
    >

    <Grid RowDefinitions="*">
        <Grid.Resources>
            <ResourceDictionary>
                <Style TargetType="dx:DXButton">
                    <Setter Property="HeightRequest" Value="50" />
                </Style>
            </ResourceDictionary>
        </Grid.Resources>
        <dx:DXImage
            x:Name="MainBgImg"
            Grid.RowSpan="2"
            Aspect="AspectFill"
            Opacity="0.6"
            Source="{Binding CurrentPlayingSongView.CoverImagePath}"
            />

        <dx:DXBorder
            Grid.RowSpan="2"
            BackgroundColor="Black"
            Opacity="0.5"
            />

        <dx:DXExpander x:Name="SyncLyricsView" IsExpanded="False">

            <Grid RowDefinitions="auto,*">
                <dx:DXStackLayout Grid.Row="0">

                    <dx:DXButton
                        x:Name="NowPlayingHighlightBtn"
                        Padding="5"
                        HorizontalContentAlignment="Fill"
                        BackgroundColor="Transparent"
                        CornerRadius="10"
                        HeightRequest="100"
                        IsVisible="True"
                        PressedBackgroundColor="{Binding CurrentPlaySongDominantColor}"
                        TapPressed="NowPlayingHighlightBtn_TapPressed"
                        >

                        <Grid
                            Padding="0"
                            BackgroundColor="Transparent"
                            ColumnDefinitions="auto, *"
                            >
                            <dx:DXBorder
                                Grid.ColumnSpan="2"
                                BackgroundColor="{Binding CurrentPlaySongDominantColor}"
                                CornerRadius="10"
                                Opacity="0.8"
                                />
                            <dx:DXImage
                                Grid.Column="0"
                                Margin="5,0"
                                Aspect="AspectFit"
                                MaximumHeightRequest="60"
                                MaximumWidthRequest="60"
                                Source="{Binding CurrentPlayingSongView.CoverImagePath}"
                                VerticalOptions="Start"
                                />

                            <dx:DXStackLayout
                                Grid.Column="1"
                                Margin="0,5"
                                BackgroundColor="Transparent"
                                VerticalOptions="Start"
                                >
                                <dx:DXStackLayout.Resources>
                                    <ResourceDictionary>
                                        <Style TargetType="Label">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=White}" />
                                        </Style>
                                    </ResourceDictionary>
                                </dx:DXStackLayout.Resources>
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    Text="{Binding CurrentPlayingSongView.Title}"
                                    />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="5">
                                    <Label
                                        Grid.Column="0"
                                        FontSize="13"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding CurrentPlayingSongView.OtherArtistsName}"
                                        />

                                    <Label
                                        Grid.Column="1"
                                        FontSize="13"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding CurrentPlayingSongView.AlbumName}"
                                        />

                                </Grid>
                            </dx:DXStackLayout>



                        </Grid>
                    </dx:DXButton>
                </dx:DXStackLayout>
                <dx:DXCollectionView
                    x:Name="AllLyricsCV"
                    Grid.Row="1"
                    Margin="5"
                    ItemsSource="{Binding AllLines}"
                    SelectedItem="{Binding CurrentLine}"
                    SelectionChanged="AllLyricsCV_SelectionChanged"
                    SelectionMode="Single"
                    Tap="AllLyricsCV_Tap"
                    >
                    <dx:DXCollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:LyricPhraseModelView">
                            <Label
                                FontSize="19"
                                Text="{Binding Text}"
                                TextColor="White"
                                />
                        </DataTemplate>
                    </dx:DXCollectionView.ItemTemplate>

                    <dx:DXCollectionView.SelectedItemTemplate>
                        <DataTemplate x:DataType="models:LyricPhraseModelView">

                            <dx:DXButton
                                x:Name="CurrentLineBtn"
                                Padding="2"
                                HorizontalContentAlignment="Fill"
                                BackgroundColor="Transparent"
                                CornerRadius="10"
                                IsVisible="True"
                                TapPressed="NowPlayingHighlightBtn_TapPressed"
                                >

                                <Grid BackgroundColor="Transparent" ColumnDefinitions="*">
                                    <dx:DXBorder
                                        Margin="1"
                                        BackgroundColor="Black"
                                        CornerRadius="0"
                                        Opacity="0.6"
                                        />

                                    <Label
                                        Margin="1"
                                        FontSize="28"
                                        Text="{Binding Text}"
                                        TextColor="DarkSlateBlue"
                                        />

                                </Grid>
                            </dx:DXButton>

                        </DataTemplate>
                    </dx:DXCollectionView.SelectedItemTemplate>
                </dx:DXCollectionView>
            </Grid>
        </dx:DXExpander>

        <dx:DXExpander x:Name="NowPlayingViewExpander" VerticalOptions="End">

            <Grid
                Grid.Row="0"
                Margin="10,0,0,60"
                Padding="5,0"
                BackgroundColor="Transparent"
                RowDefinitions="auto,auto"
                RowSpacing="20"
                >
                <dx:DXButton
                    x:Name="CurrentLyricLineBtn"
                    Grid.Row="0"
                    Padding="5"
                    BackgroundColor="Transparent"
                    Clicked="CurrentLyricLine_Clicked"
                    CornerRadius="0"
                    IsVisible="{Binding CurrentPlayingSongView.HasSyncedLyrics}"
                    PressedBackgroundColor="{Binding CurrentPlaySongDominantColor}"
                    >


                    <Label
                        x:Name="CurrentLyricLine"
                        Margin="5"
                        BackgroundColor="Transparent"
                        FontAttributes="Bold"
                        FontSize="28"
                        HeightRequest="400"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"
                        Text="{Binding CurrentLine.Text}"
                        TextColor="White"
                        />

                </dx:DXButton>

                <dx:DXStackLayout Grid.Row="1" ItemSpacing="10">
                    <Label
                        x:Name="SongTitleLabel"
                        FontAttributes="Bold"
                        FontSize="24"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Justify"
                        LineBreakMode="WordWrap"
                        Text="{Binding CurrentPlayingSongView.Title}"
                        TextColor="White"
                        />

                    <dx:Chip
                        x:Name="ArtistChip"
                        Grid.Column="0"
                        BorderThickness="0"
                        >
                        <dx:Chip.ContentTemplate>
                            <DataTemplate>
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding CurrentPlayingSongView.OtherArtistsName}"
                                    TextColor="DarkGray"
                                    />
                            </DataTemplate>
                        </dx:Chip.ContentTemplate>
                    </dx:Chip>


                    <Grid>
                        <dx:DXBorder
                            BackgroundColor="{Binding CurrentPlaySongDominantColor}"
                            CornerRadius="20"
                            Opacity="1"
                            />
                        <dx:DXStackLayout
                            Padding="15"
                            BorderColor="Transparent"
                            BorderThickness="2"
                            CornerRadius="20"
                            ItemSpacing="15"
                            >
                            <FlexLayout JustifyContent="SpaceBetween">
                                <dx:DXStackLayout Orientation="Horizontal">

                                    <dx:Chip
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalOptions="Center"
                                        Icon="shuffle.png"
                                        IconSize="40,40"
                                        IsEnabled="{Binding IsTimestampingInProgress, Converter={converters:BoolToInverseConverter}}"
                                        IsIconVisible="True"
                                        TapCommand="{Binding ToggleShuffleCommand}"
                                        ToolTipProperties.Text="{Binding IsShuffleActive, Converter={converters:BoolToYesNoConverter}, StringFormat='Is Shuffle Active? : {0}'}"
                                        WidthRequest="60"
                                        >

                                        <dx:Chip.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsShuffleActive}"
                                                TargetType="dx:Chip"
                                                Value="True"
                                                >
                                                <Setter Property="BorderColor" Value="DarkSlateBlue" />
                                                <Setter Property="BorderThickness" Value="2" />

                                            </DataTrigger>
                                        </dx:Chip.Triggers>

                                    </dx:Chip>

                                    <dx:Chip
                                        x:Name="LyricsChip"
                                        BorderThickness="0"
                                        IconSize="25,25"
                                        LongPress="LyricsChip_LongPress"
                                        Tap="LyricsChip_Tap"
                                        Text="🎙️"
                                        />


                                </dx:DXStackLayout>

                                <dx:DXButton
                                    x:Name="PlaybackChip"
                                    Padding="5"
                                    BackgroundColor="Transparent"
                                    Icon="playlistminimalistic3.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    TapPressed="PlaybackChip_TapPressed"
                                    />

                            </FlexLayout>

                            <Slider
                                x:Name="TrackProgressSlider"
                                Grid.Column="1"
                                DragCompleted="OnSliderDragCompleted"
                                DragStarted="OnSliderDragStarted"
                                Maximum="{Binding CurrentPlayingSongView.DurationInSeconds}"
                                MaximumTrackColor="{AppThemeBinding Dark=White,
                                                                    Light=Black}"
                                Minimum="0"
                                MinimumTrackColor="DarkSlateBlue"
                                ThumbColor="{Binding CurrentPlaySongDominantColor}"
                                Value="{Binding CurrentTrackPositionSeconds}"
                                />

                            <FlexLayout JustifyContent="SpaceBetween">
                                <dx:Chip
                                    BorderThickness="0"
                                    Text="{Binding CurrentTrackPositionSecondsTxt}"
                                    TextColor="White"
                                    />

                                <dx:Chip
                                    BorderThickness="0"
                                    IconSize="25,25"
                                    Text="{Binding CurrentPlayingSongView.DurationFormatted}"
                                    TextColor="White"
                                    />

                            </FlexLayout>

                            <Grid ColumnDefinitions="*,*,*,*,*">

                                <dx:DXButton
                                    Grid.Column="0"
                                    Padding="10"
                                    Background="Transparent"
                                    BackgroundColor="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding ToggleRepeatModeCommand}"
                                    HorizontalOptions="Center"
                                    Icon="repeat.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True"
                                    ToolTipProperties.Text="{Binding CurrentRepeatMode, StringFormat='Current Repeat Mode : {0}'}"
                                    >
                                    <dx:DXButton.Triggers>
                                        <DataTrigger
                                            Binding="{Binding CurrentRepeatMode}"
                                            TargetType="dx:DXButton"
                                            Value="0"
                                            >
                                            <Setter Property="BorderColor" Value="DarkSlateBlue" />
                                            <Setter Property="BorderThickness" Value="1" />


                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding CurrentRepeatMode}"
                                            TargetType="dx:DXButton"
                                            Value="1"
                                            >
                                            <Setter Property="BorderColor" Value="LightBlue" />
                                            <Setter Property="BorderThickness" Value="2" />

                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding CurrentRepeatMode}"
                                            TargetType="dx:DXButton"
                                            Value="2"
                                            >
                                            <Setter Property="BorderColor" Value="Orange" />
                                            <Setter Property="BorderThickness" Value="2" />

                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding CurrentRepeatMode}"
                                            TargetType="dx:DXButton"
                                            Value="3"
                                            >
                                            <Setter Property="BorderColor" Value="Red" />
                                            <Setter Property="BorderThickness" Value="2" />

                                        </DataTrigger>
                                    </dx:DXButton.Triggers>

                                </dx:DXButton>



                                <dx:DXButton
                                    Grid.Column="1"
                                    Padding="10"
                                    BackgroundColor="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding PreviousTrackCommand}"
                                    HorizontalOptions="Center"
                                    Icon="skipprevious.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True"
                                    >
                                    <dx:DXButton.CommandParameter>
                                        <x:Boolean>False</x:Boolean>
                                    </dx:DXButton.CommandParameter>
                                </dx:DXButton>

                                <dx:DXButton
                                    x:Name="PlayPauseBtn"
                                    Grid.Column="2"
                                    Padding="10"
                                    BackgroundColor="Transparent"
                                    BorderColor="{Binding CurrentPlaySongDominantColor}"
                                    BorderThickness="0"
                                    Command="{Binding PlayPauseToggleCommand}"
                                    HorizontalOptions="Center"
                                    Icon="play.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True"
                                    >



                                    <dx:DXButton.Triggers>
                                        <DataTrigger
                                            Binding="{Binding IsDimmerPlaying}"
                                            TargetType="dx:DXButton"
                                            Value="true"
                                            >
                                            <Setter Property="Icon" Value="pause.png" />
                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding IsDimmerPlaying}"
                                            TargetType="dx:DXButton"
                                            Value="false"
                                            >
                                            <Setter Property="Icon" Value="play.png" />
                                        </DataTrigger>
                                    </dx:DXButton.Triggers>
                                </dx:DXButton>

                                <dx:DXButton
                                    Grid.Column="3"
                                    Padding="10"
                                    BackgroundColor="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding NextTrackCommand}"
                                    HorizontalOptions="Center"
                                    Icon="skipnext.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True"
                                    >
                                    <dx:DXButton.CommandParameter>
                                        <x:Boolean>False</x:Boolean>
                                    </dx:DXButton.CommandParameter>
                                </dx:DXButton>
                                <dx:DXButton
                                    Grid.Column="4"
                                    Padding="10"
                                    BackgroundColor="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding AddFavoriteRatingToSongCommand}"
                                    CommandParameter="{Binding CurrentPlayingSongView}"
                                    HorizontalOptions="Center"
                                    Icon="heart.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True"
                                    >
                                    <dx:DXButton.Triggers>
                                        <DataTrigger
                                            Binding="{Binding CurrentPlayingSongView.IsFavorite}"
                                            TargetType="dx:DXButton"
                                            Value="true"
                                            >
                                            <Setter Property="Icon" Value="heartlock.png" />
                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding CurrentPlayingSongView.IsFavorite}"
                                            TargetType="dx:DXButton"
                                            Value="false"
                                            >
                                            <Setter Property="Icon" Value="heart.png" />
                                        </DataTrigger>
                                    </dx:DXButton.Triggers>
                                </dx:DXButton>
                            </Grid>
                        </dx:DXStackLayout>

                    </Grid>


                </dx:DXStackLayout>
            </Grid>
        </dx:DXExpander>





    </Grid>
</ContentView>