<?xml version="1.0" encoding="utf-8" ?>
<dx:BottomSheet
    x:Class="Dimmer.Views.CustomViews.NowPlayingBottomSheet"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:Dimmer.Utilities.TypeConverters;assembly=Dimmer"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:localBehv="clr-namespace:Dimmer.Utils.Behaviors"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    x:DataType="vm:BaseViewModelAnd"
    AllowedState="FullExpanded"
    ShowGrabber="False">
    <dx:BottomSheet.Resources>
        <ResourceDictionary>
            <Style TargetType="dx:DXButton">
                <Setter Property="HeightRequest" Value="50" />
            </Style>
        </ResourceDictionary>
    </dx:BottomSheet.Resources>

    <Grid RowDefinitions="*,auto">

        <dx:DXImage
            x:Name="MainBgImg"
            Grid.RowSpan="2"
            Aspect="AspectFill"
            Opacity="0.4"
            Source="{Binding CurrentPlayingSongView.CoverImagePath}" />
        <dx:DXExpander
            x:Name="NowPlayingExp"
            IsExpanded="True"
            VerticalOptions="End">

            <Grid
                Margin="10,0,0,80"
                Padding="5,0"
                BackgroundColor="Transparent"
                RowDefinitions="auto,auto"
                VerticalOptions="End">
                <dx:DXStackLayout Grid.Row="0">
                    <dx:Chip
                        x:Name="CurrentLyricLine"
                        FontSize="19"
                        HorizontalOptions="Center"
                        Tap="CurrentLyricLine_Tap"
                        Text="{Binding CurrentLine.Text}">
                        <dx:Chip.Triggers>
                            <DataTrigger
                                Binding="{Binding CurrentPlayingSongView.HasSyncedLyrics}"
                                TargetType="dx:Chip"
                                Value="True">
                                <Setter Property="IsVisible" Value="True" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding CurrentPlayingSongView.HasSyncedLyrics}"
                                TargetType="dx:Chip"
                                Value="False">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </dx:Chip.Triggers>
                    </dx:Chip>
                </dx:DXStackLayout>
                <dx:DXStackLayout Grid.Row="1" ItemSpacing="15">
                    <Label
                        x:Name="SongTitleLabel"
                        FontAttributes="Bold"
                        FontSize="20"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Justify"
                        SizeChanged="SongTitleLabel_SizeChanged"
                        Text="{Binding CurrentPlayingSongView.Title}" />

                    <dx:Chip
                        Grid.Column="0"
                        BorderThickness="0"
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="{Binding CurrentPlayingSongView.OtherArtistsName}" />


                    <Grid>
                        <dx:DXBorder
                            BackgroundColor="{Binding CurrentPlaySongDominantColor}"
                            CornerRadius="20"
                            Opacity="10" />
                        <dx:DXStackLayout
                            Padding="15"
                            BorderColor="Transparent"
                            BorderThickness="2"
                            CornerRadius="20"
                            ItemSpacing="15">
                            <FlexLayout JustifyContent="SpaceBetween">
                                <dx:DXStackLayout Orientation="Horizontal">

                                    <dx:Chip
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalOptions="Center"
                                        Icon="shuffle.png"
                                        IconSize="40,40"
                                        IsEnabled="{Binding IsTimestampingInProgress, Converter={converters:BoolToInverseConverter}}"
                                        IsIconVisible="True"
                                        TapCommand="{Binding ToggleShuffleCommand}"
                                        ToolTipProperties.Text="{Binding IsShuffleActive, Converter={converters:BoolToYesNoConverter}, StringFormat='Is Shuffle Active? : {0}'}"
                                        WidthRequest="60">

                                        <dx:Chip.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsShuffleActive}"
                                                TargetType="dx:Chip"
                                                Value="True">
                                                <Setter Property="BorderColor" Value="{Binding CurrentPlaySongDominantColor}" />
                                                <Setter Property="BorderThickness" Value="2" />

                                            </DataTrigger>
                                        </dx:Chip.Triggers>

                                    </dx:Chip>

                                    <dx:Chip
                                        x:Name="LyricsChip"
                                        BorderThickness="0"
                                        IconSize="25,25"
                                        Tap="LyricsChip_Tap"
                                        Text="🎙️" />


                                </dx:DXStackLayout>

                                <dx:DXButton
                                    x:Name="PlaybackChip"
                                    Padding="5"
                                    BackgroundColor="Transparent"
                                    Icon="playlistminimalistic3.png"
                                    IconHeight="40"
                                    IconWidth="40"
                                    TapPressed="PlaybackChip_TapPressed" />

                            </FlexLayout>

                            <dx:DXSlider
                                BackgroundColor="Transparent"
                                MaxValue="100"
                                MinValue="0"
                                TickmarkStep="4"
                                TooltipDisplayFormat="mm:ss"
                                Value="{Binding CurrentTrackPositionPercentage}">
                                <dx:DXSlider.Behaviors>
                                    <localBehv:SliderDragCompletedBehavior DragPreviewCommand="{Binding DragPreviewCommand}" UserValueChangedCommand="{Binding UserChangedTrackPositionCommand}" />

                                </dx:DXSlider.Behaviors>


                                <dx:DXSlider.TrackAppearance>
                                    <dx:DXSliderTrackAppearance
                                        ActiveBackgroundColor="{Binding CurrentPlaySongDominantColor}"
                                        BackgroundColor="DimGray"
                                        CornerRadius="10"
                                        DisabledActiveBackgroundColor="Red"
                                        DisabledBackgroundColor="Red"
                                        Thickness="10" />


                                </dx:DXSlider.TrackAppearance>

                                <dx:DXSlider.ThumbAppearance>
                                    <dx:DXSliderThumbAppearance
                                        Width="10"
                                        Height="25"
                                        BackgroundColor="{Binding CurrentPlaySongDominantColor}"
                                        BorderColor="DarkSlateBlue"
                                        BorderThickness="1"
                                        PressedHeight="20"
                                        PressedWidth="20" />
                                </dx:DXSlider.ThumbAppearance>

                                <dx:DXSlider.TooltipAppearance>
                                    <dx:DXSliderTooltipAppearance
                                        MinWidth="25"
                                        MinHeight="25"
                                        Padding="20"
                                        BackgroundColor="{Binding CurrentPlaySongDominantColor}"
                                        CornerRadius="15"
                                        FontAttributes="Italic"
                                        FontSize="18"
                                        Indent="15"
                                        TextColor="White" />

                                </dx:DXSlider.TooltipAppearance>

                            </dx:DXSlider>

                            <FlexLayout JustifyContent="SpaceBetween">
                                <dx:Chip BorderThickness="0" Text="{Binding CurrentTrackPositionSecondsTxt}" />

                                <dx:Chip
                                    BorderThickness="0"
                                    IconSize="25,25"
                                    Text="{Binding CurrentPlayingSongView.DurationFormatted}" />

                            </FlexLayout>

                            <Grid ColumnDefinitions="*,*,*,*,*">

                                <dx:DXButton
                                    Grid.Column="0"
                                    Padding="10"
                                    Background="Transparent"
                                    BackgroundColor="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding ToggleRepeatModeCommand}"
                                    HorizontalOptions="Center"
                                    Icon="repeat.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True"
                                    ToolTipProperties.Text="{Binding CurrentRepeatMode, StringFormat='Current Repeat Mode : {0}'}">
                                    <dx:DXButton.Triggers>
                                        <DataTrigger
                                            Binding="{Binding CurrentRepeatMode}"
                                            TargetType="dx:DXButton"
                                            Value="0">
                                            <Setter Property="BorderColor" Value="{Binding CurrentPlaySongDominantColor}" />
                                            <Setter Property="BorderThickness" Value="1" />


                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding CurrentRepeatMode}"
                                            TargetType="dx:DXButton"
                                            Value="1">
                                            <Setter Property="BorderColor" Value="LightBlue" />
                                            <Setter Property="BorderThickness" Value="2" />

                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding CurrentRepeatMode}"
                                            TargetType="dx:DXButton"
                                            Value="2">
                                            <Setter Property="BorderColor" Value="Orange" />
                                            <Setter Property="BorderThickness" Value="2" />

                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding CurrentRepeatMode}"
                                            TargetType="dx:DXButton"
                                            Value="3">
                                            <Setter Property="BorderColor" Value="Red" />
                                            <Setter Property="BorderThickness" Value="2" />

                                        </DataTrigger>
                                    </dx:DXButton.Triggers>

                                </dx:DXButton>



                                <dx:DXButton
                                    Grid.Column="1"
                                    Padding="10"
                                    BackgroundColor="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding PreviousTrackCommand}"
                                    HorizontalOptions="Center"
                                    Icon="skipprevious.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True">
                                    <dx:DXButton.CommandParameter>
                                        <x:Boolean>False</x:Boolean>
                                    </dx:DXButton.CommandParameter>
                                </dx:DXButton>

                                <dx:DXButton
                                    x:Name="PlayPauseBtn"
                                    Grid.Column="2"
                                    Padding="10"
                                    BackgroundColor="Transparent"
                                    BorderColor="{Binding CurrentPlaySongDominantColor}"
                                    BorderThickness="0"
                                    Command="{Binding PlayPauseToggleCommand}"
                                    HorizontalOptions="Center"
                                    Icon="play.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True">



                                    <dx:DXButton.Triggers>
                                        <DataTrigger
                                            Binding="{Binding IsDimmerPlaying}"
                                            TargetType="dx:DXButton"
                                            Value="true">
                                            <Setter Property="Icon" Value="pause.png" />
                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding IsDimmerPlaying}"
                                            TargetType="dx:DXButton"
                                            Value="false">
                                            <Setter Property="Icon" Value="play.png" />
                                        </DataTrigger>
                                    </dx:DXButton.Triggers>
                                </dx:DXButton>

                                <dx:DXButton
                                    Grid.Column="3"
                                    Padding="10"
                                    BackgroundColor="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding NextTrackCommand}"
                                    HorizontalOptions="Center"
                                    Icon="skipnext.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True">
                                    <dx:DXButton.CommandParameter>
                                        <x:Boolean>False</x:Boolean>
                                    </dx:DXButton.CommandParameter>
                                </dx:DXButton>
                                <dx:DXButton
                                    Grid.Column="4"
                                    Padding="10"
                                    BackgroundColor="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding AddFavoriteRatingToSongCommand}"
                                    CommandParameter="{Binding CurrentPlayingSongView}"
                                    HorizontalOptions="Center"
                                    Icon="heart.png"
                                    IconColor="DarkSlateBlue"
                                    IconHeight="40"
                                    IconWidth="40"
                                    ShowIcon="True">
                                    <dx:DXButton.Triggers>
                                        <DataTrigger
                                            Binding="{Binding CurrentPlayingSongView.IsFavorite}"
                                            TargetType="dx:DXButton"
                                            Value="true">
                                            <Setter Property="Icon" Value="heartlock.png" />
                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding CurrentPlayingSongView.IsFavorite}"
                                            TargetType="dx:DXButton"
                                            Value="false">
                                            <Setter Property="Icon" Value="heart.png" />
                                        </DataTrigger>
                                    </dx:DXButton.Triggers>
                                </dx:DXButton>
                            </Grid>
                        </dx:DXStackLayout>

                    </Grid>


                </dx:DXStackLayout>
            </Grid>

        </dx:DXExpander>

        <dx:DXExpander
            x:Name="PlayBackQueueExp"
            Grid.Row="1"
            IsExpanded="False">
            <Grid>

                <dx:DXStackLayout Margin="10,0" ItemSpacing="15">
                    <FlexLayout JustifyContent="SpaceBetween">
                        <dx:DXStackLayout>
                            <Label
                                FontAttributes="Bold"
                                FontSize="38"
                                Text="Queue" />
                            <Label FontSize="22" Text="{Binding PlaybackQueue.Count, StringFormat='Total {0} songs'}" />
                        </dx:DXStackLayout>

                        <dx:DXStackLayout
                            IsVisible="False"
                            ItemSpacing="5"
                            Orientation="Horizontal">
                            <dx:DXButton Icon="savea.png" />
                            <dx:DXButton Icon="minus_l.png" />
                        </dx:DXStackLayout>
                    </FlexLayout>


                    <dx:DXButton
                        x:Name="NowPlayingHighlightBtn"
                        Padding="5"
                        HorizontalContentAlignment="Fill"
                        BackgroundColor="Transparent"
                        CornerRadius="10"
                        HeightRequest="100"
                        IsVisible="{Binding IsDimmerPlaying}"
                        PressedBackgroundColor="{Binding CurrentPlaySongDominantColor}"
                        TapPressed="NowPlayingHighlightBtn_TapPressed">

                        <Grid
                            Padding="0"
                            BackgroundColor="Transparent"
                            ColumnDefinitions="auto, *,auto"
                            RowDefinitions="90">
                            <dx:DXBorder
                                Grid.ColumnSpan="3"
                                Padding="15"
                                BackgroundColor="{Binding CurrentPlaySongDominantColor}"
                                CornerRadius="10"
                                Opacity="0.8" />
                            <dx:DXImage
                                Grid.Column="0"
                                Margin="5,0"
                                Aspect="AspectFill"
                                HeightRequest="70"
                                Source="{Binding CurrentPlayingSongView.CoverImagePath}"
                                WidthRequest="70" />

                            <dx:DXStackLayout
                                Grid.Column="1"
                                Margin="0,5"
                                Padding="2">
                                <Label
                                    FontAttributes="Italic"
                                    FontSize="12"
                                    Text="Now Playing" />
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="19"
                                    Text="{Binding CurrentPlayingSongView.Title}" />
                                <dx:DXStackLayout ItemSpacing="5" Orientation="Horizontal">
                                    <Label FontSize="18" Text="{Binding CurrentPlayingSongView.ArtistName}" />
                                    <Label Text="|" />
                                    <Label FontSize="11" Text="{Binding CurrentPlayingSongView.AlbumName}" />

                                </dx:DXStackLayout>
                            </dx:DXStackLayout>

                            <dx:DXStackLayout Grid.Column="2" Orientation="Vertical">
                                <dx:DXImage
                                    BackgroundColor="Transparent"
                                    HeightRequest="30"
                                    Source="musical_notes.png"
                                    WidthRequest="30" />
                                <Label
                                    BackgroundColor="Transparent"
                                    HeightRequest="30"
                                    IsVisible="{Binding CurrentPlayingSongView.HasSyncedLyrics}"
                                    Text="🎙️"
                                    WidthRequest="30" />
                                <dx:DXImage
                                    BackgroundColor="Transparent"
                                    HeightRequest="30"
                                    IsVisible="{Binding CurrentPlayingSongView.IsFavorite}"
                                    Source="heartlock.png"
                                    WidthRequest="30" />

                            </dx:DXStackLayout>

                        </Grid>
                    </dx:DXButton>
                    <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="5">
                        <Label
                            Grid.Column="0"
                            FontSize="20"
                            Text="UP NEXT" />
                        <BoxView
                            Grid.Column="1"
                            BackgroundColor="DarkGray"
                            HeightRequest="1"
                            VerticalOptions="Center" />
                        <dx:Chip
                            Grid.Column="2"
                            BackgroundColor="{Binding CurrentPlaySongDominantColor}"
                            BorderThickness="0"
                            Text="{Binding PlaybackQueue.Count}" />
                    </Grid>
                    <dx:DXCollectionView
                        x:Name="PlaybackQueueCV"
                        ItemSpacing="8"
                        ItemsSource="{Binding PlaybackQueue}"
                        MaximumHeightRequest="450"
                        Scrolled="PlaybackQueueCV_Scrolled">
                        <dx:DXCollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SongModelView">
                                <dx:DXBorder
                                    Padding="10"
                                    BorderColor="Gray"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <Grid ColumnDefinitions="80,*,auto" ColumnSpacing="5">
                                        <dx:DXImage Grid.Column="0" Source="{Binding CoverImagePath}" />
                                        <dx:DXStackLayout
                                            Grid.Column="1"
                                            Padding="5"
                                            ItemSpacing="10"
                                            VerticalOptions="Center">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="16"
                                                Text="{Binding Title}">
                                                <Label.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding IsCurrentPlayingHighlight}"
                                                        TargetType="Label"
                                                        Value="true">
                                                        <Setter Property="TextColor" Value="DarkSlateBlue" />

                                                    </DataTrigger>
                                                </Label.Triggers>

                                            </Label>

                                            <Label FontSize="14" Text="{Binding ArtistName}" />
                                        </dx:DXStackLayout>

                                        <dx:DXStackLayout Grid.Column="2" Orientation="Horizontal">
                                            <dx:DXButton
                                                x:Name="PlaySongInQueue"
                                                Padding="5"
                                                BackgroundColor="Transparent"
                                                Icon="playcircle.png"
                                                IconColor="White"
                                                IconHeight="25"
                                                IconWidth="25"
                                                Tap="PlaySongInQueue_Tap" />

                                            <dx:DXButton
                                                x:Name="AddSongToFav"
                                                Padding="5"
                                                BackgroundColor="Transparent"
                                                CommandParameter="{Binding .}"
                                                Icon="heart.png"
                                                IconColor="White"
                                                IconHeight="25"
                                                IconWidth="25"
                                                Tap="AddSongToFav_Tap">
                                                <dx:DXButton.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding IsFavorite}"
                                                        TargetType="dx:DXButton"
                                                        Value="true">
                                                        <Setter Property="Icon" Value="heartlock.png" />
                                                        <Setter Property="IconColor" Value="{Binding CurrentPlaySongDominantColor}" />
                                                    </DataTrigger>
                                                </dx:DXButton.Triggers>
                                            </dx:DXButton>
                                            <dx:DXButton
                                                x:Name="RemoveSongFromQueueBtn"
                                                Padding="5"
                                                BackgroundColor="DarkRed"
                                                HeightRequest="35"
                                                Icon="minus_l.png"
                                                IconColor="White"
                                                IconHeight="25"
                                                IconWidth="25"
                                                TapPressed="RemoveSongFromQueueBtn_TapPressed" />

                                        </dx:DXStackLayout>
                                    </Grid>

                                </dx:DXBorder>
                            </DataTemplate>
                        </dx:DXCollectionView.ItemTemplate>
                    </dx:DXCollectionView>
                </dx:DXStackLayout>
                <dx:DXStackLayout
                    Margin="60"
                    HorizontalOptions="Center"
                    VerticalOptions="End">
                    <dx:DXButton
                        x:Name="ScrollToInPlayBackQueue"
                        Padding="15"
                        BackgroundColor="DarkSlateBlue"
                        Icon="eye.png"
                        IconColor="White"
                        IconHeight="35"
                        IconWidth="35"
                        ShowContent="False"
                        Tap="ScrollToInPlayBackQueue_Tap" />
                </dx:DXStackLayout>
            </Grid>
        </dx:DXExpander>

        <dx:DXExpander x:Name="SingleSongLyricsView" IsExpanded="False">
            <dx:DXStackLayout>
                <Grid ColumnDefinitions="80,*">
                    <dx:DXImage
                        Grid.Column="0"
                        Aspect="AspectFill"
                        HeightRequest="70"
                        Opacity="0.5"
                        Source="{Binding CurrentPlayingSongView.CoverImagePath}"
                        WidthRequest="70" />

                    <dx:DXStackLayout
                        Grid.Column="1"
                        Padding="5"
                        ItemSpacing="10"
                        VerticalOptions="Center">
                        <Label FontSize="16" Text="{Binding CurrentPlayingSongView.Title}" />
                        <Label FontSize="13" Text="{Binding CurrentPlayingSongView.ArtistName}" />
                        <Label FontSize="10" Text="{Binding CurrentPlayingSongView.AlbumName}" />
                    </dx:DXStackLayout>
                </Grid>

                <dx:DXCollectionView
                    x:Name="AllLyricsColView"
                    Grid.Row="1"
                    ItemsSource="{Binding AllLines}"
                    SelectedItem="{Binding CurrentLine}"
                    SelectionChanged="AllLyricsColView_SelectionChanged"
                    SelectionMode="Single">
                    <dx:DXCollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:LyricPhraseModelView">
                            <Grid>
                                <Border
                                    BackgroundColor="{AppThemeBinding Dark=#1e1e1e}"
                                    IsVisible="{Binding IsHighlighted}"
                                    Opacity="0.7"
                                    Stroke="DarkSlateBlue" />

                                <Label
                                    FontSize="{Binding NowPlayingLyricsFontSize}"
                                    HorizontalTextAlignment="Center"
                                    Text="{Binding Text}"
                                    TextColor="{Binding HighlightColor}" />
                            </Grid>
                        </DataTemplate>
                    </dx:DXCollectionView.ItemTemplate>
                </dx:DXCollectionView>

            </dx:DXStackLayout>
        </dx:DXExpander>
    </Grid>
</dx:BottomSheet>
