<?xml version="1.0" encoding="utf-8" ?>
<dx:DXPopup
    x:Class="Dimmer.Views.CustomViews.SingleSongInCVPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:TQlVM="clr-namespace:Dimmer.ViewModel.TQL;assembly=Dimmer"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    x:Name="SongInCVPopup"
    x:DataType="models:SongModelView"
    Opening="SongInCVPopup_Opening">
    <dx:DXStackLayout>
        <dx:SlideView x:Name="PopupSlideView" HeightRequest="500"
                      CurrentItemChanged="PopupSlideView_CurrentItemChanged">
            <dx:SlideView.Items>
                <Label Text="Yvan" />
                <Label Text="Brunel" />
                <Label Text="YBTopaz8" />
            </dx:SlideView.Items>

        </dx:SlideView>
        <FlexLayout JustifyContent="SpaceBetween">
            <dx:Chip
                x:Name="PrevChip"
                Tap="NavChip_Tapped"
                Text="Prev" />
            <dx:Chip x:Name="NextChip" Text="Next" />
        </FlexLayout>
    </dx:DXStackLayout>
</dx:DXPopup>
