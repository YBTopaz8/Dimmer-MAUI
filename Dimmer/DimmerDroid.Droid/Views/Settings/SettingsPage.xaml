<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dimmer.Views.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    Title="Settings"
    x:DataType="vm:BaseViewModelAnd"
    Shell.NavBarIsVisible="False"
    >
    <dx:DXScrollView Margin="5,50,5,0">
        <dx:DXStackLayout ItemSpacing="5">
            <dx:DXStackLayout.Resources>
                <ResourceDictionary>
                    <Style TargetType="dx:DXStackLayout">
                        <Setter Property="CornerRadius" Value="10" />
                        <Setter Property="ItemSpacing" Value="5" />
                        <Setter Property="Padding" Value="5" />
                    </Style>
                </ResourceDictionary>
            </dx:DXStackLayout.Resources>

            <dx:DXStackLayout>
                <ProgressBar Progress="{Binding LatestAppLog.ProgressValue}" />
                <Label Text="{Binding LatestAppLog.Message}" />
                <dx:DXStackLayout HorizontalOptions="Center" Orientation="Horizontal">
                    <Label Text="{Binding AppTitle}" />
                    <Label Text="{Binding CurrentAppStage}" />

                </dx:DXStackLayout>


            </dx:DXStackLayout>

            <dx:DXStackLayout>
                <dx:DXStackLayout.Triggers>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="true"
                        >
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderColor" Value="DarkSlateBlue" />

                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="false"
                        >
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="BorderColor" Value="Transparent" />

                    </DataTrigger>
                </dx:DXStackLayout.Triggers>
                <dx:Chip
                    x:Name="LastFMHeaderChip"
                    Icon="arrowdown.png"
                    IsIconVisible="True"
                    TapCommand="{Binding Commands.ToggleExpandState, Source={x:Reference LastFmExpander}}"
                    Text="Last FM"
                    />
                <dx:DXExpander x:Name="LastFmExpander" IsExpanded="False">
                    <dx:DXExpander.Content>
                        <dx:DXStackLayout ItemSpacing="10">
                            <Label Text="Username" />
                            <dx:TextEdit
                                x:Name="LastFMUname"
                                PlaceholderColor="Gray"
                                PlaceholderText="Ex. YBTopaz8.."
                                ReturnType="Go"
                                />




                            <dx:DXButton
                                x:Name="ConnectToLastFM"
                                BackgroundColor="Red"
                                Clicked="ConnectToLastFM_Clicked"
                                Icon="lastfm.png"
                                IconColor="White"
                                ShowContent="False"
                                />

                        </dx:DXStackLayout>
                    </dx:DXExpander.Content>
                </dx:DXExpander>
            </dx:DXStackLayout>

            <dx:DXStackLayout>

                <dx:DXStackLayout.Triggers>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="true"
                        >
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderColor" Value="DarkSlateBlue" />

                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="false"
                        >
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="BorderColor" Value="Transparent" />

                    </DataTrigger>
                </dx:DXStackLayout.Triggers>
                <dx:Chip
                    x:Name="FoldersSectionChip"
                    Icon="arrowdown.png"
                    IconSize="25,25"
                    IsIconVisible="True"
                    TapCommand="{Binding Commands.ToggleExpandState, Source={x:Reference FoldersSectionExpander}}"
                    Text="Folders Section"
                    />

                <dx:DXExpander x:Name="FoldersSectionExpander" IsExpanded="False">
                    <dx:DXExpander.Content>
                        <Grid RowDefinitions="auto,*">
                            <dx:DXStackLayout Grid.Row="0">

                                <dx:DXButton
                                    x:Name="OpenFolderScannerBtn"
                                    Clicked="OpenFolderScannerBtn_Clicked"
                                    Content="Add Folder to Library"
                                    />

                            </dx:DXStackLayout>
                            <dx:DXCollectionView
                                Grid.Row="1"
                                Header="Folders"
                                HeightRequest="300"
                                ItemsSource="{Binding FolderPaths}"
                                >
                                <dx:DXCollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid ColumnDefinitions="*,auto" RowSpacing="5">
                                            <Label Text="{Binding .}" />

                                            <dx:DXStackLayout
                                                Grid.Column="1"
                                                HorizontalOptions="End"
                                                Orientation="Horizontal"
                                                >
                                                <dx:Chip
                                                    x:Name="RescanFolderChip"
                                                    Tap="RescanFolderChip_Tap"
                                                    Text="Rescan"
                                                    />
                                                <dx:Chip Tap="RemoveFolderBtn_Clicked" Text="Remove" />
                                            </dx:DXStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </dx:DXCollectionView.ItemTemplate>
                            </dx:DXCollectionView>

                        </Grid>
                    </dx:DXExpander.Content>
                </dx:DXExpander>
            </dx:DXStackLayout>

            <dx:DXStackLayout>
                <dx:DXStackLayout.Triggers>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="true"
                        >
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderColor" Value="DarkSlateBlue" />

                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="false"
                        >
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="BorderColor" Value="Transparent" />

                    </DataTrigger>
                </dx:DXStackLayout.Triggers>
                <dx:Chip
                    Icon="arrowdown.png"
                    IconSize="20,20"
                    IsIconVisible="True"
                    TapCommand="{Binding Commands.ToggleExpandState, Source={x:Reference FetchLyricsDataExpander}}"
                    Text="Lyrics Section"
                    />
                <dx:DXExpander x:Name="FetchLyricsDataExpander" IsExpanded="False">
                    <dx:DXExpander.Content>
                        <dx:DXStackLayout>


                            <dx:DXButton
                                x:Name="FetchLyricsDataBtn"
                                Clicked="FetchLyricsData_Click"
                                Content="Fetch Lyrics Online"
                                />
                            <ProgressBar Progress="{Binding LatestAppLog.ProgressValue}" />
                        </dx:DXStackLayout>
                    </dx:DXExpander.Content>
                </dx:DXExpander>
            </dx:DXStackLayout>

            <dx:DXStackLayout>
                <dx:DXStackLayout.Triggers>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="true"
                        >
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderColor" Value="DarkSlateBlue" />

                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="false"
                        >
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="BorderColor" Value="Transparent" />

                    </DataTrigger>
                </dx:DXStackLayout.Triggers>
                <dx:Chip
                    Icon="arrowdown.png"
                    IconSize="20,20"
                    IsIconVisible="True"
                    TapCommand="{Binding Commands.ToggleExpandState, Source={x:Reference BackupRestoreExpander}}"
                    Text="Backup/Restore"
                    >
                    <dx:Chip.Triggers>
                        <DataTrigger
                            Binding="{Binding IsExpanded, Source={x:Reference BackupRestoreExpander}}"
                            TargetType="dx:Chip"
                            Value="True"
                            >
                            <Setter Property="Icon" Value="roundaltarrowup.png" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsExpanded, Source={x:Reference BackupRestoreExpander}}"
                            TargetType="dx:Chip"
                            Value="False"
                            >
                            <Setter Property="Icon" Value="arrowdown.png" />
                        </DataTrigger>
                    </dx:Chip.Triggers>
                </dx:Chip>
                <dx:DXExpander x:Name="BackupRestoreExpander" IsExpanded="False">
                    <dx:DXExpander.Content>
                        <dx:TabView x:Name="BackUpAndRestoreTabView" HeightRequest="300">
                            <dx:TabViewItem x:Name="BackUpTab" HeaderText="Back Up">
                                <dx:DXScrollView>
                                    <dx:DXStackLayout>
                                        <dx:DXButton
                                            x:Name="BackupDeviceBtn"
                                            Clicked="BackupDeviceBtn_Clicked"
                                            Content="Backup Device"
                                            />

                                        <dx:DXStackLayout x:Name="BackedUpStackLayout">
                                            <dx:DXStackLayout.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding BackUpCompletResult.IsBackUpComplete}"
                                                    TargetType="dx:DXStackLayout"
                                                    Value="True"
                                                    >
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding BackUpCompletResult.IsBackUpComplete}"
                                                    TargetType="dx:DXStackLayout"
                                                    Value="False"
                                                    >
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </dx:DXStackLayout.Triggers>

                                            <Label Text="{Binding BackUpCompletResult.AppVersion}" />
                                            <Label Text="{Binding BackUpCompletResult.BackupDate}" />
                                            <Label Text="{Binding BackUpCompletResult.FavoriteBackedUp}" />
                                            <Label Text="{Binding BackUpCompletResult.PlayEventsBackedUp}" />
                                        </dx:DXStackLayout>
                                    </dx:DXStackLayout>
                                </dx:DXScrollView>
                            </dx:TabViewItem>
                            <dx:TabViewItem x:Name="RestoreTab" HeaderText="Restore">

                                <dx:DXStackLayout ItemSpacing="5">


                                    <dx:DXButton
                                        x:Name="RestoreBackupDeviceBtn"
                                        Clicked="RestoreBackupDeviceBtn_Clicked"
                                        Content="Restore Backup Device"
                                        />

                                    <ActivityIndicator
                                        x:Name="FilePickedAndRestoreInProgressActIndic"
                                        IsRunning="False"
                                        IsVisible="False"
                                        />

                                    <dx:DXButton
                                        x:Name="ConfirmRestoreBtn"
                                        Clicked="ConfirmRestoreBtn_Clicked"
                                        Content="Confirm Restore"
                                        Loaded="ConfirmRestoreBtn_Loaded"
                                        />
                                    <Label Text="{Binding PickedUpBackup.Version, StringFormat='BackUp Version {0}'}" />
                                    <Label Text="{Binding PickedUpBackup.PlayEvents.Count, StringFormat='Events Count {0}'}" />
                                    <Label Text="{Binding PickedUpBackup.FavoriteSongs.Count, StringFormat='Favorite Songs Count {0}'}" />

                                    <!--<dx:DXStackLayout x:Name="RestoredResultStackLayout">
                                        <Label Text="{Binding MyRestoredResult.EventsRestored, StringFormat='Events Restored {0}'}" />
                                        <Label Text="{Binding MyRestoredResult.FavoritesRestored, StringFormat='Favorite Restored {0}'}" />

                                    </dx:DXStackLayout>-->


                                </dx:DXStackLayout>
                            </dx:TabViewItem>
                        </dx:TabView>

                    </dx:DXExpander.Content>
                </dx:DXExpander>

            </dx:DXStackLayout>
            <dx:DXStackLayout>
                <dx:DXStackLayout.Triggers>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="true"
                        >
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderColor" Value="DarkSlateBlue" />

                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding IsExpanded, Source={x:Reference LastFmExpander}}"
                        TargetType="dx:DXStackLayout"
                        Value="false"
                        >
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="BorderColor" Value="Transparent" />

                    </DataTrigger>
                </dx:DXStackLayout.Triggers>
                <dx:Chip
                    Icon="arrowdown.png"
                    IconSize="20,20"
                    IsIconVisible="True"
                    TapCommand="{Binding Commands.ToggleExpandState, Source={x:Reference AppUtilsExp}}"
                    Text="App Utilities"
                    />
                <dx:DXExpander x:Name="AppUtilsExp" IsExpanded="False">
                    <dx:DXExpander.Content>
                        <dx:DXStackLayout ItemSpacing="10">
                            <dx:DXButton
                                x:Name="ReloadSongsCoverImage"
                                Command="{Binding EnsureAllCoverArtCachedForSongsCommand}"
                                Content="Reload Songs Cover Image"
                                />





                        </dx:DXStackLayout>
                    </dx:DXExpander.Content>
                </dx:DXExpander>

            </dx:DXStackLayout>

        </dx:DXStackLayout>
    </dx:DXScrollView>
</ContentPage>