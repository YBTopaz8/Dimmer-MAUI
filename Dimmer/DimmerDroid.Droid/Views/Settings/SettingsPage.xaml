<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dimmer.Views.Settings.SettingsPage"
              Shell.NavBarIsVisible="False"
 xmlns:vm="clr-namespace:Dimmer.ViewModels"
 xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
 xmlns:dx="http://schemas.devexpress.com/maui"
 xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
 x:DataType="vm:BaseViewModelAnd"
             >
    <dx:DXScrollView Margin="5,50,5,0">
        <dx:DXStackLayout ItemSpacing="5">

            <dx:DXStackLayout ItemSpacing="5">
                <ProgressBar Progress="{Binding LatestAppLog.ProgressValue}"
                         />
                <Label Text="{Binding LatestAppLog.Message}"
                         />
                <dx:DXStackLayout Orientation="Horizontal" HorizontalOptions="Center">
                    <Label Text="{Binding AppTitle}"
                         />
                    <Label Text="{Binding CurrentAppVersion}"
                         />
                    <Label Text="{Binding CurrentAppStage}"
                         />

                </dx:DXStackLayout>

                <dx:DXButton ShowContent="False"
                                Clicked="GoBackBtn_Clicked"
                             HorizontalContentAlignment="Start"
                             HorizontalOptions="Start"
                             Icon="backa.png"/>
                <dx:DXStackLayout  Padding="10" CornerRadius="10">
                    <dx:DXStackLayout.Triggers>
                        <DataTrigger 
         Binding="{Binding IsExpanded,Source={x:Reference LastFmExpander}}"
         TargetType="dx:DXStackLayout" Value="true">
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderColor" Value="DarkSlateBlue"/>

                        </DataTrigger>
                    </dx:DXStackLayout.Triggers>
                <dx:Chip Text="Last FM"  Icon="arrowdown.png" IsIconVisible="True" 
                     Tap="LastFMHeaderChip_Tap" x:Name="LastFMHeaderChip"/>
                <dx:DXExpander x:Name="LastFmExpander" IsExpanded="False"
                               >
                    <dx:DXExpander.Content>
                        <dx:DXStackLayout ItemSpacing="10">
                            <Label Text="Username" />
                            <dx:TextEdit 
                                x:Name="LastFMUname"
                                ReturnType="Go"
                                
                                PlaceholderText="Ex. YBTopaz8.."
                                         PlaceholderColor="Gray"/>
                            
                            
                            
                            
                            <dx:DXButton ShowContent="False"
                                         x:Name="ConnectToLastFM" Clicked="ConnectToLastFM_Clicked"
                                         
                                         Icon="lastfm.png" IconColor="White" BackgroundColor="Red"/>

                        </dx:DXStackLayout>
                    </dx:DXExpander.Content>
                </dx:DXExpander>
                </dx:DXStackLayout>

            </dx:DXStackLayout>
            <dx:DXStackLayout ItemSpacing="10" Padding="10" CornerRadius="10">
                <dx:DXStackLayout.Triggers>
                    <DataTrigger 
                        Binding="{Binding IsExpanded,Source={x:Reference FoldersSectionExpander}}"
                        TargetType="dx:DXStackLayout" Value="true">
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderColor" Value="DarkSlateBlue"/>

                    </DataTrigger>
                </dx:DXStackLayout.Triggers>
                <dx:Chip 
                    Icon="roundaltarrowdown.png"
                    IconSize="25,25"
                    x:Name="FoldersSectionChip" Tap="FoldersSectionChip_Tap"
                    Text="Folders Section" />
                <dx:DXButton Content="Add Folder to Library"
               Clicked="OpenFolderScannerBtn_Clicked" x:Name="OpenFolderScannerBtn"/>

                <dx:DXExpander x:Name="FoldersSectionExpander"
                               
                               IsExpanded="False">
                    <dx:DXExpander.Content>
                    <dx:DXCollectionView ItemsSource="{Binding FolderPaths}" Header="Folders" HeightRequest="300">
                <dx:DXCollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid ColumnDefinitions="*,auto" RowSpacing="5">
                            <Label Text="{Binding .}" />
                            
                            <dx:DXStackLayout Orientation="Horizontal" HorizontalOptions="End" Grid.Column="1">
                                            <dx:Chip Text="Rescan" x:Name="RescanFolderChip"
                                                     Tap="RescanFolderChip_Tap"/>
                                            <dx:Chip Text="Remove" Tap="RemoveFolderBtn_Clicked"/>
                            </dx:DXStackLayout>
                        </Grid>
                    </DataTemplate>
                </dx:DXCollectionView.ItemTemplate>
            </dx:DXCollectionView>
                    </dx:DXExpander.Content>
                </dx:DXExpander>
            </dx:DXStackLayout>
            
            <dx:DXButton Content="Fetch Lyrics Online"
                          Clicked="FetchLyricsData_Click" x:Name="FetchLyricsDataBtn"/>
            
           
            <dx:DXStackLayout ItemSpacing="10">
                <dx:Chip Text="Backup/Restore" Icon="arrowdown.png" IconSize="20,20"
       TapCommand="{Binding Commands.ToggleExpandState,Source={x:Reference BackupRestoreExpander}}"  />
                <dx:DXExpander x:Name="BackupRestoreExpander" IsExpanded="False">
                    <dx:DXExpander.Content>
                        <dx:DXStackLayout ItemSpacing="10">
                            <dx:DXButton Content="Backup Device"
                         x:Name="BackupDeviceBtn"
                         Clicked="BackupDeviceBtn_Clicked">
                            </dx:DXButton>


                            <dx:DXButton Content="Restore Backup Device"
                         x:Name="RestoreBackupDeviceBtn"
                         Clicked="RestoreBackupDeviceBtn_Clicked">
                            </dx:DXButton>


                            <dx:DXButton Content="Confirm Restore"
                         x:Name="ConfirmRestoreBtn"
                         Clicked="ConfirmRestoreBtn_Clicked">
                            </dx:DXButton>

                            <dx:DataGridView ItemsSource="{Binding PickedUpBackup.PlayEvents}"
                                AutoGenerateColumnsMode="None"     HeightRequest="450"    >
                                <dx:DataGridView.Columns>
                                    <dx:ImageColumn FieldName="CoverImagePath" Width="50"
                                                />
                                    <dx:TextColumn FieldName="PlayTypeStr" />
                                    <dx:TextColumn FieldName="ArtistName"/>
                                    <dx:TextColumn FieldName="AlbumName"/>
                                    <dx:CheckBoxColumn IsReadOnly="True"
                                                   FieldName="WasPlayCompleted"/>
                                    <dx:TextColumn FieldName="AlbumName"/>
                                    <dx:DateColumn FieldName="EventDate"/>
                                </dx:DataGridView.Columns>
                            </dx:DataGridView>
                        </dx:DXStackLayout>
                    </dx:DXExpander.Content>
                </dx:DXExpander>
               
            </dx:DXStackLayout>

        </dx:DXStackLayout>
    </dx:DXScrollView>
</ContentPage>