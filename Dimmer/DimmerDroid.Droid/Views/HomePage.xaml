<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dimmer.Views.HomePage"
             Title="HomePage"
             Shell.NavBarIsVisible="False" xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:Dimmer.ViewModels"
             xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
             xmlns:dx="http://schemas.devexpress.com/maui"
             xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
             x:DataType="vm:BaseViewModelAnd">

    <Grid RowDefinitions="auto,*,auto"  RowSpacing="5"
              >
        <Border Grid.RowSpan="3" Opacity="0.01" BackgroundColor="{Binding CurrentPlaySongDominantColor}"/>
        <dx:DXStackLayout CornerRadius="10" Orientation="Vertical" Margin="5,0"  Grid.Row="0" ItemSpacing="5" Opacity="1" BackgroundColor="#1e1e1e">
            <dx:DXButton Content="Settings" HorizontalOptions="End"
                          Clicked="SettingsBtn_Clicked" x:Name="SettingsBtn"/>
            <FlexLayout JustifyContent="SpaceBetween">
                <dx:Chip Icon="hamburgermenu.png" x:Name="MenuBtn" IsIconVisible="True" BackgroundColor="Transparent" IconColor="DarkSlateBlue"
                         IconSize="35,35"
                     BorderThickness="0" Tap="MenuBtn_Tap"/>
                <dx:Chip x:Name="ViewPlaybackQueueBtn" Icon="eye.png" HorizontalOptions="End"
                         BackgroundColor="Transparent" IconColor="DarkSlateBlue"
                         IconSize="35,35"
                     IsIconVisible="True" BorderThickness="0"   
                     Tap="ViewPlaybackQueueBtn_Clicked"/>
            </FlexLayout>
            <Grid BackgroundColor="Transparent" ColumnDefinitions="*,auto">
                

                <dx:TextEdit x:Name="SearchBarTextEdit"  CornerRadius="8,8,10,10" PlaceholderText="Search with TQL..."
                         TextChanged="SearchBar_TextChanged" PlaceholderColor="Gray"
                             Loaded="SearchBar_Loaded" HorizontalOptions="Fill" 
                             Unloaded="SearchBar_Unloaded"
                             >
                   
                    
                </dx:TextEdit>

                <dx:DXButton Icon="filter.png" Grid.Column="1" IconHeight="30" ShowIcon="True"
                             Loaded="DXButton_Loaded"
                             BackgroundColor="Transparent" Padding="5" IconWidth="30"/>
            </Grid>


        

        </dx:DXStackLayout>
        <dx:DXCollectionView x:Name="SongsCV"  ItemsSource="{Binding SearchResults}" Grid.Row="1" Margin="5,0" BackgroundColor="Transparent"
                             PullToRefresh="SongsCV_PullToRefresh" ItemSpacing="5">
                <dx:DXCollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SongModelView">
                        <Grid ColumnDefinitions="60,*,auto" RowDefinitions="75" >
                        
                            <dx:DXImage Source="{Binding CoverImagePath}" Aspect="AspectFit" HeightRequest="80" Grid.Column="0">
                                <dx:DXImage.GestureRecognizers>
                                    <TapGestureRecognizer  Tapped="CurrentPlayingCoverTapGesture_Tapped"/>
                                </dx:DXImage.GestureRecognizers>
                            </dx:DXImage>
                        

                            <dx:DXStackLayout Grid.Column="1" Orientation="Vertical" >
                                <dx:DXStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer NumberOfTapsRequired="1"
                                                         x:Name="MiddleGridSection"
                                                          Tapped="MiddleGridSection_Tapped"
                                                         />
                                </dx:DXStackLayout.GestureRecognizers>

                            <dx:Chip Text="{Binding Title}" BorderThickness="0" HorizontalOptions="Start" 
                                         Tap="TitleChip_Tap" FontSize="17"
                                         FontAttributes="Bold"
                                         x:Name="TitleChip">
                                <dx:Chip.Triggers>
                                    <DataTrigger TargetType="dx:Chip" Binding="{Binding IsCurrentPlayingHighlight}"
                                                 Value="True">
                                        <Setter Property="TextColor" Value="DarkSlateBlue"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="dx:Chip" Binding="{Binding IsCurrentPlayingHighlight}"
                                                 Value="False">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                </dx:Chip.Triggers>
                            </dx:Chip>
                            <dx:Chip Text="{Binding OtherArtistsName}" BorderThickness="0" 
                                         x:Name="ArtistChip" Tap="ArtistChip_Tap"
                                         HorizontalOptions="Start"
                                     DoubleTap="ArtistChip_DoubleTap"
                                         FontSize="13" FontAttributes="Italic"
                                         LongPress="ArtistChip_LongPress">
                                <dx:Chip.Triggers>
                                    <DataTrigger TargetType="dx:Chip" Binding="{Binding HasSyncedLyrics}">
                                        <Setter Property="BorderThickness" Value="1"/>
                                        
                                    </DataTrigger>
                                </dx:Chip.Triggers>
                            </dx:Chip>
                            </dx:DXStackLayout>

                        <dx:DXButton Icon="more1.png" ShowIcon="True" PressedBackgroundColor="{Binding CurrentPlaySongDominantColor}"
         Tap="MoreBtn_Tap" Grid.Column="2" IconPlacement="Top" Padding="2"
         x:Name="MoreBtn" BorderThickness="0" BackgroundColor="Transparent"
         >
                          
                                    
                        <dx:DXStackLayout  Orientation="Vertical">
                                
                            <Label Text="{Binding DurationFormatted}" HorizontalOptions="End" VerticalOptions="Center" FontSize="8" Margin="5,0"/>

                            <dx:DXStackLayout Orientation="Horizontal" HorizontalOptions="Center">
                                <Label Text="🎙️" IsVisible="{Binding HasSyncedLyrics}"/>
                                <Label HorizontalOptions="Center" Text="{Binding PlayCompletedCount}" VerticalOptions="Center" FontSize="8" Margin="5,0"/>

                                </dx:DXStackLayout>
                                <Label Text="❤️" FontSize="10" IsVisible="{Binding IsFavorite}" HorizontalOptions="Center"/>
                            </dx:DXStackLayout>

</dx:DXButton>
                    </Grid>
                    </DataTemplate>
                </dx:DXCollectionView.ItemTemplate>
        </dx:DXCollectionView>


        <dx:DXStackLayout  x:Name="NPBottomBar" Margin="5,0" CornerRadius="15" Grid.Row="2" BorderThickness="2" VerticalOptions="End"
                          ZIndex="1">
            <dx:DXStackLayout.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="NPBottomBar_PanUpdated"/>
            </dx:DXStackLayout.GestureRecognizers>
           
            <Grid ColumnDefinitions="0.4*,*,auto" >

                
                    <dx:DXImage Grid.Column="0"  BackgroundColor="Transparent" HeightRequest="70" WidthRequest="70"
                                Source="{Binding CurrentPlayingSongView.CoverImagePath}" Aspect="AspectFill" >
                        <dx:DXImage.GestureRecognizers>
                            <TapGestureRecognizer x:Name="CurrentPlayingCoverTapGesture" Tapped="CurrentPlayingCoverTapGesture_Tapped"/>
                        </dx:DXImage.GestureRecognizers>
                    </dx:DXImage>
               
                
                <dx:DXStackLayout Grid.Column="1" Orientation="Vertical" VerticalOptions="Center"   Margin="5,0,0,0" x:Name="MiddleGridSL">
                    <dx:DXStackLayout.GestureRecognizers>
                        <TapGestureRecognizer x:Name="NPMiddleGridSection" NumberOfTapsRequired="1" Tapped="NPMiddleGridSection_Tapped"/>
                        <SwipeGestureRecognizer Direction="Up" Swiped="SwipeGestureRecognizer_Swiped"/>
                        <PanGestureRecognizer x:Name="SwipeGestureRecog"
                                          PanUpdated="NPBottomBar_PanUpdated"/>
                        
                    </dx:DXStackLayout.GestureRecognizers>
                    <dx:DXButton   Padding="5,0" CornerRadius="5" BackgroundColor="Transparent"
                        HorizontalContentAlignment="Start"     PressedBackgroundColor="{Binding CurrentPlaySongDominantColor}"
                                  IconColorizationEnabled="True" IconColor="{Binding CurrentPlaySongDominantColor}" Icon="heartlock.png"
                                  ShowIcon="{Binding CurrentPlayingSongView.IsFavorite}" ShowContent="True" IconPlacement="Left"
                                  Tap="CurrentPlayingTitleChip_Tap"   >
                        <dx:DXButton.Behaviors>
                            <toolkit:TouchBehavior LongPressDuration="250"
                                                   LongPressCompleted="TouchBehavior_LongPressCompleted"/>
                        </dx:DXButton.Behaviors>
                        
                                
                        <Label Text="{Binding CurrentPlayingSongView.Title}" HorizontalOptions="Start" BackgroundColor="Transparent" Padding="2"
                             FontAttributes="Bold"  FontSize="16"
                             x:Name="CurrentPlayingTitleChip"/>

                        
                    </dx:DXButton>

                    <dx:Chip Text="{Binding CurrentPlayingSongView.OtherArtistsName}" BorderThickness="0" 
                             x:Name="CurrentPlayingArtistChip" HorizontalOptions="Start" Padding="2"
                             FontSize="13" LongPress="CurrentPlayingArtistChip_LongPress"/>


                    <dx:DXSlider Value="{Binding CurrentTrackPositionPercentage}"
                             MaxValue="100" MinValue="0" VerticalOptions="End" IsVisible="{Binding IsDimmerPlaying}"
                        Grid.Row="1" 
                             Grid.RowSpan="3">
                        <dx:DXSlider.TrackAppearance>
                            <dx:DXSliderTrackAppearance Thickness="8" BackgroundColor="Transparent"
                                                        ActiveBackgroundColor="{Binding CurrentPlaySongDominantColor}">
                                
                            </dx:DXSliderTrackAppearance>
                        </dx:DXSlider.TrackAppearance>
                        <dx:DXSlider.ThumbAppearance 
                        >

                            <dx:DXSliderThumbAppearance
                        BackgroundColor="{Binding CurrentPlaySongDominantColor}"
BorderColor="DarkSlateBlue"
BorderThickness="0"
Height="2" 
Width="0"
PressedHeight="20"
PressedWidth="20">

                            </dx:DXSliderThumbAppearance>
                        </dx:DXSlider.ThumbAppearance>
                    </dx:DXSlider>
                </dx:DXStackLayout>
                
                <dx:DXStackLayout Grid.Column="2" ItemSpacing="5" Orientation="Horizontal" HorizontalOptions="End" VerticalOptions="Center">

                    <dx:DXButton Icon="skipprevious.png" ShowIcon="True" 
                                IconHeight="40" IconWidth="40" Padding="5" 
                                x:Name="PreviousBtn" BorderThickness="0" BackgroundColor="Transparent"
                                 Command="{Binding PreviousTrackCommand}">
                        <dx:DXButton.CommandParameter>
                            <x:Boolean>False</x:Boolean>
                        </dx:DXButton.CommandParameter>
                    </dx:DXButton>

                    <dx:DXButton BorderThickness="0"
     ShowIcon="True"
                                IconHeight="40" IconWidth="40" Padding="0"   IconColor="DarkSlateBlue"
x:Name="PlayPauseBtn"
BorderColor="{Binding CurrentPlaySongDominantColor}"
   
BackgroundColor="Transparent"

Command="{Binding PlayPauseToggleCommand}"
Icon="play.png">



                        <dx:DXButton.Triggers>
                            <DataTrigger
        Binding="{Binding IsDimmerPlaying}"
        TargetType="dx:DXButton"
        Value="true">
                                <Setter Property="Icon" Value="pause.png" />
                            </DataTrigger>

                            <DataTrigger
        Binding="{Binding IsDimmerPlaying}"
        TargetType="dx:DXButton"
        Value="false">
                                <Setter Property="Icon" Value="play.png" />
                            </DataTrigger>
                        </dx:DXButton.Triggers>
                    </dx:DXButton>

                    
                    
                    
                    <dx:DXButton Icon="skipnext.png" ShowIcon="True" x:Name="NextBtn" BorderThickness="0" BackgroundColor="Transparent"
                                Command="{Binding NextTrackCommand}"
                                IconHeight="40" IconWidth="40" Padding="0" >
                        <dx:DXButton.CommandParameter>
                            <x:Boolean>False</x:Boolean>
                        </dx:DXButton.CommandParameter>
                    </dx:DXButton>
                </dx:DXStackLayout>

            </Grid>
        </dx:DXStackLayout>

        <local:NowPlayingBottomSheet x:Name="NPBtmSheet" 
            StateChanged="NPBtmSheet_StateChanged"/>
       

        <dx:BottomSheet x:Name="ArtistsChoiceBtmSheet" AllowDismiss="True" >
            <dx:BottomSheet.Content>
                <dx:DXStackLayout Margin="10,0">
                    

                    <dx:DXCollectionView ItemsSource="{Binding SelectedSong.ArtistToSong}" >
                        <dx:DXCollectionView.HeaderTemplate>
                            <DataTemplate x:DataType="vm:BaseViewModelAnd">

                                <HorizontalStackLayout HorizontalOptions="Center">

                                    <Label Text="Artists" FontSize="20" HorizontalOptions="Center"/>
                                    <Label Text="{Binding SelectedSong.ArtistToSong.Count, StringFormat='({0})'}" FontSize="20" HorizontalOptions="Center"/>
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </dx:DXCollectionView.HeaderTemplate>
                    <dx:DXCollectionView.ItemTemplate>
                        <DataTemplate x:DataType ="models:ArtistModelView">
                            
                                    
                            <Grid  ColumnDefinitions="*,*" ColumnSpacing="10"
                                   RowDefinitions="auto,auto">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="ArtistGrid_Tapped"/>
                                    </Grid.GestureRecognizers>
                                <dx:DXStackLayout Grid.Row="0" Grid.Column="0">
                                    <Label Text="{Binding Name}" FontSize="20" />
                                </dx:DXStackLayout>

                                <dx:DXStackLayout Grid.Column="1" Grid.Row="0" HorizontalOptions="End">
                                    <Label Text="{Binding TotalSongsByArtist, StringFormat='{0} Songs'}" FontSize="20" />
                                        <dx:DXStackLayout Orientation="Horizontal" HorizontalOptions="Center">
                                            <dx:Chip Icon="searchalta.png" IconSize="30,30"
                                                     IconColor="DarkSlateBlue" LongPressCommandParameter="{Binding Name}"
                                                     Tap="SearchArtistBtnTQL_Tap" x:Name="SearchArtistBtnTQL"
                                                     IsIconVisible="True" BorderThickness="0"/>
                                            <dx:Chip Icon="eye.png" IconSize="30,30"
                                                     x:Name="ViewArtistBtn" Tap="ViewArtistBtn_Tap"
                                                     IconColor="DarkSlateBlue" LongPressCommandParameter="{Binding .}"
                                                     IsIconVisible="True" BorderThickness="0"/>
                                        </dx:DXStackLayout>
                                </dx:DXStackLayout>
                                
                    
                            </Grid>
                            
                        </DataTemplate>
                    </dx:DXCollectionView.ItemTemplate>
                </dx:DXCollectionView>
                </dx:DXStackLayout>
            </dx:BottomSheet.Content>
        </dx:BottomSheet>
        

        <dx:BottomSheet x:Name="SingleSongBtmSheet" AllowDismiss="True" >
            <dx:BottomSheet.Content>
                <dx:DXStackLayout Margin="10,0">
                    <Label x:Name="SongTitle" HorizontalOptions="Center"
       Loaded="SongTitle_Loaded" />
                    <dx:DXButton Content="Play Next"
                                 Clicked="PlayNextBtn_Clicked" x:Name="PlayNextBtn"
                                 />
                    <dx:DXButton 
                        
                   x:Name="ToggleFavBtn" Icon="heart.png"
                                       BackgroundColor="Transparent"
                                       IconHeight="40"
                                       IconWidth="40"
                   Tap="ToggleFavBtn_Tap"/>

                    <dx:Chip Icon="deletesonginterfacesymbol.png" 
         x:Name="DeleteSongBtn" Text="Delete Song" IsIconVisible="True"
 Tap="DeleteSongBtn_Tap"/>
                    
                </dx:DXStackLayout>
            </dx:BottomSheet.Content>
        </dx:BottomSheet>
        
        
    </Grid>
</ContentPage>