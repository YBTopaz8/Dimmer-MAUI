<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dimmer.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:local="clr-namespace:Dimmer.Views.CustomViews"
    xmlns:models="clr-namespace:Dimmer.Data.ModelView;assembly=Dimmer"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Dimmer.ViewModels"
    Title="HomePage"
    x:DataType="vm:BaseViewModelAnd"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="auto,*,auto" RowSpacing="5">
        <Border
            Grid.RowSpan="3"
            BackgroundColor="{Binding CurrentPlaySongDominantColor}"
            Opacity="0.01" />
        <dx:DXStackLayout
            Grid.Row="0"
            Margin="5,0"
            BackgroundColor="#1e1e1e"
            CornerRadius="10"
            ItemSpacing="5"
            Opacity="1"
            Orientation="Vertical">

            <FlexLayout JustifyContent="SpaceBetween">
                <dx:Chip
                    x:Name="MenuBtn"
                    BackgroundColor="Transparent"
                    BorderThickness="0"
                    Icon="hamburgermenu.png"
                    IconColor="DarkSlateBlue"
                    IconSize="35,35"
                    IsIconVisible="True"
                    Tap="MenuBtn_Tap" />
                <dx:Chip
                    x:Name="ViewPlaybackQueueBtn"
                    BackgroundColor="Transparent"
                    BorderThickness="0"
                    HorizontalOptions="End"
                    Icon="eye.png"
                    IconColor="DarkSlateBlue"
                    IconSize="35,35"
                    IsIconVisible="True"
                    Tap="ViewPlaybackQueueBtn_Clicked" />
            </FlexLayout>
            <Grid BackgroundColor="Transparent" ColumnDefinitions="*,auto">


                <dx:TextEdit
                    x:Name="SearchBarTextEdit"
                    CornerRadius="8,8,10,10"
                    HorizontalOptions="Fill"
                    Loaded="SearchBar_Loaded"
                    PlaceholderColor="Gray"
                    PlaceholderText="Search with TQL..."
                    TextChanged="SearchBar_TextChanged"
                    Unloaded="SearchBar_Unloaded" />


            </Grid>




        </dx:DXStackLayout>
        <dx:DXCollectionView
            x:Name="SongsCV"
            Grid.Row="1"
            Margin="5,0"
            BackgroundColor="Transparent"
            ItemSpacing="5"
            ItemsSource="{Binding SearchResults}"
            PropertyChanged="SongsCV_PropertyChanged"
            PullToRefresh="SongsCV_PullToRefresh">
            <dx:DXCollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SongModelView">
                    <Grid ColumnDefinitions="60,*,auto" RowDefinitions="75">

                        <dx:DXImage
                            Grid.Column="0"
                            Aspect="AspectFit"
                            HeightRequest="80"
                            Source="{Binding CoverImagePath}">
                            <dx:DXImage.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped" />
                            </dx:DXImage.GestureRecognizers>
                        </dx:DXImage>


                        <dx:DXStackLayout Grid.Column="1" Orientation="Vertical">
                            <dx:DXStackLayout.GestureRecognizers>
                                <TapGestureRecognizer
                                    x:Name="MiddleGridSection"
                                    NumberOfTapsRequired="1"
                                    Tapped="MiddleGridSection_Tapped" />
                            </dx:DXStackLayout.GestureRecognizers>

                            <dx:Chip
                                x:Name="TitleChip"
                                BorderThickness="0"
                                FontAttributes="Bold"
                                FontSize="17"
                                HorizontalOptions="Start"
                                Tap="TitleChip_Tap"
                                Text="{Binding Title}">
                                <dx:Chip.Triggers>
                                    <DataTrigger
                                        Binding="{Binding IsCurrentPlayingHighlight}"
                                        TargetType="dx:Chip"
                                        Value="True">
                                        <Setter Property="TextColor" Value="DarkSlateBlue" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding IsCurrentPlayingHighlight}"
                                        TargetType="dx:Chip"
                                        Value="False">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </dx:Chip.Triggers>
                            </dx:Chip>
                            <dx:Chip
                                x:Name="ArtistChip"
                                BorderThickness="0"
                                DoubleTap="ArtistChip_DoubleTap"
                                FontAttributes="Italic"
                                FontSize="13"
                                HorizontalOptions="Start"
                                LongPress="ArtistChip_LongPress"
                                Tap="ArtistChip_Tap"
                                Text="{Binding OtherArtistsName}">
                                <dx:Chip.Triggers>
                                    <DataTrigger Binding="{Binding HasSyncedLyrics}" TargetType="dx:Chip">
                                        <Setter Property="BorderThickness" Value="1" />

                                    </DataTrigger>
                                </dx:Chip.Triggers>
                            </dx:Chip>
                        </dx:DXStackLayout>

                        <dx:DXButton
                            x:Name="MoreBtn"
                            Grid.Column="2"
                            Padding="2"
                            BackgroundColor="Transparent"
                            BorderThickness="0"
                            Icon="more1.png"
                            IconPlacement="Top"
                            PressedBackgroundColor="{Binding CurrentPlaySongDominantColor}"
                            ShowIcon="True"
                            Tap="MoreBtn_Tap">


                            <dx:DXStackLayout Orientation="Vertical">

                                <Label
                                    Margin="5,0"
                                    FontSize="8"
                                    HorizontalOptions="End"
                                    Text="{Binding DurationFormatted}"
                                    VerticalOptions="Center" />

                                <dx:DXStackLayout HorizontalOptions="Center" Orientation="Horizontal">
                                    <Label IsVisible="{Binding HasSyncedLyrics}" Text="🎙️" />
                                    <Label
                                        Margin="5,0"
                                        FontSize="8"
                                        HorizontalOptions="Center"
                                        Text="{Binding PlayCompletedCount}"
                                        VerticalOptions="Center" />

                                </dx:DXStackLayout>
                                <Label
                                    FontSize="10"
                                    HorizontalOptions="Center"
                                    IsVisible="{Binding IsFavorite}"
                                    Text="❤️" />
                            </dx:DXStackLayout>

                        </dx:DXButton>
                    </Grid>
                </DataTemplate>
            </dx:DXCollectionView.ItemTemplate>
        </dx:DXCollectionView>
        <dx:DXStackLayout
            Grid.Row="1"
            Margin="10,0"
            HorizontalOptions="End"
            VerticalOptions="End">
            <dx:DXButton
                Padding="5"
                BackgroundColor="#1e1e1e"
                Command="{Binding Commands.Show, Source={Reference FilteringBtmSheet}}"
                Icon="searchd.png"
                IconHeight="50"
                IconWidth="50"
                ShowContent="False"
                ShowIcon="True" />

        </dx:DXStackLayout>


        <dx:DXStackLayout
            x:Name="NPBottomBar"
            Grid.Row="2"
            Margin="5,0"
            BorderThickness="2"
            CornerRadius="15"
            VerticalOptions="End"
            ZIndex="1">
            <dx:DXStackLayout.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="NPBottomBar_PanUpdated" />
            </dx:DXStackLayout.GestureRecognizers>

            <Grid ColumnDefinitions="0.4*,*,auto">


                <dx:DXImage
                    x:Name="BtmBarCoverImageView"
                    Grid.Column="0"
                    Aspect="AspectFill"
                    BackgroundColor="Transparent"
                    HeightRequest="70"
                    Loaded="BtmBarCoverImageView_Loaded"
                    Source="{Binding CurrentPlayingSongView.CoverImagePath}"
                    WidthRequest="70" />


                <dx:DXStackLayout
                    x:Name="MiddleGridSL"
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Orientation="Vertical"
                    VerticalOptions="Center">
                    <dx:DXStackLayout.GestureRecognizers>
                        <TapGestureRecognizer
                            x:Name="NPMiddleGridSection"
                            NumberOfTapsRequired="1"
                            Tapped="NPMiddleGridSection_Tapped" />
                        <SwipeGestureRecognizer Direction="Up" Swiped="SwipeGestureRecognizer_Swiped" />
                        <PanGestureRecognizer x:Name="SwipeGestureRecog" PanUpdated="NPBottomBar_PanUpdated" />

                    </dx:DXStackLayout.GestureRecognizers>
                    <dx:DXButton
                        Padding="5,0"
                        HorizontalContentAlignment="Start"
                        BackgroundColor="Transparent"
                        CornerRadius="5"
                        Icon="heartlock.png"
                        IconColor="{Binding CurrentPlaySongDominantColor}"
                        IconColorizationEnabled="True"
                        IconPlacement="Left"
                        PressedBackgroundColor="{Binding CurrentPlaySongDominantColor}"
                        ShowContent="True"
                        ShowIcon="{Binding CurrentPlayingSongView.IsFavorite}"
                        Tap="CurrentPlayingTitleChip_Tap">



                        <Label
                            x:Name="CurrentPlayingTitleChip"
                            Padding="2"
                            BackgroundColor="Transparent"
                            FontAttributes="Bold"
                            FontSize="16"
                            HorizontalOptions="Start"
                            Text="{Binding CurrentPlayingSongView.Title}" />


                    </dx:DXButton>

                    <dx:Chip
                        x:Name="CurrentPlayingArtistChip"
                        Padding="2"
                        BorderThickness="0"
                        FontSize="13"
                        HorizontalOptions="Start"
                        LongPress="CurrentPlayingArtistChip_LongPress"
                        Text="{Binding CurrentPlayingSongView.OtherArtistsName}" />


                    <dx:DXSlider
                        Grid.Row="1"
                        Grid.RowSpan="3"
                        IsVisible="{Binding IsDimmerPlaying}"
                        MaxValue="100"
                        MinValue="0"
                        VerticalOptions="End"
                        Value="{Binding CurrentTrackPositionPercentage}">
                        <dx:DXSlider.TrackAppearance>
                            <dx:DXSliderTrackAppearance
                                ActiveBackgroundColor="{Binding CurrentPlaySongDominantColor}"
                                BackgroundColor="Transparent"
                                Thickness="8" />
                        </dx:DXSlider.TrackAppearance>
                        <dx:DXSlider.ThumbAppearance>

                            <dx:DXSliderThumbAppearance
                                Width="0"
                                Height="2"
                                BackgroundColor="{Binding CurrentPlaySongDominantColor}"
                                BorderColor="DarkSlateBlue"
                                BorderThickness="0"
                                PressedHeight="20"
                                PressedWidth="20" />
                        </dx:DXSlider.ThumbAppearance>
                    </dx:DXSlider>
                </dx:DXStackLayout>

                <dx:DXStackLayout
                    Grid.Column="2"
                    HorizontalOptions="End"
                    ItemSpacing="5"
                    Orientation="Horizontal"
                    VerticalOptions="Center">

                    <dx:DXButton
                        x:Name="PreviousBtn"
                        Padding="5"
                        BackgroundColor="Transparent"
                        BorderThickness="0"
                        Command="{Binding PreviousTrackCommand}"
                        Icon="skipprevious.png"
                        IconHeight="40"
                        IconWidth="40"
                        ShowIcon="True">
                        <dx:DXButton.CommandParameter>
                            <x:Boolean>False</x:Boolean>
                        </dx:DXButton.CommandParameter>
                    </dx:DXButton>

                    <dx:DXButton
                        x:Name="PlayPauseBtn"
                        Padding="0"
                        BackgroundColor="Transparent"
                        BorderColor="{Binding CurrentPlaySongDominantColor}"
                        BorderThickness="0"
                        Command="{Binding PlayPauseToggleCommand}"
                        Icon="play.png"
                        IconColor="DarkSlateBlue"
                        IconHeight="40"
                        IconWidth="40"
                        ShowIcon="True">



                        <dx:DXButton.Triggers>
                            <DataTrigger
                                Binding="{Binding IsDimmerPlaying}"
                                TargetType="dx:DXButton"
                                Value="true">
                                <Setter Property="Icon" Value="pause.png" />
                            </DataTrigger>

                            <DataTrigger
                                Binding="{Binding IsDimmerPlaying}"
                                TargetType="dx:DXButton"
                                Value="false">
                                <Setter Property="Icon" Value="play.png" />
                            </DataTrigger>
                        </dx:DXButton.Triggers>
                    </dx:DXButton>




                    <dx:DXButton
                        x:Name="NextBtn"
                        Padding="0"
                        BackgroundColor="Transparent"
                        BorderThickness="0"
                        Command="{Binding NextTrackCommand}"
                        Icon="skipnext.png"
                        IconHeight="40"
                        IconWidth="40"
                        ShowIcon="True">
                        <dx:DXButton.CommandParameter>
                            <x:Boolean>False</x:Boolean>
                        </dx:DXButton.CommandParameter>
                    </dx:DXButton>
                </dx:DXStackLayout>

            </Grid>
        </dx:DXStackLayout>

        <local:NowPlayingBottomSheet x:Name="NPBtmSheet" StateChanged="NPBtmSheet_StateChanged" />


        <dx:BottomSheet x:Name="ArtistsChoiceBtmSheet" AllowDismiss="True">
            <dx:BottomSheet.Content>
                <dx:DXStackLayout Margin="10,0">


                    <dx:DXCollectionView ItemsSource="{Binding SelectedSong.ArtistToSong}">
                        <dx:DXCollectionView.HeaderTemplate>
                            <DataTemplate x:DataType="vm:BaseViewModelAnd">

                                <HorizontalStackLayout HorizontalOptions="Center">

                                    <Label
                                        FontSize="20"
                                        HorizontalOptions="Center"
                                        Text="Artists" />
                                    <Label
                                        FontSize="20"
                                        HorizontalOptions="Center"
                                        Text="{Binding SelectedSong.ArtistToSong.Count, StringFormat='({0})'}" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </dx:DXCollectionView.HeaderTemplate>
                        <dx:DXCollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ArtistModelView">


                                <Grid
                                    ColumnDefinitions="*,*"
                                    ColumnSpacing="10"
                                    RowDefinitions="auto,auto">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="ArtistGrid_Tapped" />
                                    </Grid.GestureRecognizers>
                                    <dx:DXStackLayout Grid.Row="0" Grid.Column="0">
                                        <Label FontSize="20" Text="{Binding Name}" />
                                    </dx:DXStackLayout>

                                    <dx:DXStackLayout
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        HorizontalOptions="End">
                                        <Label FontSize="20" Text="{Binding TotalSongsByArtist, StringFormat='{0} Songs'}" />
                                        <dx:DXStackLayout HorizontalOptions="Center" Orientation="Horizontal">
                                            <dx:Chip
                                                x:Name="SearchArtistBtnTQL"
                                                BorderThickness="0"
                                                Icon="searchalta.png"
                                                IconColor="DarkSlateBlue"
                                                IconSize="30,30"
                                                IsIconVisible="True"
                                                LongPressCommandParameter="{Binding Name}"
                                                Tap="SearchArtistBtnTQL_Tap" />
                                            <dx:Chip
                                                x:Name="ViewArtistBtn"
                                                BorderThickness="0"
                                                Icon="eye.png"
                                                IconColor="DarkSlateBlue"
                                                IconSize="30,30"
                                                IsIconVisible="True"
                                                LongPressCommandParameter="{Binding .}"
                                                Tap="ViewArtistBtn_Tap" />
                                        </dx:DXStackLayout>
                                    </dx:DXStackLayout>


                                </Grid>

                            </DataTemplate>
                        </dx:DXCollectionView.ItemTemplate>
                    </dx:DXCollectionView>
                </dx:DXStackLayout>
            </dx:BottomSheet.Content>
        </dx:BottomSheet>


        <dx:BottomSheet x:Name="SingleSongBtmSheet" AllowDismiss="True">
            <dx:BottomSheet.Content>
                <dx:DXStackLayout Margin="10,0">
                    <dx:DXStackLayout Orientation="Horizontal">
                        <dx:Chip Text="{Binding SelectedSong.PlayCompletedCount, StringFormat='Played {0} Times'}" />

                    </dx:DXStackLayout>
                    <Label
                        x:Name="SongTitle"
                        HorizontalOptions="Center"
                        Loaded="SongTitle_Loaded" />
                    <dx:Chip
                        x:Name="SelectedSongBtmSheetArtistNameChip"
                        Tap="SelectedSongBtmSheetArtistNameChip_Tap"
                        Text="{Binding SelectedSong.ArtistName}" />

                    <dx:Chip
                        x:Name="SelectedSongBtmSheetAlbumNameChip"
                        Tap="SelectedSongBtmSheetAlbumNameChip_Tap"
                        Text="{Binding SelectedSong.AlbumName}" />

                    <dx:DXButton
                        x:Name="PlayNextBtn"
                        Clicked="PlayNextBtn_Clicked"
                        Content="Play Next" />
                    <dx:DXButton
                        x:Name="ToggleFavBtn"
                        BackgroundColor="Transparent"
                        Icon="heart.png"
                        IconHeight="40"
                        IconWidth="40"
                        Tap="ToggleFavBtn_Tap">
                        <dx:DXButton.Triggers>
                            <DataTrigger
                                Binding="{Binding SelectedSong.IsFavorite}"
                                TargetType="dx:DXButton"
                                Value="True">
                                <Setter Property="Icon" Value="heartlock.png" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding SelectedSong.IsFavorite}"
                                TargetType="dx:DXButton"
                                Value="False">
                                <Setter Property="Icon" Value="heart.png" />
                            </DataTrigger>
                        </dx:DXButton.Triggers>
                    </dx:DXButton>

                    <dx:Chip
                        x:Name="DeleteSongBtn"
                        Icon="deletesonginterfacesymbol.png"
                        IsIconVisible="True"
                        IsVisible="False"
                        Tap="DeleteSongBtn_Tap"
                        Text="Delete Song" />

                </dx:DXStackLayout>
            </dx:BottomSheet.Content>
        </dx:BottomSheet>

        <dx:BottomSheet
            x:Name="FilteringBtmSheet"
            AllowDismiss="True"
            AllowedState="HalfExpanded"
            HalfExpandedRatio="0.6">
            <dx:BottomSheet.Content>
                <dx:DXStackLayout>
                    <dx:FilterCheckItem
                        AllowIndeterminateInput="True"
                        Context="{Binding FilteringContext, Source={x:Reference SongsCV}}"
                        FieldName="IsFavorite"
                        Text="Is Favorite?" />
                    <dx:FilterNumericRangeSliderItem
                        Context="{Binding FilteringContext, Source={Reference SongsCV}}"
                        FieldName="PlayCount"
                        Max="20"
                        Text="Play Count"
                        ValueStep="1" />
                </dx:DXStackLayout>
            </dx:BottomSheet.Content>
        </dx:BottomSheet>
    </Grid>
</ContentPage>