                            HorizontalOptions="Center"
                            ItemSpacing="15"
                            Orientation="Horizontal">
                            <dx:Chip
                                x:Name="TQLMyFavChip"
                                Tap="TQLMyFavChip_Tap"
                                Text="My Fav" />
                            <dx:Chip
                                x:Name="TQLShuffleChip"
                                Tap="TQLShuffleChip_Tap"
                                Text="Shuffle" />
                            <dx:Chip
                                x:Name="TqlFilter"
