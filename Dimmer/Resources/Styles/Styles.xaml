<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncf="http://schemas.syncfusion.com/maui/toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:dx="http://schemas.devexpress.com/maui"
             xmlns:ratingsView="clr-namespace:Dimmer_MAUI.Utilities.OtherUtils.CustomControl.RatingsView.Views">

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLight}}" />
    </Style>

    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="{AppThemeBinding Light={StaticResource AccentLightL}, Dark={StaticResource AccentDark}}"/>
        <Setter Property="SelectedIndicatorColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}"/>
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource AccentLightL}, Dark={StaticResource AccentDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 5"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="BackgroundColor" Value="Transparent" />
        <!-- Keep background transparent to emphasize the stroke -->
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
    </Style>

    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundLightL}, Dark={StaticResource BackgroundDark}}" />
    </Style>

    <Style TargetType="dx:DXStackLayout">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>
    <Style TargetType="VerticalStackLayout">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="HorizontalStackLayout">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="Grid">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="toolkit:Expander">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLightL}, Dark={StaticResource SurfaceDark}}" />
    </Style>

    <Style TargetType="syncf:SfChipGroup">
        <Setter Property="ChipBackground" Value="{AppThemeBinding Light={StaticResource SurfaceLightL}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="SelectedChipBackground" Value="{AppThemeBinding Light={StaticResource AccentLightL}, Dark={StaticResource AccentDark}}" />
        <Setter Property="SelectedChipTextColor" Value="{AppThemeBinding Light={StaticResource WhiteLightL}, Dark={StaticResource WhiteDark}}" />
        <Setter Property="ChipTextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
    </Style>

    <Style TargetType="syncf:SfEffectsView">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLightL}, Dark={StaticResource SurfaceDark}}" />
    </Style>

    <Style TargetType="syncf:SfTabItem">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLightL}, Dark={StaticResource SurfaceDark}}" />
    </Style>

    <Style TargetType="toolkit:DockLayout">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLightL}, Dark={StaticResource SurfaceDark}}" />
    </Style>

    <Style TargetType="ratingsView:RatingControl">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WhiteLightL}, Dark={StaticResource WhiteDark}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray400LightL}, Dark={StaticResource Gray500Dark}}" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray400LightL}, Dark={StaticResource Gray500Dark}}" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        
    </Style>

    <Style TargetType="Frame">
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style TargetType="ImageButton">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="BorderColor" Value="Transparent"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="HeightRequest" Value="44"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        
    </Style>
    <Style x:Key="SecondarySubText" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="Gray" />
        <Setter Property="Opacity" Value="0.55" />
    </Style>

    <Style TargetType="dx:DXButton">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Dark=#121212,Light=White}"/>
    </Style>
    
    <Style TargetType="Span">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
    </Style>

    <Style TargetType="Label" x:Key="Headline">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="SubHeadline">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="ListView">
        <Setter Property="SeparatorColor" Value="{AppThemeBinding Light={StaticResource AccentLightL}, Dark={StaticResource AccentDark}}" />
        <Setter Property="RefreshControlColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource Gray400LightL}, Dark={StaticResource Gray500Dark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray400LightL}, Dark={StaticResource Gray500Dark}}" />
        <Setter Property="CancelButtonColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        
    </Style>

    <Style TargetType="SearchHandler">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray400LightL}, Dark={StaticResource Gray500Dark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        
    </Style>

    <Style TargetType="Shadow">
        <Setter Property="Radius" Value="15" />
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Brush" Value="{AppThemeBinding Light={StaticResource AccentLightL}, Dark={StaticResource AccentDark}}" />
        <Setter Property="Offset" Value="10,10" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="MaximumTrackColor" Value="{AppThemeBinding Light={StaticResource Gray400LightL}, Dark={StaticResource Gray500Dark}}" />
        <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        
    </Style>

    <Style TargetType="SwipeItem">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AccentLightL}, Dark={StaticResource AccentDark}}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource WhiteLightL}, Dark={StaticResource WhiteDark}}" />
        
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundLightL}, Dark={StaticResource BackgroundDark}}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <!-- Background color for the Shell -->
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLightL}, Dark={StaticResource BackgroundDark}}" />

        <!-- Foreground color for the Shell -->
        <Setter Property="Shell.ForegroundColor" Value="{OnPlatform WinUI={StaticResource AccentDark}, Default={StaticResource AccentDark}}" />

        <!-- Title color for the Shell -->
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />

        <!-- Disabled color for Shell items -->
        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={StaticResource Gray200LightL}, Dark={StaticResource Gray950Dark}}" />

        <!-- Unselected color for Shell items -->
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={StaticResource Gray200LightL}, Dark={StaticResource Gray200Dark}}" />

        <!-- TabBar background color -->
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLightL}, Dark={StaticResource BackgroundDark}}" />

        <!-- TabBar foreground color (for selected tabs) -->
        <Setter Property="Shell.TabBarForegroundColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />

        <!-- TabBar title color -->
        <Setter Property="Shell.TabBarTitleColor" Value="{AppThemeBinding Light={StaticResource WhiteLightL}, Dark={StaticResource WhiteDark}}" />

        <!-- TabBar unselected color -->
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource SecondaryTextLightL}, Dark={StaticResource SecondaryTextDark}}" />

        <!-- Disable shadow on the NavBar -->
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundLightL}, Dark={StaticResource BackgroundDark}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource WhiteLightL}, Dark={StaticResource WhiteDark}}" />
        <Setter Property="IconColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundLightL}, Dark={StaticResource Gray950Dark}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource WhiteLightL}, Dark={StaticResource WhiteDark}}" />
        <Setter Property="UnselectedTabColor" Value="{AppThemeBinding Light={StaticResource Gray200LightL}, Dark={StaticResource Gray950Dark}}" />
        <Setter Property="SelectedTabColor" Value="{AppThemeBinding Light={StaticResource AccentLightL}, Dark={StaticResource AccentDark}}" />
    </Style>

    <Style TargetType="dx:DXButton">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="PressedBackgroundColor" Value="DarkSlateBlue" 
                />
    </Style>
    <Style TargetType="dx:Chip">
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource BorderStrokeL}, Dark={StaticResource BackgroundDark}}" />
        <Setter Property="SelectedBorderColor" Value="{AppThemeBinding Light={StaticResource AccentDark}, Dark={StaticResource AccentLightL}}" />
        
    </Style>
</ResourceDictionary>